{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "metaphors-new",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2025-05-21",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist",
		"not_found_handling": "404-page"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "metaphors-db",
			"database_id": "1fdd72aa-3d22-4348-9e14-261db2602cb0"
		}
	]
}