---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MainCta from "../components/MainCta.astro";
import {
  client,
  SECTORS_QUERY,
  EMPLOYEES_QUERY,
  PRESS_QUOTES_QUERY,
  urlFor,
  imageUrl,
} from "../lib/sanity";
import Press from "../components/Press.astro";
import Cta from "../components/Cta.astro";

const title = "About Metaphors Design | Architectural Practice & Leadership";
const description =
  "Defining modern Indian architecture for four decades. Metaphors Design delivers precise, strategic architectural solutions for corporate, civic, and residential environments.";

const employees = await client.fetch(EMPLOYEES_QUERY);
const leadership = employees.filter(
  (e: any) => e.classification === "leadership",
);
const team = employees.filter((e: any) => e.classification === "senior");

const rawSectors = await client.fetch(SECTORS_QUERY);
const sectors = rawSectors.map((s: any, idx: number) => ({
  index: String(idx + 1).padStart(2, "0"),
  title: s.title,
  body: s.teaser,
  slug: s.slug,
  image: s.image,
}));

const quotes = (await client.fetch(PRESS_QUOTES_QUERY)) || [];
---

<Layout
  title={title}
  description={description}
  canonicalURL="https://metaphors.design/about"
>
  <div class="relative min-h-screen overflow-x-hidden bg-bone">
    <Header />

    <main>
      <!-- ─── HERO HEADER (DIRECT HERO.ASTRO MIRROR) ─────── -->
      <section class="relative w-full py-48 lg:py-56">
        <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
          <div class="max-w-5xl mx-auto flex flex-col items-center text-center">
            <h1
              class="font-medium leading-[0.9] tracking-[-0.045em] text-[clamp(3.5rem,11vw,9rem)] lg:text-[clamp(3.5rem,9vw,8rem)] select-none reveal"
            >
              <span class="block text-charcoal">Architectural Conviction</span>
              <span
                class="block mt-4 lg:mt-6 text-transparent bg-clip-text animate-sheen will-change-[background-position] bg-[linear-gradient(105deg,#6b6b67_0%,#6b6b67_40%,#a8a8a2_48%,#a8a8a2_52%,#6b6b67_60%,#6b6b67_100%)] bg-size-[200%_auto] text-[clamp(1.5rem,6vw,3.5rem)] lg:text-[clamp(2rem,4.5vw,4.5rem)] tracking-[-0.03em] leading-tight"
              >
                Across Every Brief.
              </span>
            </h1>
          </div>
        </div>
      </section>
    </main>

    <!-- ─── STATURE CONTENT GRID ────────────────────────── -->
    <section class="w-full px-6 lg:px-12 pb-32">
      <div class="max-w-[1440px] mx-auto reveal relative">
        <div class="grid grid-cols-1 lg:grid-cols-10 gap-6 lg:gap-8">
          <!-- Large Image column -->
          <div class="lg:col-span-7 flex flex-col gap-12">
            <div class="max-w-3xl reveal">
              <p
                class="hidden lg:block text-[12px] font-bold uppercase tracking-[0.3em] text-charcoal/40 mb-8"
              >
                The Practice — Pune, Est. 1989
              </p>
              <p
                class="text-2xl lg:text-4xl text-charcoal/90 font-light leading-[1.15] tracking-tight"
              >
                A dynamic Pune‑based studio of 80+ architects and designers,
                practising for nearly four decades across commercial,
                residential, retail, healthcare, hospitality, industrial, civic,
                and private residential sectors.
              </p>
            </div>

            <div
              class="group/stature-lg relative overflow-hidden h-[60vh] lg:h-[70vh] transition-all duration-1000 grayscale-65 saturate-88 contrast-104 hover:grayscale-0 hover:saturate-100 hover:contrast-100"
            >
              <img
                src="https://images.unsplash.com/photo-1600607688969-a5bfcd646154?auto=format&fit=crop&w=2000&q=85"
                alt="Metaphors Design — Architectural Space"
                class="w-full h-full object-cover transition-transform duration-[3s] cubic-bezier(0.19, 1, 0.22, 1) group-hover/stature-lg:scale-[1.02]"
                loading="eager"
              />
              <div class="absolute left-0 bottom-0 pointer-events-none z-10">
                <div
                  class="origin-bottom-left translate-x-10 -translate-y-10 bg-bone/50 backdrop-blur-sm px-8 py-4 border border-white/10 transition-all duration-1000 group-hover/stature-lg:bg-bone/90 group-hover/stature-lg:backdrop-blur-xl group-hover/stature-lg:border-white/20"
                >
                  <p
                    class="text-[10px] font-semibold uppercase tracking-[0.5em] text-charcoal whitespace-nowrap transition-all duration-1000"
                  >
                    Metaphors Design Studio - Pune
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Secondary Column (Dialogue Style) -->
          <div
            class="group/stature-sm lg:col-span-3 relative overflow-hidden h-[50vh] lg:h-[80vh] bg-charcoal reveal mt-12 lg:mt-0"
            style="transition-delay: 200ms"
          >
            <img
              src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1000&q=80"
              alt="Precision Backdrop"
              class="absolute inset-0 w-full h-full object-cover grayscale opacity-40 group-hover/stature-sm:opacity-60 transition-all duration-[2s]"
            />
            <div
              class="absolute inset-0 p-8 lg:p-12 bg-linear-to-t from-charcoal via-charcoal/60 to-transparent flex flex-col justify-end z-10"
            >
              <div class="space-y-12 mb-12">
                <div class="h-px w-12 bg-white/20"></div>
                <p
                  class="text-2xl lg:text-4xl text-white font-light leading-normal tracking-tight"
                >
                  Our expertise lies not in a single type of space - <span
                    class="italic text-white/40"
                    >but in the deep architectural thinking we bring to those we
                    create.</span
                  >
                </p>
              </div>

              <div class="pt-8 border-t border-white/10">
                <p
                  class="text-[12px] font-bold uppercase tracking-[0.2em] text-white/30 mb-3"
                >
                  The Stewardship
                </p>
                <p
                  class="text-[12px] text-white/50 leading-relaxed max-w-[240px]"
                >
                  Strategic clarity from initial thought to final handover.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ─── THE PHILOSOPHY (EDITORIAL ASYMMETRY) ────────── -->
  <section class="px-6 py-24 lg:px-12 lg:py-48 mt-24 lg:mt-48 bg-[#f2f1ec]">
    <div class="mx-auto max-w-[1440px]">
      <div
        class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 items-start"
      >
        <!-- Left Column: Core Conviction -->
        <div class="lg:col-span-12 xl:col-span-7 reveal">
          <p
            class="text-[12px] font-bold uppercase tracking-[0.3em] text-charcoal/40 mb-10 font-inter"
          >
            ONE METHOD. ACROSS SECTORS.
          </p>

          <h2
            class="text-4xl lg:text-7xl font-light leading-[1.05] tracking-tight text-charcoal mb-12"
          >
            Collaborative.<br />
            Rigorous.<br />
            Intentional.
          </h2>

          <p
            class="text-xl lg:text-2xl text-charcoal/60 font-light leading-relaxed tracking-tight max-w-xl"
          >
            Our expertise lies in architectural discipline. Across four decades,
            we have proven that the same meticulous method can — and should be —
            applied to every brief, regardless of scale, sector, or complexity.
          </p>
          <div class="mt-12">
            <Cta
              text="Explore Our Engagement"
              href="/engagement"
              invert={true}
            />
          </div>
        </div>

        <!-- Right Column: Stacked Rigour -->
        <div class="lg:col-span-12 xl:col-span-5 flex flex-col space-y-16">
          <article class="reveal" style="transition-delay: 150ms">
            <p
              class="text-xs font-bold uppercase tracking-[0.2em] text-charcoal/40 mb-8"
            >
              CLEAN SLATE RIGOUR
            </p>

            <div class="space-y-4">
              <p class="text-base leading-relaxed text-charcoal/60">
                Every project starts with an empty sheet. Nothing is assumed,
                everything reset to zero. Client brief defines our direction.
                Site and context inform, inspire and challenge our decisions.
              </p>

              <p class="text-base leading-relaxed text-charcoal/60">
                We immerse ourselves in the site and the programme to create
                <span class="italic">the space that needs to be there</span>,
                without ever imposing a signature style upon it.
              </p>
            </div>
          </article>

          <article
            class="reveal pt-16 border-t border-charcoal/10"
            style="transition-delay: 300ms"
          >
            <p
              class="text-xs font-bold uppercase tracking-[0.2em] text-charcoal/40 mb-8"
            >
              COLLABORATIVE STEWARDSHIP
            </p>

            <div class="space-y-4">
              <p class="text-base leading-relaxed text-charcoal/60">
                An idea that cannot survive construction and the test of time
                simply never leaves the drawing board. We intently engage with
                our clients from concept design to final handover in close
                collaboration.
              </p>

              <p class="text-base leading-relaxed text-charcoal/60">
                Original spatial logic and commercial aspects are never
                compromised. The results speak for themselves.
              </p>
            </div>
          </article>

          <article
            class="reveal pt-16 border-t border-charcoal/10"
            style="transition-delay: 450ms"
          >
            <p
              class="text-xs font-bold uppercase tracking-[0.2em] text-charcoal/40 mb-8"
            >
              CONTEMPORARY INSTINCT
            </p>

            <div class="space-y-4">
              <p class="text-base leading-relaxed text-charcoal/60">
                Architecture demands constant reinvention. Our knowledge runs
                deep, but our thinking stays young, dynamic and fresh. We are
                fiercely dedicated to progressive design and technological
                innovation.
              </p>

              <p class="text-base leading-relaxed text-charcoal/60">
                We leverage past insights to pioneer new spatial creations,
                ensuring the practice never stands still.
              </p>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>
  <!-- ─── LEADERSHIP (EDITORIAL PROFILE) ──────────────── -->
  <section class="px-6 py-24 lg:px-12 lg:py-40 border-t border-charcoal/5">
    <div class="mx-auto max-w-[1440px]">
      <div class="reveal mb-30 max-w-5xl">
        <p
          class="text-[12px] font-bold uppercase tracking-[0.3em] text-charcoal/40 mb-8"
        >
          Stewardship
        </p>
        <h2
          class="text-4xl lg:text-6xl font-light tracking-tight text-charcoal leading-none"
        >
          The Practice<br />Foundations.
        </h2>
      </div>

      <div class="space-y-32 lg:space-y-56">
        {
          leadership.map((member, idx) => (
            <div
              class={`reveal grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24 items-start ${idx % 2 !== 0 ? "lg:flex-row-reverse" : ""}`}
            >
              <div class={`lg:col-span-4 ${idx % 2 !== 0 ? "lg:order-2" : ""}`}>
                <div class="relative overflow-hidden aspect-4/5 bg-charcoal/5 group">
                  {member.image && (
                    <img
                      src={imageUrl(member.image, { width: 1000 })}
                      alt={member.name}
                      class="absolute inset-0 w-full h-full object-cover grayscale transition-all duration-1000 group-hover:scale-105 group-hover:grayscale-0"
                    />
                  )}
                </div>
              </div>
              <div class="lg:col-span-7 flex flex-col justify-center pt-8">
                <p class="text-[12px] font-bold uppercase tracking-[0.2em] text-charcoal/40 mb-6">
                  {member.role} — {member.experience}
                </p>
                <h3 class="text-5xl lg:text-7xl font-light tracking-tighter text-charcoal mb-10">
                  {member.name}
                </h3>
                <p class="text-lg lg:text-xl text-charcoal/60 leading-relaxed max-w-2xl mb-12">
                  {member.body}
                </p>

                <div class="flex flex-wrap items-center gap-6 mb-12">
                  {((member.sectors && member.sectors.length > 0) ||
                    (member.disciplines && member.disciplines.length > 0)) && (
                    <div class="h-px w-8 bg-charcoal/5 hidden lg:block" />
                  )}
                </div>

                {((member.sectors && member.sectors.length > 0) ||
                  (member.disciplines && member.disciplines.length > 0)) && (
                  <div class="flex flex-wrap gap-2">
                    {member.sectors?.filter(Boolean).map((s: any) => (
                      <a
                        href={`/sectors/${s.slug}`}
                        class="text-[9px] font-bold uppercase tracking-[0.2em] text-charcoal/40 bg-charcoal/5 px-3 py-2 rounded-sm hover:bg-charcoal/10 transition-colors"
                      >
                        {s.title}
                      </a>
                    ))}
                    {member.disciplines?.filter(Boolean).map((d: any) => (
                      <a
                        href={`/disciplines/${d.slug}`}
                        class="text-[9px] font-bold uppercase tracking-[0.2em] text-charcoal/40 bg-charcoal/5 px-3 py-2 rounded-sm hover:bg-charcoal/10 transition-colors"
                      >
                        {d.title}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─── TEAM (MINIMAL GRID) ────────────────────────── -->
  <section class="px-6 py-24 lg:px-12 lg:py-48 bg-[#f2f1ec]">
    <div class="mx-auto max-w-[1440px]">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
        <div class="lg:col-span-4">
          <p
            class="text-[12px] font-bold uppercase tracking-[0.3em] text-charcoal/40 mb-8"
          >
            Senior Bench
          </p>
          <h2
            class="text-4xl lg:text-6xl font-light tracking-tight text-charcoal leading-none"
          >
            Specialists in Rigour.
          </h2>
        </div>
        <div
          class="lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-12"
        >
          {
            team.map((member) => (
              <article class="reveal border-t border-charcoal/10 pt-10">
                <div class="grid grid-cols-1 md:grid-cols-[120px_1fr] gap-8 items-start">
                  <div class="aspect-square bg-charcoal/5 overflow-hidden">
                    {member.image && (
                      <img
                        src={imageUrl(member.image, {
                          width: 300,
                          height: 300,
                          fit: "crop",
                        })}
                        alt={member.name}
                        class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
                      />
                    )}
                  </div>
                  <div>
                    {member.experience && (
                      <p class="text-[11px] font-bold uppercase tracking-widest text-charcoal/40 mb-2">
                        {member.experience}
                      </p>
                    )}
                    <p class="text-xl font-medium text-charcoal mb-2">
                      {member.name}
                    </p>
                    <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-charcoal/40 mb-4">
                      {member.role}
                    </p>
                    <p class="text-sm leading-relaxed text-charcoal/50 mb-6">
                      {member.body}
                    </p>
                  </div>
                </div>

                {((member.sectors && member.sectors.length > 0) ||
                  (member.disciplines && member.disciplines.length > 0)) && (
                  <div class="pt-6 border-t border-charcoal/5 space-y-4">
                    {member.sectors && member.sectors.length > 0 && (
                      <div class="flex flex-wrap gap-2">
                        {member.sectors.filter(Boolean).map((s: any) => (
                          <a
                            href={`/sectors/${s.slug}`}
                            class="text-[8px] font-bold uppercase tracking-[0.2em] text-charcoal/60 bg-charcoal/5 px-2.5 py-1.5 rounded-sm hover:bg-charcoal/10 transition-colors"
                          >
                            {s.title}
                          </a>
                        ))}
                      </div>
                    )}

                    {member.sectors &&
                      member.sectors.length > 0 &&
                      member.disciplines &&
                      member.disciplines.length > 0 && (
                        <div class="h-[1px] w-12 bg-charcoal/5" />
                      )}

                    {member.disciplines && member.disciplines.length > 0 && (
                      <div class="flex flex-wrap gap-2">
                        {member.disciplines.filter(Boolean).map((d: any) => (
                          <a
                            href={`/disciplines/${d.slug}`}
                            class="text-[8px] font-bold uppercase tracking-[0.2em] text-charcoal/60 bg-charcoal/5 px-2.5 py-1.5 rounded-sm hover:bg-charcoal/10 transition-colors"
                          >
                            {d.title}
                          </a>
                        ))}
                      </div>
                    )}
                  </div>
                )}
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ─── THE INDUSTRY RECORD (CINEMATIC RECORD) ──────── -->
  <section class="w-full bg-bone py-32 lg:py-48 border-t border-charcoal/5">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
      <div
        class="flex flex-col lg:flex-row lg:items-end justify-between gap-12 mb-30"
      >
        <div class="text-center lg:text-left w-full">
          <p
            class="text-[12px] font-bold uppercase tracking-[0.3em] text-charcoal/30 mb-8 reveal font-inter"
          >
            The Industry Record
          </p>
          <h2
            class="text-4xl lg:text-6xl font-light tracking-tight text-charcoal reveal"
          >
            Observed.<br />Analysed.<br />Acclaimed.
          </h2>
        </div>

        <div
          class="reveal flex flex-col items-center text-center lg:text-right lg:items-end lg:justify-end gap-10 lg:pt-12"
        >
          <p
            class="text-[10px] sm:text-xs font-semibold leading-loose tracking-[0.25em] text-charcoal/60 uppercase max-w-2xl"
          >
            Metaphors Design is consistently recognised across for it's work.
            Discover our insights, awards and media coverage.
          </p>
          <div class="flex justify-center lg:justify-end w-full">
            <Cta text="View Full Record" href="/press" invert={true} />
          </div>
        </div>
      </div>

      <Press quotes={quotes.slice(0, 3)} layout="minimal" />
    </div>
  </section>

  <!-- ─── SECTORS (ASYMMETRICAL TILES) ────────────────── -->
  <section class="bg-charcoal px-6 py-24 lg:px-12 lg:py-48">
    <div class="mx-auto max-w-[1440px]">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-32 mb-24 items-end">
        <div>
          <p
            class="text-[12px] font-bold uppercase tracking-[0.3em] text-bone/40 mb-10"
          >
            Where we practise
          </p>
          <h2
            class="text-5xl lg:text-8xl font-light tracking-tighter text-bone leading-[0.9]"
          >
            One Method.<br />Eight Sectors.
          </h2>
        </div>
        <p
          class="text-lg lg:text-2xl text-bone/50 font-light leading-snug max-w-lg lg:ml-auto"
        >
          Our method is rigour. Our experience taught us that a resort and a
          corporate campus require the same architectural discipline as a
          residential project or a healthcare facility.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {
          sectors.map((s, idx) => (
            <a
              href={`/sectors/${s.slug}`}
              class="group relative block aspect-4/5 overflow-hidden border border-bone/10 reveal"
              style={`transition-delay: ${idx * 100}ms`}
            >
              {/* Background Image */}
              <div
                class="absolute inset-0 grayscale transition-transform duration-[2s] group-hover:scale-110 group-hover:grayscale-0"
                style={`background-image: url(${s.image ? urlFor(s.image).width(800).url() : ""}); background-size: cover; background-position: center;`}
              />

              {/* Overlay */}
              <div class="absolute inset-0 bg-linear-to-t from-charcoal/90 via-charcoal/40 to-transparent transition-opacity duration-700 group-hover:opacity-80" />

              {/* Content */}
              <div class="relative h-full p-8 flex flex-col justify-end">
                <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-bone/40 mb-4">
                  {s.index}
                </p>
                <h3 class="text-2xl font-light tracking-tight text-bone mb-3">
                  {s.title}
                </h3>
                <p class="text-xs leading-relaxed text-bone/60 line-clamp-3 group-hover:text-bone/80 transition-colors">
                  {s.body}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─── FINAL CTA (STRATEGIC CLARITY) ────────────────── -->
  <MainCta
    section={{
      eyebrow: "Engagement",
      headline: "Begin the Dialogue.",
      tagline:
        "You don't need a finished brief. Ambition and intent are enough to start the conversation. We bring the strategic clarity to carry your project from first idea to final handover.",
      ctaLabel: "Start the Conversation",
      ctaUrl: "/contact",
    }}
    className="bg-bone"
  />

  <Footer />
</Layout>
