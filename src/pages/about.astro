---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MainCta from "../components/MainCta.astro";
import {
  client,
  SECTORS_QUERY,
  EMPLOYEES_QUERY,
  PRESS_QUOTES_QUERY,
  urlFor,
  imageUrl,
} from "../lib/sanity";
import Press from "../components/Press.astro";
import Cta from "../components/Cta.astro";

const title = "About Metaphors Design | Architectural Practice & Leadership";
const description =
  "Defining modern Indian architecture for four decades. Metaphors Design delivers precise, strategic architectural solutions for corporate, civic, and residential environments.";

const employees = await client.fetch(EMPLOYEES_QUERY);
const leadership = employees.filter((e: any) => e.classification === "leadership");
const team = employees.filter((e: any) => e.classification === "senior");

const rawSectors = await client.fetch(SECTORS_QUERY);
const sectors = rawSectors.map((s: any, idx: number) => ({
  index: String(idx + 1).padStart(2, "0"),
  title: s.title,
  body: s.teaser,
  slug: s.slug,
  image: s.image,
}));

const quotes = (await client.fetch(PRESS_QUOTES_QUERY)) || [];
---

<Layout title={title} description={description} canonicalURL="https://metaphors.design/about">
  <div class="bg-bone relative min-h-screen overflow-x-hidden">
    <Header />

    <main>
      <!-- ─── HERO HEADER (DIRECT HERO.ASTRO MIRROR) ─────── -->
      <section class="relative w-full py-48 lg:py-56">
        <div class="mx-auto max-w-[1440px] px-6 lg:px-12">
          <div class="mx-auto flex max-w-5xl flex-col items-center text-center">
            <h1
              class="reveal text-[clamp(3.5rem,11vw,9rem)] leading-[0.9] font-medium tracking-[-0.045em] select-none lg:text-[clamp(3.5rem,9vw,8rem)]"
            >
              <span class="text-charcoal block">Architectural Conviction</span>
              <span
                class="animate-sheen mt-4 block bg-[linear-gradient(105deg,#6b6b67_0%,#6b6b67_40%,#a8a8a2_48%,#a8a8a2_52%,#6b6b67_60%,#6b6b67_100%)] bg-size-[200%_auto] bg-clip-text text-[clamp(1.5rem,6vw,3.5rem)] leading-tight tracking-[-0.03em] text-transparent will-change-[background-position] lg:mt-6 lg:text-[clamp(2rem,4.5vw,4.5rem)]"
              >
                Across Every Brief.
              </span>
            </h1>
          </div>
        </div>
      </section>
    </main>

    <!-- ─── STATURE CONTENT GRID ────────────────────────── -->
    <section class="w-full px-6 pb-32 lg:px-12">
      <div class="reveal relative mx-auto max-w-[1440px]">
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-10 lg:gap-8">
          <!-- Large Image column -->
          <div class="flex flex-col gap-12 lg:col-span-7">
            <div class="reveal max-w-3xl">
              <p
                class="text-charcoal/40 mb-8 hidden text-[12px] font-bold tracking-[0.3em] uppercase lg:block"
              >
                The Practice — Pune, Est. 1989
              </p>
              <p
                class="text-charcoal/90 text-2xl leading-[1.15] font-light tracking-tight lg:text-4xl"
              >
                A dynamic Pune‑based studio of 80+ architects and designers, practising for nearly
                four decades across commercial, residential, retail, healthcare, hospitality,
                industrial, civic, and private residential sectors.
              </p>
            </div>

            <div
              class="group/stature-lg relative h-[60vh] overflow-hidden contrast-104 grayscale-65 saturate-88 transition-all duration-1000 hover:contrast-100 hover:grayscale-0 hover:saturate-100 lg:h-[70vh]"
            >
              <img
                src="https://images.unsplash.com/photo-1600607688969-a5bfcd646154?auto=format&fit=crop&w=2000&q=85"
                alt="Metaphors Design — Architectural Space"
                class="cubic-bezier(0.19, 1, 0.22, 1) h-full w-full object-cover transition-transform duration-[3s] group-hover/stature-lg:scale-[1.02]"
                loading="eager"
              />
              <div class="pointer-events-none absolute bottom-0 left-0 z-10">
                <div
                  class="bg-bone/50 group-hover/stature-lg:bg-bone/90 origin-bottom-left translate-x-10 -translate-y-10 border border-white/10 px-8 py-4 backdrop-blur-sm transition-all duration-1000 group-hover/stature-lg:border-white/20 group-hover/stature-lg:backdrop-blur-xl"
                >
                  <p
                    class="text-charcoal text-[10px] font-semibold tracking-[0.5em] whitespace-nowrap uppercase transition-all duration-1000"
                  >
                    Metaphors Design Studio - Pune
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Secondary Column (Dialogue Style) -->
          <div
            class="group/stature-sm bg-charcoal reveal relative mt-12 h-[50vh] overflow-hidden lg:col-span-3 lg:mt-0 lg:h-[80vh]"
            style="transition-delay: 200ms"
          >
            <img
              src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1000&q=80"
              alt="Precision Backdrop"
              class="absolute inset-0 h-full w-full object-cover opacity-40 grayscale transition-all duration-[2s] group-hover/stature-sm:opacity-60"
            />
            <div
              class="from-charcoal via-charcoal/60 absolute inset-0 z-10 flex flex-col justify-end bg-linear-to-t to-transparent p-8 lg:p-12"
            >
              <div class="mb-12 space-y-12">
                <div class="h-px w-12 bg-white/20"></div>
                <p class="text-2xl leading-normal font-light tracking-tight text-white lg:text-4xl">
                  Our expertise lies not in a single type of space - <span
                    class="text-white/40 italic"
                    >but in the deep architectural thinking we bring to those we create.</span
                  >
                </p>
              </div>

              <div class="border-t border-white/10 pt-8">
                <p class="mb-3 text-[12px] font-bold tracking-[0.2em] text-white/30 uppercase">
                  The Stewardship
                </p>
                <p class="max-w-[240px] text-[12px] leading-relaxed text-white/50">
                  Strategic clarity from initial thought to final handover.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ─── THE PHILOSOPHY (EDITORIAL ASYMMETRY) ────────── -->
  <section class="mt-24 bg-[#f2f1ec] px-6 py-24 lg:mt-48 lg:px-12 lg:py-48">
    <div class="mx-auto max-w-[1440px]">
      <div class="grid grid-cols-1 items-start gap-16 lg:grid-cols-12 lg:gap-24">
        <!-- Left Column: Core Conviction -->
        <div class="reveal lg:col-span-12 xl:col-span-7">
          <p
            class="text-charcoal/40 font-inter mb-10 text-[12px] font-bold tracking-[0.3em] uppercase"
          >
            ONE METHOD. ACROSS SECTORS.
          </p>

          <h2
            class="text-charcoal mb-12 text-4xl leading-[1.05] font-light tracking-tight lg:text-7xl"
          >
            Collaborative.<br />
            Rigorous.<br />
            Intentional.
          </h2>

          <p
            class="text-charcoal/60 max-w-xl text-xl leading-relaxed font-light tracking-tight lg:text-2xl"
          >
            Our expertise lies in architectural discipline. Across four decades, we have proven that
            the same meticulous method can — and should be — applied to every brief, regardless of
            scale, sector, or complexity.
          </p>
          <div class="mt-12">
            <Cta text="How We Work" href="/engagement" invert={true} />
          </div>
        </div>

        <!-- Right Column: Stacked Rigour (Timeline Feel) -->
        <div class="relative lg:col-span-12 xl:col-span-5">
          <!-- Vertical timeline hairline -->
          <div class="bg-charcoal/10 absolute top-3 bottom-0 left-0 w-px"></div>

          <div class="flex flex-col space-y-16 pl-12 sm:pl-16 lg:space-y-24 lg:pl-24">
            <article class="group reveal relative" style="transition-delay: 150ms">
              <!-- Timeline dot -->
              <div
                class="bg-charcoal ring-bone group-hover:bg-charcoal/80 absolute top-1.5 -left-[52px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8] sm:-left-[68px] lg:-left-[100px]"
              >
              </div>

              <div
                class="group-hover:bg-charcoal/5 -mx-6 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:-mx-10 lg:p-10"
              >
                <p class="text-charcoal/90 mb-8 text-xs font-bold tracking-[0.2em] uppercase">
                  ZERO ASSUMPTION
                </p>
                <div class="space-y-4">
                  <p class="text-charcoal/60 text-base leading-relaxed">
                    Every site is different. Every brief is different. Every client is different.
                    The worst thing an architect can bring to that is a predetermined answer.
                  </p>
                  <p class="text-charcoal text-base leading-relaxed font-bold">
                    We start from zero. Every time.
                  </p>
                </div>
              </div>
            </article>

            <article class="group reveal relative" style="transition-delay: 300ms">
              <!-- Timeline dot -->
              <div
                class="bg-charcoal ring-bone group-hover:bg-charcoal/80 absolute top-1.5 -left-[52px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8] sm:-left-[68px] lg:-left-[100px]"
              >
              </div>

              <div
                class="group-hover:bg-charcoal/5 -mx-6 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:-mx-10 lg:p-10"
              >
                <p class="text-charcoal/90 mb-8 text-xs font-bold tracking-[0.2em] uppercase">
                  COLLABORATIVE INTENT
                </p>
                <div class="space-y-4">
                  <p class="text-charcoal/60 text-base leading-relaxed">
                    The gap between a great design and a great finished space is almost always the
                    same thing: a breakdown in alignment somewhere between concept and completion.
                  </p>
                  <p class="text-charcoal text-base leading-relaxed font-bold">
                    We stay in the room. From first brief to final handover.
                  </p>
                </div>
              </div>
            </article>

            <article class="group reveal relative" style="transition-delay: 450ms">
              <!-- Timeline dot -->
              <div
                class="bg-charcoal ring-bone group-hover:bg-charcoal/80 absolute top-1.5 -left-[52px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8] sm:-left-[68px] lg:-left-[100px]"
              >
              </div>

              <div
                class="group-hover:bg-charcoal/5 -mx-6 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:-mx-10 lg:p-10"
              >
                <p class="text-charcoal/90 mb-8 text-xs font-bold tracking-[0.2em] uppercase">
                  CONTEMPORARY INSTINCT
                </p>
                <div class="space-y-4">
                  <p class="text-charcoal/60 text-base leading-relaxed">
                    Experience is only valuable if it does not harden into habit. Knowing what has
                    worked before is useful. Assuming it will work again is how practices stop being
                    relevant.
                  </p>
                  <p class="text-charcoal text-base leading-relaxed font-bold">
                    We apply what we know. We question everything else.
                  </p>
                </div>
              </div>
            </article>

            <article class="group reveal relative" style="transition-delay: 600ms">
              <!-- Timeline dot -->
              <div
                class="bg-charcoal ring-bone group-hover:bg-charcoal/80 absolute top-1.5 -left-[52px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8] sm:-left-[68px] lg:-left-[100px]"
              >
              </div>

              <div
                class="group-hover:bg-charcoal/5 -mx-6 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:-mx-10 lg:p-10"
              >
                <p class="text-charcoal/90 mb-8 text-xs font-bold tracking-[0.2em] uppercase">
                  SUSTAINABLE RIGOUR
                </p>
                <div class="space-y-4">
                  <p class="text-charcoal/60 text-base leading-relaxed">
                    Sustainability is not a feature added at the end of a design process. It runs
                    through every decision we make — from how we read a brief, to what we specify,
                    to how a space is built and how long it remains relevant.
                  </p>
                  <p class="text-charcoal text-base leading-relaxed font-bold">
                    For us, responsible execution is not a credential. It is understood.
                  </p>
                </div>
              </div>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- ─── LEADERSHIP (EDITORIAL PROFILE) ──────────────── -->
  <section class="border-charcoal/5 border-t px-6 py-24 lg:px-12 lg:py-40">
    <div class="mx-auto max-w-[1440px]">
      <div class="reveal mb-30 max-w-5xl">
        <p class="text-charcoal/40 mb-8 text-[12px] font-bold tracking-[0.3em] uppercase">
          Stewardship
        </p>
        <h2 class="text-charcoal text-4xl leading-none font-light tracking-tight lg:text-6xl">
          The Practice<br />Foundations.
        </h2>
      </div>

      <div class="space-y-32 lg:space-y-56">
        {
          leadership.map(
            (
              member: {
                image: object;
                name: unknown;
                role: unknown;
                experience: unknown;
                body: unknown;
                sectors: any[];
                disciplines: any[];
              },
              idx: number,
            ) => (
              <div
                class={`reveal grid grid-cols-1 items-start gap-12 lg:grid-cols-12 lg:gap-24 ${idx % 2 !== 0 ? "lg:flex-row-reverse" : ""}`}
              >
                <div class={`lg:col-span-4 ${idx % 2 !== 0 ? "lg:order-2" : ""}`}>
                  <div class="bg-charcoal/5 group relative aspect-4/5 overflow-hidden">
                    {member.image && (
                      <img
                        src={imageUrl(member.image, { width: 1000 })}
                        alt={member.name}
                        class="absolute inset-0 h-full w-full object-cover grayscale transition-all duration-1000 group-hover:scale-105 group-hover:grayscale-0"
                      />
                    )}
                  </div>
                </div>
                <div class="flex flex-col justify-center pt-8 lg:col-span-7">
                  <p class="text-charcoal/40 mb-6 text-[12px] font-bold tracking-[0.2em] uppercase">
                    {member.role} — {member.experience}
                  </p>
                  <h3 class="text-charcoal mb-10 text-5xl font-light tracking-tighter lg:text-7xl">
                    {member.name}
                  </h3>
                  <p class="text-charcoal/60 mb-12 max-w-2xl text-lg leading-relaxed lg:text-xl">
                    {member.body}
                  </p>

                  <div class="mb-12 flex flex-wrap items-center gap-6">
                    {((member.sectors && member.sectors.length > 0) ||
                      (member.disciplines && member.disciplines.length > 0)) && (
                      <div class="bg-charcoal/5 hidden h-px w-8 lg:block" />
                    )}
                  </div>

                  {((member.sectors && member.sectors.length > 0) ||
                    (member.disciplines && member.disciplines.length > 0)) && (
                    <div class="flex flex-wrap gap-2">
                      {member.sectors?.filter(Boolean).map((s: any) => (
                        <a
                          href={`/sectors/${s.slug}`}
                          class="text-charcoal/40 bg-charcoal/5 hover:bg-charcoal/10 rounded-sm px-3 py-2 text-[9px] font-bold tracking-[0.2em] uppercase transition-colors"
                        >
                          {s.title}
                        </a>
                      ))}
                      {member.disciplines?.filter(Boolean).map((d: any) => (
                        <a
                          href={`/disciplines/${d.slug}`}
                          class="text-charcoal/40 bg-charcoal/5 hover:bg-charcoal/10 rounded-sm px-3 py-2 text-[9px] font-bold tracking-[0.2em] uppercase transition-colors"
                        >
                          {d.title}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ),
          )
        }
      </div>
    </div>
  </section>

  <!-- ─── TEAM (MINIMAL GRID) ────────────────────────── -->
  <section class="bg-[#f2f1ec] px-6 py-24 lg:px-12 lg:py-48">
    <div class="mx-auto max-w-[1440px]">
      <div class="grid grid-cols-1 gap-16 lg:grid-cols-12 lg:gap-24">
        <div class="lg:col-span-4">
          <p class="text-charcoal/40 mb-8 text-[12px] font-bold tracking-[0.3em] uppercase">
            Senior Bench
          </p>
          <h2 class="text-charcoal text-4xl leading-none font-light tracking-tight lg:text-6xl">
            Specialists in Rigour.
          </h2>
        </div>
        <div class="grid grid-cols-1 gap-x-16 gap-y-12 md:grid-cols-2 lg:col-span-8">
          {
            team.map(
              (member: {
                image: object;
                name: unknown;
                experience: unknown;
                role: unknown;
                body: unknown;
                sectors: any[];
                disciplines: any[];
              }) => (
                <article class="reveal border-charcoal/10 border-t pt-10">
                  <div class="grid grid-cols-1 items-start gap-8 md:grid-cols-[120px_1fr]">
                    <div class="bg-charcoal/5 aspect-square overflow-hidden">
                      {member.image && (
                        <img
                          src={imageUrl(member.image, {
                            width: 300,
                            height: 300,
                            fit: "crop",
                          })}
                          alt={member.name}
                          class="h-full w-full object-cover grayscale transition-all duration-700 hover:grayscale-0"
                        />
                      )}
                    </div>
                    <div>
                      {member.experience && (
                        <p class="text-charcoal/40 mb-2 text-[11px] font-bold tracking-widest uppercase">
                          {member.experience}
                        </p>
                      )}
                      <p class="text-charcoal mb-2 text-xl font-medium">{member.name}</p>
                      <p class="text-charcoal/40 mb-4 text-[11px] font-bold tracking-[0.2em] uppercase">
                        {member.role}
                      </p>
                      <p class="text-charcoal/50 mb-6 text-sm leading-relaxed">{member.body}</p>
                    </div>
                  </div>

                  {((member.sectors && member.sectors.length > 0) ||
                    (member.disciplines && member.disciplines.length > 0)) && (
                    <div class="border-charcoal/5 space-y-4 border-t pt-6">
                      {member.sectors && member.sectors.length > 0 && (
                        <div class="flex flex-wrap gap-2">
                          {member.sectors.filter(Boolean).map((s: any) => (
                            <a
                              href={`/sectors/${s.slug}`}
                              class="text-charcoal/60 bg-charcoal/5 hover:bg-charcoal/10 rounded-sm px-2.5 py-1.5 text-[8px] font-bold tracking-[0.2em] uppercase transition-colors"
                            >
                              {s.title}
                            </a>
                          ))}
                        </div>
                      )}

                      {member.sectors &&
                        member.sectors.length > 0 &&
                        member.disciplines &&
                        member.disciplines.length > 0 && <div class="bg-charcoal/5 h-px w-12" />}

                      {member.disciplines && member.disciplines.length > 0 && (
                        <div class="flex flex-wrap gap-2">
                          {member.disciplines.filter(Boolean).map((d: any) => (
                            <a
                              href={`/disciplines/${d.slug}`}
                              class="text-charcoal/60 bg-charcoal/5 hover:bg-charcoal/10 rounded-sm px-2.5 py-1.5 text-[8px] font-bold tracking-[0.2em] uppercase transition-colors"
                            >
                              {d.title}
                            </a>
                          ))}
                        </div>
                      )}
                    </div>
                  )}
                </article>
              ),
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ─── THE INDUSTRY RECORD (CINEMATIC RECORD) ──────── -->
  <section class="bg-bone border-charcoal/5 w-full border-t py-32 lg:py-48">
    <div class="mx-auto max-w-[1440px] px-6 lg:px-12">
      <div class="mb-30 flex flex-col justify-between gap-12 lg:flex-row lg:items-end">
        <div class="w-full text-center lg:text-left">
          <p
            class="text-charcoal/30 reveal font-inter mb-8 text-[12px] font-bold tracking-[0.3em] uppercase"
          >
            The Industry Record
          </p>
          <h2 class="text-charcoal reveal text-4xl font-light tracking-tight lg:text-6xl">
            Observed.<br />Analysed.<br />Acclaimed.
          </h2>
        </div>

        <div
          class="reveal flex flex-col items-center gap-10 text-center lg:items-end lg:justify-end lg:pt-12 lg:text-right"
        >
          <p
            class="text-charcoal/60 max-w-2xl text-[10px] leading-loose font-semibold tracking-[0.25em] uppercase sm:text-xs"
          >
            Metaphors Design is consistently recognised across for it's work. Discover our insights,
            awards and media coverage.
          </p>
          <div class="flex w-full justify-center lg:justify-end">
            <Cta text="View Full Record" href="/press" invert={true} />
          </div>
        </div>
      </div>

      <Press quotes={quotes.slice(0, 3)} layout="minimal" />
    </div>
  </section>

  <!-- ─── SECTORS (ASYMMETRICAL TILES) ────────────────── -->
  <section class="bg-charcoal px-6 py-24 lg:px-12 lg:py-48">
    <div class="mx-auto max-w-[1440px]">
      <div class="mb-24 grid items-end gap-16 lg:grid-cols-2 lg:gap-32">
        <div>
          <p class="text-bone/40 mb-10 text-[12px] font-bold tracking-[0.3em] uppercase">
            Where we practise
          </p>
          <h2 class="text-bone text-5xl leading-[0.9] font-light tracking-tighter lg:text-8xl">
            One Method.<br />Eight Sectors.
          </h2>
        </div>
        <p class="text-bone/50 max-w-lg text-lg leading-snug font-light lg:ml-auto lg:text-2xl">
          Our method is rigour. Our experience taught us that a resort and a corporate campus
          require the same architectural discipline as a residential project or a healthcare
          facility.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
        {
          sectors.map(
            (
              s: {
                slug: any;
                image: any;
                index: unknown;
                title: unknown;
                body: unknown;
              },
              idx: number,
            ) => (
              <a
                href={`/sectors/${s.slug}`}
                class="group border-bone/10 reveal relative block aspect-4/5 overflow-hidden border"
                style={`transition-delay: ${idx * 100}ms`}
              >
                {/* Background Image */}
                <div
                  class="absolute inset-0 grayscale transition-transform duration-[2s] group-hover:scale-110 group-hover:grayscale-0"
                  style={`background-image: url(${s.image ? urlFor(s.image).width(800).url() : ""}); background-size: cover; background-position: center;`}
                />

                {/* Overlay */}
                <div class="from-charcoal/90 via-charcoal/40 absolute inset-0 bg-linear-to-t to-transparent transition-opacity duration-700 group-hover:opacity-80" />

                {/* Content */}
                <div class="relative flex h-full flex-col justify-end p-8">
                  <p class="text-bone/40 mb-4 text-[10px] font-bold tracking-[0.4em] uppercase">
                    {s.index}
                  </p>
                  <h3 class="text-bone mb-3 text-2xl font-light tracking-tight">{s.title}</h3>
                  <p class="text-bone/60 group-hover:text-bone/80 line-clamp-3 text-xs leading-relaxed transition-colors">
                    {s.body}
                  </p>
                </div>
              </a>
            ),
          )
        }
      </div>
    </div>
  </section>

  <!-- ─── FINAL CTA (STRATEGIC CLARITY) ────────────────── -->
  <MainCta
    section={{
      eyebrow: "Engagement",
      headline: "Begin the Dialogue.",
      tagline:
        "You don't need a finished brief. Ambition and intent are enough to start the conversation. We bring the strategic clarity to carry your project from first idea to final handover.",
      ctaLabel: "Start the Conversation",
