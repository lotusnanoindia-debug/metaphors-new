---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MainCta from "../components/MainCta.astro";
import Cta from "../components/Cta.astro";
import Icon from "../components/Icon.astro";

const title = "Architecture | Metaphors Design";
const description =
  "Form is the Consequence of a Resolved Brief, Never the Premise. Forty years of architectural practice across India.";
const canonicalURL = "https://metaphors.design/disciplines/architecture";

const projectSectors = [
  { title: "Commercial & Workplace", slug: "commercial-and-workplace" },
  { title: "Residential & Township", slug: "residential-and-township" },
  { title: "Retail & Mixed-Use", slug: "retail-and-mixed-use" },
  { title: "Healthcare", slug: "healthcare" },
  { title: "Hospitality & Leisure", slug: "hospitality-and-leisure" },
  { title: "Industrial & Logistics", slug: "industrial-and-logistics" },
  { title: "Civic & Education", slug: "civic-and-education" },
  { title: "Private Residences", slug: "private-residences" },
];

const principles = [
  {
    number: "01",
    title: "Structure Is Not Separate from Space",
    text: "We do not design skins to conceal engineering. The load-bearing logic of a building should inform its spatial character. When structure and intent are unified, the architecture achieves an inherent, unforced clarity — one that no amount of surface treatment can substitute for.",
  },
  {
    number: "02",
    title: "The Site Is Never Neutral",
    text: "Every plot carries a pre-existing dialogue of light, orientation, topography, and urban condition. We do not impose generic forms onto passive land. Our work begins by interrogating what the site demands and what it will bear — and that reading directly dictates form, not the other way around.",
  },
  {
    number: "03",
    title: "The Facade Earns Its Right",
    text: "A building's exterior is not a canvas for arbitrary expression. It is the most public decision an architect makes — one that must answer to the interior it wraps, the street it addresses, and the climate it mediates. The facade is resolved at concept stage, not specified at tender.",
  },
  {
    number: "04",
    title: "Longevity Is Not Negotiable",
    text: "Material responsibility and longevity are not items on a client brief. They are conditions of how we work — applied without exception, regardless of budget pressures, market trends, or client preference. We are accountable to the building's future, not only its commission.",
  },
];

const sectorBlocks = [
  {
    title: "Commercial & Workplace",
    slug: "commercial-and-workplace",
    directive: "Asset Efficiency & Lifecycle",
    image:
      "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=2070&auto=format&fit=crop",
    text: [
      "Floor plate efficiency, column-free spans, ceiling heights that admit genuine natural light, and core placement that does not compromise future fitout flexibility — these are architectural decisions that determine tenant retention and rental performance for the life of the asset.",
      "A commercial building that ages poorly within seven years has failed its primary brief regardless of how it photographs at completion.",
      "These parameters are resolved at concept stage, independent of fitout.",
    ],
  },
  {
    title: "Residential & Township",
    slug: "residential-and-township",
    directive: "Human-Centric Urbanism",
    image:
      "https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?q=80&w=2070&auto=format&fit=crop",
    text: [
      "A residential development that cannot justify its premium pricing through lived experience has failed — regardless of unit count.",
      "Residential design begins with the quality of light reaching a bedroom at 7am and the cross-ventilation that makes a flat habitable without air conditioning.",
      "Maximum GFA and density are the outcomes of a well-resolved brief; they are never the premise.",
    ],
  },
  {
    title: "Retail & Mixed-Use",
    slug: "retail-and-mixed-use",
    directive: "Spatial Choreography",
    image:
      "https://images.unsplash.com/photo-1519567241046-7f570eee3ce6?q=80&w=2070&auto=format&fit=crop",
    text: [
      "Footfall fails and upper floors stay dead when the underlying spatial logic is wrong.",
      "The architectural decisions that determine commercial performance — sightlines, facade legibility from 200 metres, approach sequence, vertical circulation — must be resolved before the first schematic is approved.",
      "Spatial choreography is engineered at concept stage, not corrected during fitout.",
    ],
  },
  {
    title: "Healthcare",
    slug: "healthcare",
    directive: "Clinical Operational Rigour",
    image:
      "https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?q=80&w=2070&auto=format&fit=crop",
    text: [
      "A hospital brief is an operational problem before it is a design problem.",
      "Clinical workflow, infection control, wayfinding, and the anxiety-reduction that good spatial design provides to patients and families are the primary commission.",
      "The distinction between clinical workflow and mere circulation is the foundation of healthcare architecture.",
    ],
  },
  {
    title: "Hospitality & Leisure",
    slug: "hospitality-and-leisure",
    directive: "Operational Excellence",
    image:
      "https://images.unsplash.com/photo-1566073771259-6a8506099945?q=80&w=2070&auto=format&fit=crop",
    text: [
      "The arrival sequence, lobby orientation, and guest room proportion are architectural decisions that directly determine review scores — not interior design choices made after the fact.",
      "Hospitality architecture exists at the intersection of operator standards, owner ambitions, and site reality.",
      "A building that fails operationally has delivered a room-count, not a destination.",
    ],
  },
  {
    title: "Industrial & Logistics",
    slug: "industrial-and-logistics",
    directive: "Infrastructure Adaptation",
    image:
      "https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=2070&auto=format&fit=crop",
    text: [
      "A facility becomes operationally obsolete within a decade when the column grid cannot accommodate modern racking or the floor loading was specified for the first occupant rather than the range of future uses.",
      "Industrial commissions are infrastructure problems, requiring resolution for operational flexibility, workforce environment, and adaptation.",
    ],
  },
  {
    title: "Civic & Education",
    slug: "civic-and-education",
    directive: "Social Sustainability",
    image:
      "https://images.unsplash.com/photo-1541339907198-e08756ebafe3?q=80&w=2070&auto=format&fit=crop",
    text: [
      "Civic and educational buildings carry a social obligation that commercial projects do not.",
      "A well-designed school produces demonstrably better outcomes for the people inside it.",
      "Civic architecture is not a gesture; it is an infrastructure of daily life for the community it serves.",
    ],
  },
  {
    title: "Private Residences",
    slug: "private-residences",
    directive: "Principal-Led Narratives",
    image:
      "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=2070&auto=format&fit=crop",
    text: [
      "Private residence commissions require principal leadership from brief through to handover — without exception.",
      "The brief begins with how a specific family moves through a day, not a style preference.",
      "A house that reflects architectural taste rather than family life is a failure of purpose.",
    ],
  },
];

const placeholderProjects = [
  {
    slug: "corinthians-club",
    title: "Corinthians Club",
    client: "Corinthians",
    sector: "Hospitality & Leisure",
    sectorSlug: "hospitality-and-leisure",
    areaSqFt: "280,000",
    city: "Pune",
    year: "2004",
    image:
      "https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&w=1200&q=80",
  },
  {
    slug: "oracle-office",
    title: "Oracle India Office",
    client: "Oracle",
    sector: "Commercial & Workplace",
    sectorSlug: "commercial-and-workplace",
    areaSqFt: "120,000",
    city: "Mumbai",
    year: "2018",
    image:
      "https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1200&q=80",
  },
  {
    slug: "limban-resort",
    title: "Limban Resort",
    client: "Private Client",
    sector: "Hospitality & Leisure",
    sectorSlug: "hospitality-and-leisure",
    areaSqFt: "85,000",
    city: "Maharashtra",
    year: "2022",
    image:
      "https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&fit=crop&w=1200&q=80",
  },
  {
    slug: "cosmos-bank",
    title: "Cosmos Bank HQ",
    client: "Cosmos Bank",
    sector: "Commercial & Workplace",
    sectorSlug: "commercial-and-workplace",
    areaSqFt: "450,000",
    city: "Pune",
    year: "2020",
    image:
      "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1200&q=80",
  },
];
---

<Layout title={title} description={description} canonicalURL={canonicalURL}>
  <div class="bg-bone relative min-h-screen">
    <Header />

    <main>
      {/* ─── 1. MONUMENTAL HERO ──────────────────────────────── */}
      <section class="relative w-full py-48 lg:py-56" aria-labelledby="discipline-hero-heading">
        <div class="mx-auto max-w-[1440px] px-6 lg:px-12">
          <div class="mx-auto flex max-w-5xl flex-col items-center text-center">
            <h1
              id="discipline-hero-heading"
              class="reveal text-[clamp(3.5rem,11vw,9rem)] leading-[1.04] font-medium tracking-[-0.045em] select-none lg:text-[clamp(3.5rem,9vw,7rem)]"
            >
              <span class="text-charcoal block"> Architecture </span>
            </h1>

            {/* Fast-Track Navigation - Zero Friction */}
            <nav class="reveal mt-10 w-full lg:mt-32" aria-label="Page Index">
              <ul
                class="flex items-center justify-center gap-x-8 text-[10px] font-bold tracking-widest uppercase sm:gap-x-12 sm:tracking-[0.2em] lg:text-[11px] lg:tracking-[0.4em]"
              >
                <li>
                  <a
                    href="#positions"
                    class="group text-charcoal/60 hover:text-charcoal flex items-center transition-all duration-500"
                  >
                    <span
                      class="text-charcoal/30 group-hover:text-charcoal/40 mr-3 hidden transition-colors duration-500 lg:inline"
                      >01</span
                    >
                    <span class="relative py-1">
                      Positions
                      <span
                        class="bg-charcoal/60 absolute -bottom-1 left-0 h-px w-0 transition-all duration-700 group-hover:w-full"
                      ></span>
                    </span>
                  </a>
                </li>
                <li>
                  <a
                    href="#sectors"
                    class="group text-charcoal/60 hover:text-charcoal flex items-center transition-all duration-500"
                  >
                    <span
                      class="text-charcoal/30 group-hover:text-charcoal/40 mr-3 hidden transition-colors duration-500 lg:inline"
                      >02</span
                    >
                    <span class="relative py-1">
                      Sectors
                      <span
                        class="bg-charcoal/60 absolute -bottom-1 left-0 h-px w-0 transition-all duration-700 group-hover:w-full"
                      ></span>
                    </span>
                  </a>
                </li>
                <li>
                  <a
                    href="#commissions"
                    class="group text-charcoal/60 hover:text-charcoal flex items-center transition-all duration-500"
                  >
                    <span
                      class="group-hover:text-charcoal/40 text-charcoal/30 mr-3 hidden transition-colors duration-500 lg:inline"
                      >03</span
                    >
                    <span class="relative py-1">
                      Commissions
                      <span
                        class="bg-charcoal/60 absolute -bottom-1 left-0 h-px w-0 transition-all duration-700 group-hover:w-full"
                      ></span>
                    </span>
                  </a>
                </li>
              </ul>
            </nav>
          </div>
        </div>
      </section>

      {/* ─── 2. STATURE IMAGE GRID (REVERSED) ──────────────────────────── */}
      <section
        class="-mt-12 w-full px-6 pb-32 lg:mt-0 lg:px-12 lg:pb-48"
        aria-label="Architecture stature imagery"
      >
        <div class="reveal relative mx-auto max-w-[1800px]">
          <div class="grid grid-cols-1 gap-12 lg:grid-cols-10 lg:gap-4">
            <!-- Right Column (Desktop): Sub-headline + Large Image -->
            <!-- First in HTML to ensure Text -> Large Image -> Dark Block order on mobile -->
            <div class="flex flex-col gap-12 lg:order-2 lg:col-span-7">
              <div class="reveal mx-auto max-w-4xl text-center lg:mx-0 lg:p-12 lg:text-left">
                <p
                  class="text-charcoal/90 text-2xl leading-[1.15] font-light tracking-tight lg:text-4xl"
                >
                  The principles are fixed. What changes is how architecture must answer the sector,
                  the site, and the people using it every day.
                </p>
                <div class="mt-12 flex justify-center lg:justify-start">
                  <Cta
                    text="Discuss a Commission"
                    isContact={true}
                    contactContext="Architecture Commission Enquiry"
                    invert={true}
                  />
                </div>
              </div>

              <div
                class="group/stature-lg lg:aspect-none relative h-[60vh] overflow-hidden contrast-104 grayscale-65 saturate-88 transition-all duration-1000 hover:contrast-100 hover:grayscale-0 hover:saturate-100 lg:h-[80vh]"
              >
                <img
                  src="https://cdn.sanity.io/images/h05maah4/production/1b1c51a989ea65b5f623c7b749612d9bc2248991-2943x3923.jpg?q=80&w=1000&auto=format&fit=crop"
                  alt="Architecture — Metaphors Design"
                  class="cubic-bezier(0.19, 1, 0.22, 1) h-full w-full object-cover transition-transform duration-[3s] group-hover/stature-lg:scale-[1.02]"
                  loading="lazy"
                  decoding="async"
                />

                {/* Footnote Badge */}
                <div class="pointer-events-none absolute bottom-0 left-0 z-10">
                  <div
                    class="bg-bone/50 group-hover/stature-lg:bg-bone/90 origin-bottom-left translate-x-10 -translate-y-10 border border-white/10 px-8 py-4 backdrop-blur-sm transition-all duration-1000 group-hover/stature-lg:border-white/20 group-hover/stature-lg:backdrop-blur-xl"
                  >
                    <p
                      class="text-charcoal text-[10px] font-semibold tracking-[0.5em] whitespace-nowrap uppercase transition-all duration-1000"
                    >
                      Architectural Commissions
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Left Column (Desktop): Fixed Dark Column (Img 1) -->
            <!-- Second in HTML, but lg:order-1 to move to left on desktop -->
            <div
              class="group/stature-sm bg-charcoal reveal relative h-auto overflow-hidden delay-200 lg:order-1 lg:col-span-3 lg:h-[80vh]"
            >
              <img
                src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1000&q=80"
                alt="Architectural precision — Metaphors Design Studio"
                class="cubic-bezier(0.19, 1, 0.22, 1) absolute inset-0 h-full w-full object-cover opacity-40 grayscale transition-all duration-[2s] group-hover/stature-sm:opacity-60"
                loading="lazy"
                decoding="async"
              />
              <div
                class="from-charcoal via-charcoal/60 relative z-10 flex flex-col justify-end bg-linear-to-t to-transparent p-8 lg:absolute lg:inset-0 lg:p-12"
              >
                <div class="mb-12 space-y-12">
                  <div class="h-px w-12 bg-white/20"></div>
                  <p class="text-2xl leading-snug font-light tracking-tight text-white lg:text-3xl">
                    "Architecture is the art and discipline of defining space. Rigorous,
                    context-led, and held to a clear purpose."
                    <span class="mt-4 block text-lg text-white/40 italic">
                      Anand Bhagat<br />Co-Founder & Principal Architect<br />Metaphors Design
                    </span>
                  </p>
                </div>

                <div class="border-t border-white/10 pt-8">
                  <p class="mb-3 text-[12px] font-bold tracking-[0.2em] text-white/30 uppercase">
                    The Commitment
                  </p>
                  <p class="text-[12px] leading-relaxed text-white/50">
                    Full principal involvement from first consultation through to final handover —
                    without exception.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* ─── 3. FOUR POSITIONS ────────────────────────────────── */}
      <section
        id="positions"
        class="bg-charcoal text-bone relative w-full py-24 lg:py-48"
        aria-labelledby="positions-heading"
      >
        <div class="mx-auto max-w-[1440px] px-6 lg:px-12">
          <div class="grid grid-cols-1 gap-16 md:grid-cols-12 lg:gap-24">
            <div class="md:col-span-5">
              <div class="sticky top-24 md:top-40">
                <h2
                  id="positions-heading"
                  class="text-bone mb-8 text-center text-4xl leading-[0.95] font-light tracking-tight md:text-left md:text-6xl lg:text-7xl"
                >
                  Positions on<br />Architecture.
                </h2>
                <p
                  class="text-bone/60 text-center text-[10px] leading-loose font-semibold tracking-[0.25em] uppercase sm:text-xs md:text-left"
                >
                  These are not services - but standards applied to every commission, regardless of
                  sector, scale, or client instruction.
                </p>
              </div>
            </div>

            <div class="relative md:col-span-7">
              <div class="relative w-full">
                <div
                  id="positions-slider"
                  class="no-scrollbar flex snap-x snap-mandatory items-stretch gap-4 overflow-x-auto scroll-smooth pb-8 sm:gap-6 md:grid md:grid-cols-1 md:gap-6 md:overflow-visible md:pb-0 xl:grid-cols-2"
                >
                  {
                    principles.map((p) => (
                      <article class="reveal group border-bone/10 hover:bg-bone/3 hover:border-bone/30 relative flex h-full w-[85vw] shrink-0 snap-center flex-col overflow-hidden border p-8 transition-all duration-1000 ease-out sm:w-[60vw] md:w-full lg:p-10">
                        {/* Decorative Corner Accent */}
                        <div class="bg-bone/40 absolute top-0 left-0 h-px w-0 transition-all delay-200 duration-1000 ease-in-out group-hover:w-16" />
                        <div class="bg-bone/40 absolute top-0 left-0 h-0 w-px transition-all delay-200 duration-1000 ease-in-out group-hover:h-16" />

                        <p class="text-bone/20 group-hover:text-bone/40 mb-6 text-[10px] font-bold tracking-[0.5em] uppercase transition-colors duration-700">
                          Principle {p.number}
                        </p>
                        <h3 class="text-bone mb-6 max-w-sm text-2xl font-light tracking-tight lg:text-[2.25rem]">
                          {p.title}
                        </h3>
                        <p class="text-bone/55 group-hover:text-bone/80 max-w-md text-[15px] leading-relaxed font-light transition-colors duration-700 lg:text-base">
                          {p.text}
                        </p>

                        <span
                          class="text-bone/4 group-hover:text-bone/12 pointer-events-none absolute right-6 bottom-2 leading-none font-bold italic transition-all duration-[2s] ease-out select-none group-hover:scale-110 group-hover:opacity-100"
                          style="font-size: clamp(4rem, 7vw, 6rem);"
                        >
                          {p.number}
                        </span>

                        {/* Subtle Bottom Glow */}
                        <div class="from-bone/5 absolute inset-x-0 bottom-0 h-32 translate-y-32 bg-linear-to-t to-transparent opacity-0 transition-all duration-[1.5s] group-hover:translate-y-0 group-hover:opacity-100" />
                      </article>
                    ))
                  }
                </div>

                {/* Mobile Navigation Buttons */}
                <div class="mt-4 flex w-full items-center justify-between gap-4 md:hidden">
                  <button
                    id="pos-prev"
                    class="border-bone/20 flex flex-1 items-center justify-center gap-2 border py-4 text-[10px] font-bold tracking-widest text-white uppercase transition-colors hover:bg-white/10 active:bg-white/20 disabled:pointer-events-none disabled:opacity-30"
                    aria-label="Previous position"
                  >
                    <Icon name="ph:arrow-left" class="h-4 w-4" />
                    Previous
                  </button>
                  <button
                    id="pos-next"
                    class="border-bone/20 flex flex-1 items-center justify-center gap-2 border py-4 text-[10px] font-bold tracking-widest text-white uppercase transition-colors hover:bg-white/10 active:bg-white/20 disabled:pointer-events-none disabled:opacity-30"
                    aria-label="Next position"
                  >
                    Next
                    <Icon name="ph:arrow-right" class="h-4 w-4" />
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* ─── 4. SECTOR SHOWCASE (MONOGRAPH STYLE) ───────────────────── */}
      <section
        id="sectors"
        class="relative w-full bg-white py-24 lg:py-48"
        aria-labelledby="sectors-heading"
      >
        <div class="mx-auto max-w-[1440px] px-6 lg:px-12">
          <div class="mb-24 grid gap-16 md:mb-40 md:grid-cols-12 lg:gap-32">
            <div
              class="reveal flex flex-col items-center justify-center text-center md:col-span-7 md:items-start md:text-left"
            >
              <h2
                id="sectors-heading"
                class="text-charcoal mb-8 text-center text-4xl font-light tracking-tighter md:text-left md:text-6xl lg:text-7xl"
              >
                Eight Sectors.<br />Each Uniquely<br />Addressed.
              </h2>
            </div>
            <div
              class="reveal flex flex-col items-center gap-10 text-center md:col-span-5 md:items-end md:justify-center md:pt-12 md:text-right"
            >
              <p
                class="text-charcoal/60 max-w-sm text-center text-[10px] leading-loose font-semibold tracking-[0.25em] uppercase sm:text-xs md:text-right"
              >
                Architectural commissions demand sharp industry-specific context, clear intent,
                programming, and brief.
              </p>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-16 md:grid-cols-12 lg:gap-32">
            <!-- Left: Refined Numbered List (Desktop) / Carousel (Mobile) -->
            <div class="reveal md:col-span-4">
              {/* Desktop View: Clean Typography List */}
              <nav class="group/sector-list hidden flex-col md:flex" aria-label="Sector selection">
                {
                  sectorBlocks.map((block, i) => (
                    <div
                      class={`sector-item border-charcoal/10 group/item flex cursor-pointer items-center justify-between border-b py-6 transition-all duration-500 first:border-t ${i === 0 ? "is-active" : ""}`}
                      data-image={block.image}
                      data-title={block.title}
                      data-text={JSON.stringify(block.text)}
                      data-slug={block.slug}
                      data-directive={block.directive}
                    >
                      <div class="flex items-center gap-4">
                        <div>
                          <h3 class="text-charcoal/40 group-hover/item:text-charcoal group-[.is-active]/item:text-charcoal text-xl font-light tracking-tighter transition-all duration-500 group-[.is-active]/item:font-bold lg:text-2xl xl:text-3xl">
                            {block.title}
                          </h3>
                          <p class="mt-1 text-[9px] font-bold tracking-[0.3em] uppercase opacity-0 transition-opacity duration-500 group-[.is-active]/item:opacity-40">
                            {block.directive}
                          </p>
                        </div>
                      </div>
                      <div class="flex items-center">
                        <Icon
                          name="ph:arrow-right"
                          class="h-5 w-5 opacity-0 transition-all duration-500 group-[.is-active]/item:opacity-100"
                        />
                      </div>
                    </div>
                  ))
                }
              </nav>

              {/* Mobile View: Carousel */}
              <div class="relative md:hidden">
                <div
                  id="sector-carousel"
                  class="no-scrollbar -mx-6 flex snap-x snap-mandatory overflow-x-auto scroll-smooth pb-12"
                >
                  {
                    sectorBlocks.map((block, i) => (
                      <article class="flex w-full shrink-0 snap-center flex-col items-center px-6 text-center">
                        <div class="bg-charcoal/5 relative mb-10 aspect-square w-full overflow-hidden">
                          <img
                            src={block.image}
                            alt={block.title}
                            class="absolute inset-0 h-full w-full object-cover"
                            loading="lazy"
                            decoding="async"
                          />
                          <div class="from-charcoal/40 absolute inset-0 bg-linear-to-t to-transparent" />
                        </div>
                        <h3 class="text-charcoal mb-6 text-3xl font-bold tracking-tight">
                          {block.title}
                        </h3>
                        <div class="text-charcoal/60 mx-auto mb-10 text-sm leading-relaxed font-light">
                          {block.text.map((sentence) => (
                            <p class="mb-4 last:mb-0">{sentence}</p>
                          ))}
                        </div>
                        <div class="flex flex-row items-center justify-center gap-8">
