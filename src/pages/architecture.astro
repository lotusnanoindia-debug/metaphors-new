                      <div class="from-charcoal/90 via-charcoal/20 absolute inset-0 bg-linear-to-t to-transparent opacity-60 transition-opacity duration-1000 group-hover/project:opacity-100" />

                      <div class="absolute top-6 left-6 z-20 lg:top-10 lg:left-10">
