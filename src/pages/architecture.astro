                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* ─── 5. SELECTED COMMISSIONS ──────────────────────────── */}
      <section
        id="commissions"
        class="border-charcoal/5 border-t bg-[#f2f1ec] py-10 lg:py-24"
