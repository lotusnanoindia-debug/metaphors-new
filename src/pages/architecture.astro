        </div>

        <div class="bg-[#f2f1ec] pb-24 lg:pb-48">
          <div class="mx-auto mb-12 max-w-[1800px] px-4 md:px-8 lg:mb-20">
            <div class="border-charcoal/5 flex justify-center border-t border-b py-8 lg:py-12">
              <div
                class="grid w-full grid-cols-2 gap-2 md:grid-cols-4 lg:grid-cols-8 lg:gap-4"
                id="project-filters"
              >
                {
                  [...projectSectors]
                    .sort((a, b) => a.title.localeCompare(b.title))
                    .map((s, index) => (
                      <button
                        data-filter={s.slug}
                        class={`filter-btn ${index === 0 ? "active" : ""} border-charcoal/10 hover:border-charcoal flex cursor-pointer items-center justify-center border px-4 py-3 text-center text-[10px] font-bold tracking-[0.2em] uppercase transition-all duration-500`}
