<style>
  /* Hide scrollbar on carousel track — keep scroll functionality */
  .no-scrollbar {
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE 11 */
  }
  .no-scrollbar::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Edge */
  }

  /* Specific Filter Button Styling */
  .filter-btn.active {
    background-color: var(--color-charcoal);
    color: var(--color-bone);
    border-color: var(--color-charcoal);
  }
</style>

<script>
  function initSectorPreview() {
    const items = document.querySelectorAll(".sector-item");
    const previewImg = document.getElementById("sector-preview-img") as HTMLImageElement;
    const previewTitle = document.getElementById("sector-preview-title");
    const previewText = document.getElementById("sector-preview-text");
    const previewLink = document.getElementById("sector-preview-link") as HTMLAnchorElement;
    const previewCommBtn = document.getElementById("sector-preview-commissions") as HTMLElement;
    const previewContent = document.getElementById("sector-preview-content");

    const updatePreview = (data: any) => {
      if (!previewImg || !previewContent) return;

      // Coordinate the luxury cross-fade
      previewImg.style.opacity = "0";
      previewImg.style.transform = "scale(1.02)";
      previewContent.style.opacity = "0";

      setTimeout(() => {
        if (data.image) previewImg.src = data.image;
        if (previewTitle && data.title) previewTitle.textContent = data.title;

        if (previewText && data.text) {
          const sentences = JSON.parse(data.text);
          previewText.innerHTML = sentences
            .map((s: string) => `<p class="mb-6 last:mb-0">${s}</p>`)
            .join("");
        }

        if (previewLink && data.slug) previewLink.href = `/sectors/${data.slug}`;
        if (previewCommBtn && data.slug) previewCommBtn.dataset.sector = data.slug;

        previewImg.style.opacity = "1";
        previewImg.style.transform = "scale(1)";
        previewContent.style.opacity = "1";
      }, 400);
    };

    if (items.length && previewImg) {
      // Pre-select first item
      const firstItem = items[0] as HTMLElement;
      firstItem.classList.add("is-active");
      updatePreview(firstItem.dataset);

      items.forEach((item) => {
        item.addEventListener("mouseenter", () => {
          if (item.classList.contains("is-active")) return;

          const data = (item as HTMLElement).dataset;

          // Handle active class
          items.forEach((t) => t.classList.remove("is-active"));
          item.classList.add("is-active");

          updatePreview(data);
        });
      });
    }

    // View Commissions Logic (Independent of preview pane)
    const commissionTriggers = document.querySelectorAll(".view-commissions-trigger");
    commissionTriggers.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        const sector = (btn as HTMLElement).dataset.sector;
        if (!sector) return;

        const filterBtn = document.querySelector(
          `.filter-btn[data-filter="${sector}"]`,
        ) as HTMLElement;
        if (filterBtn) {
          filterBtn.click();
        }

        const commissionsSection = document.getElementById("commissions");
        if (commissionsSection) {
          commissionsSection.scrollIntoView({ behavior: "smooth" });
        }
      });
    });
  }

  function initSectorCarousel() {
    const carousel = document.getElementById("sector-carousel");
    const prevBtn = document.getElementById("prev-sector");
    const nextBtn = document.getElementById("next-sector");

    if (carousel && prevBtn && nextBtn) {
      const updateButtons = () => {
        const index = Math.round(carousel.scrollLeft / (carousel.offsetWidth || 1));

        (prevBtn as HTMLButtonElement).disabled = index === 0;
        (nextBtn as HTMLButtonElement).disabled = index === carousel.children.length - 1;
      };

      prevBtn.addEventListener("click", () => {
        carousel.scrollBy({ left: -carousel.offsetWidth, behavior: "smooth" });
      });

      nextBtn.addEventListener("click", () => {
        carousel.scrollBy({ left: carousel.offsetWidth, behavior: "smooth" });
      });

      carousel.addEventListener("scroll", updateButtons);
      updateButtons();
    }
  }

  function initPositionsCarousel() {
    const slider = document.getElementById("positions-slider");
    const prevBtn = document.getElementById("pos-prev") as HTMLButtonElement;
    const nextBtn = document.getElementById("pos-next") as HTMLButtonElement;

    if (slider && prevBtn && nextBtn) {
      const updateButtons = () => {
        const isAtStart = slider.scrollLeft === 0;
        const isAtEnd = slider.scrollLeft + slider.clientWidth >= slider.scrollWidth - 10;
        prevBtn.disabled = isAtStart;
        nextBtn.disabled = isAtEnd;
      };

      prevBtn.addEventListener("click", () => {
        slider.scrollBy({ left: -slider.offsetWidth, behavior: "smooth" });
      });

      nextBtn.addEventListener("click", () => {
        slider.scrollBy({ left: slider.offsetWidth, behavior: "smooth" });
      });

      slider.addEventListener("scroll", updateButtons);
      updateButtons();
    }
  }

  function initFilters() {
    const filterBtns = document.querySelectorAll(".filter-btn");
    const projectItems = document.querySelectorAll(".project-item");

    if (!filterBtns.length || !projectItems.length) return;

    // Filter by the first button automatically since 'All' is removed
    const initialFilter = (filterBtns[0] as HTMLElement).dataset.filter;

    const applyFilter = (filter: string) => {
      projectItems.forEach((item) => {
        const itemEl = item as HTMLElement;
        const sector = itemEl.dataset.sector;

        if (sector === filter) {
          itemEl.style.display = "block";
          setTimeout(() => {
            itemEl.style.opacity = "1";
            itemEl.style.transform = "scale(1)";
            itemEl.style.pointerEvents = "auto";
          }, 10);
        } else {
          itemEl.style.opacity = "0";
          itemEl.style.transform = "scale(0.95)";
          itemEl.style.pointerEvents = "none";
          setTimeout(() => {
            if (itemEl.style.opacity === "0") itemEl.style.display = "none";
          }, 700);
        }
      });
    };

    // Apply initial filter
    if (initialFilter) applyFilter(initialFilter);

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = (btn as HTMLElement).dataset.filter;
        if (!filter) return;

        filterBtns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");

        applyFilter(filter);
      });
    });
  }

  function init() {
    initSectorPreview();
    initSectorCarousel();
    initPositionsCarousel();
    initFilters();
  }

  init();
  document.addEventListener("astro:after-swap", init);
</script>
