            >
              <p class="text-charcoal/30 mb-10 text-[10px] font-medium tracking-[0.5em] uppercase">
                Proven Stature
              </p>
              <h2
                id="commissions-heading"
                class="text-charcoal text-6xl leading-[0.99] tracking-tight md:text-7xl lg:text-[6.5rem]"
              >
                Selected<br />Architecture<br />Commissions.
              </h2>
            </div>
            <div
              class="reveal flex flex-col items-center gap-10 text-center md:items-end md:justify-end md:pt-12 md:text-right"
            >
              <p
                class="text-charcoal/60 max-w-sm text-[10px] leading-loose font-semibold tracking-[0.25em] uppercase sm:text-xs"
              >
                Rigour and execution<br />across industry and scale.
              </p>
              <div class="hidden w-full justify-center md:flex md:justify-end">
                <Cta
                  text="Start a Conversation"
                  invert={true}
                  isContact={true}
                  contactContext="Architecture Commission Enquiry"
                />
              </div>
            </div>
