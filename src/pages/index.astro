---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Sectors from "../components/Sectors.astro";
import ScaleOfPractice from "../components/ScaleOfPractice.astro";
import Evidence from "../components/Evidence.astro";
import Press from "../components/Press.astro";
import Footer from "../components/Footer.astro";
import { client, HOME_SETTINGS_QUERY, imageUrl } from "../lib/sanity";

const settings = await client.fetch(HOME_SETTINGS_QUERY);
---

<Layout title="Metaphors Design | Architectural Precision">
  <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
    <Header />
    <Hero />

    <section class="w-full px-6 lg:px-12 pb-32 lg:pb-48">
      <div class="max-w-[1440px] mx-auto reveal">
        <div class="grid grid-cols-1 lg:grid-cols-10 gap-6 lg:gap-1">
          {/* Large Image - Stature */}
          <div
            class="lg:col-span-7 relative overflow-hidden grayscale hover:grayscale-0 transition-all duration-1000"
          >
            {
              settings?.heroStatureImage && (
                <img
                  alt="Dome, Oracle Building, Pune, India - Structural Stature"
                  class="w-full h-[60vh] lg:h-[80vh] object-cover object-center luxury-transition hover:scale-105"
                  loading="lazy"
                  decoding="async"
                  src={imageUrl(settings.heroStatureImage, { width: 1000 })}
                />
              )
            }
          </div>

          {/* Small Image - Detail */}
          <div
            class="lg:col-span-3 relative overflow-hidden grayscale hover:grayscale-0 transition-all duration-1000 flex flex-col"
          >
            {
              settings?.heroPrecisionImage && (
                <img
                  alt="Architectural Detail"
                  class="w-full h-[40vh] lg:h-full object-cover object-center luxury-transition hover:scale-110"
                  loading="lazy"
                  decoding="async"
                  src={imageUrl(settings.heroPrecisionImage, { width: 500 })}
                />
              )
            }
          </div>
        </div>

        {/* Architectural Footnote */}
        <div class="mt-8 px-2 text-center lg:text-left">
          <p
            class="text-[10px] font-medium uppercase tracking-[0.3em] text-charcoal/30"
          >
            Oracle Centre, Pune, India
          </p>
        </div>
      </div>
    </section>

    <Press />
    
    <Sectors />
    <ScaleOfPractice />
    <Evidence />
  </div>
  <Footer />
</Layout>
