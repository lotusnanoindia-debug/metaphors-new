---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Sectors from "../components/Sectors.astro";
import Certainty from "../components/Certainty.astro";
import Evidence from "../components/Evidence.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Metaphors Design | Architectural Precision">
  <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
    <Header />
    <Hero />

    <section class="w-full px-6 lg:px-12 pb-32 lg:pb-48">
      <div class="max-w-[1440px] mx-auto reveal">
        <div class="grid grid-cols-1 lg:grid-cols-10 gap-6 lg:gap-1">
          {/* Large Image - Stature */}
          <div
            class="lg:col-span-7 relative group overflow-hidden grayscale hover:grayscale-0 transition-all duration-1000 cursor-crosshair"
          >
            <img
              alt="Dome, Oracle Building, Pune, India - Structural Stature"
              class="w-full h-[60vh] lg:h-[80vh] object-cover object-center luxury-transition group-hover:scale-105"
              src="/oracle-pune-dome-metaphors-design.jpeg"
            />
            <div
              class="absolute bottom-10 left-10 opacity-0 group-hover:opacity-100 transition-all duration-1000"
            >
              <p
                class="text-white text-[9px] font-bold uppercase tracking-[0.4em] bg-black/20 backdrop-blur-md px-4 py-2 border border-white/10"
              >
                Stature: Curvilinear Perimeter Span
              </p>
            </div>
          </div>

          {/* Small Image - Detail */}
          <div
            class="lg:col-span-3 relative group overflow-hidden grayscale hover:grayscale-0 transition-all duration-1000 flex flex-col"
          >
            <img
              alt="Architectural Detail - Execution Precision"
              class="w-full h-[40vh] lg:h-full object-cover object-center luxury-transition group-hover:scale-110"
              src="/metaphors-detail.png"
            />
            <div
              class="absolute top-10 right-10 text-right opacity-0 group-hover:opacity-100 transition-all duration-1000"
            >
              <p
                class="text-white text-[9px] font-bold uppercase tracking-[0.4em] bg-black/20 backdrop-blur-md px-4 py-2 border border-white/10"
              >
                Precision: ±2mm Execution Tolerance
              </p>
            </div>

            <div class="absolute bottom-10 right-10 text-right hidden lg:block">
              <div class="space-y-4">
                <div>
                  <p
                    class="text-[9px] font-bold uppercase tracking-[0.3em] text-gray-500/70 mb-1"
                  >
                    Structural Load
                  </p>
                  <p
                    class="text-[11px] text-gray-500/70 font-medium tracking-widest"
                  >
                    Adaptive Tensile Array
                  </p>
                </div>
                <div>
                  <p
                    class="text-[9px] font-bold uppercase tracking-[0.3em] text-gray-500/70 mb-1"
                  >
                    Solar Control
                  </p>
                  <p
                    class="text-[11px] text-gray-500/70 font-medium tracking-widest"
                  >
                    45% High-Freq Rejection
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Architectural Footnote */}
        <div class="mt-8 flex justify-between items-center px-2">
          <p
            class="text-[10px] font-bold uppercase tracking-[0.3em] text-charcoal/30"
          >
            Archive Spec: PN-OR-01 // Oracle Centre, Pune, India
          </p>
          <div
            class="flex gap-12 text-[10px] font-bold uppercase tracking-[0.2em] text-charcoal/60"
          >
            <span class="luxury-transition hover:text-charcoal cursor-default"
              >Design: 1998</span
            >
            <span class="luxury-transition hover:text-charcoal cursor-default"
              >Execution: Metaphors Design</span
            >
          </div>
        </div>
      </div>
    </section>

    <Sectors />
    <Certainty />
    <Evidence />
  </div>
  <Footer />
</Layout>
