---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import StatureDialogue from "../components/StatureDialogue.astro";
import Sectors from "../components/Sectors.astro";
import ScaleOfPractice from "../components/ScaleOfPractice.astro";
import Disciplines from "../components/Disciplines.astro";
import MainCta from "../components/MainCta.astro";
import Footer from "../components/Footer.astro";
import { client, HOMEPAGE_QUERY, HOME_SETTINGS_QUERY, imageUrl } from "../lib/sanity";

const data = await client.fetch(HOMEPAGE_QUERY);
const homepage = data?.homepage;
const quotes = data?.quotes || [];
const homeSettings = await client.fetch(HOME_SETTINGS_QUERY);

const schema = {
  "@context": "https://schema.org",
  "@type": "ArchitecturalStore",
  name: "Metaphors Design",
  url: "https://metaphors.design",
  logo: "https://metaphors.design/logo-v1.png",
  description:
    "Architectural precision for high-stakes Indian developments. ROI-driven design, engineered for execution certainty.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Pune",
    addressCountry: "India",
  },
  foundingDate: "1989",
  founder: {
    "@type": "Person",
    name: "Metaphors Architects",
  },
  areaServed: "India",
  knowsAbout: [
    "Architectural Design",
    "Urban Planning",
    "Corporate Architecture",
    "Institutional Design",
  ],
};
---

<Layout
  title="Metaphors Design | Architectural Precision from Pune, India"
  description="Defining modern Indian architecture for four decades. Metaphors Design delivers precise, ROI-driven architectural solutions for corporate, civic, and residential environments."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />
  <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
    <Header />
    <Hero
      headline={homepage?.heroSection?.headline}
      headlineAccent={homepage?.heroSection?.headlineAccent}
      headlineTagline={homepage?.heroSection?.headlineTagline}
      subheading={homepage?.heroSection?.subheading}
    />

    <StatureDialogue
      section={homepage?.statureSection}
      subheading={homepage?.heroSection?.subheading}
      quotes={quotes}
    />

    <Sectors section={homepage?.sectorsSection} />

    <ScaleOfPractice section={homepage?.scaleSection} />

    <Disciplines section={homepage?.disciplinesSection} />

    <MainCta section={homepage?.mainCtaSection} />
  </div>
  <Footer />
</Layout>
