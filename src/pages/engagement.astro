---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MainCta from "../components/MainCta.astro";
import Cta from "../components/Cta.astro";

const title = "Engagement | Metaphors Design — How Projects Begin";
const description =
  "What working with Metaphors Design means for your project. Six defined stages from brief to handover, with the architectural discipline and sustained involvement your commission requires.";
---

<Layout
  title={title}
  description={description}
  canonicalURL="https://metaphors.design/engagement"
>
  <div class="relative min-h-screen overflow-clip bg-bone">
    <Header />

    <main>
      <!-- ─── 1. HERO ─────────────────────────────────────────── -->
      <section class="relative w-full py-48 lg:py-56">
        <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
          <div class="max-w-5xl mx-auto flex flex-col items-center text-center">
            <h1
              class="font-medium leading-[0.9] tracking-[-0.045em] text-[clamp(3.5rem,11vw,9rem)] lg:text-[clamp(3.5rem,9vw,8rem)] select-none reveal"
            >
              <span class="block text-charcoal">Decisions of Consequence.</span>
              <span
                class="block mt-4 lg:mt-6 text-transparent bg-clip-text animate-sheen will-change-[background-position] bg-[linear-gradient(105deg,#6b6b67_0%,#6b6b67_40%,#a8a8a2_48%,#a8a8a2_52%,#6b6b67_60%,#6b6b67_100%)] bg-size-[200%_auto] text-[clamp(1.5rem,6vw,3.5rem)] lg:text-[clamp(2rem,4.5vw,4.5rem)] tracking-[-0.03em] leading-tight"
              >
                Executed with Rigour.
              </span>
            </h1>
          </div>
        </div>
      </section>
    </main>

    <!-- ─── 2. STATURE IMAGE GRID (mirrors About page) ─────── -->
    <section class="w-full px-6 lg:px-12 pb-32">
      <div class="max-w-[1440px] mx-auto reveal relative">
        <div class="grid grid-cols-1 lg:grid-cols-10 gap-6 lg:gap-8">
          <!-- Large image + intro text -->
          <div class="lg:col-span-7 flex flex-col gap-12">
            <div class="max-w-3xl reveal">
              <p
                class="hidden lg:block text-[12px] font-bold uppercase tracking-[0.3em] text-charcoal/40 mb-8"
              >
                The Engagement — Pune, Est. 1989
              </p>
              <p
                class="text-2xl lg:text-4xl text-charcoal/90 font-light leading-[1.15] tracking-tight"
              >
                Spaces of significance, once created, cannot be undone or
                replaced without consequence. <br /><br />Choosing your
                architect is never a mere transactional decision; its
                foundations lie in perfectly aligned intent and mutual trust.
              </p>
            </div>

            <div
              class="group/stature-lg relative overflow-hidden h-[60vh] lg:h-[70vh] transition-all duration-1000 grayscale-65 saturate-88 contrast-104 hover:grayscale-0 hover:saturate-100 hover:contrast-100"
            >
              <img
                src="https://images.unsplash.com/photo-1600607688969-a5bfcd646154?auto=format&fit=crop&w=2000&q=85"
                alt="Metaphors Design — Studio Engagement"
                class="w-full h-full object-cover transition-transform duration-[3s] cubic-bezier(0.19, 1, 0.22, 1) group-hover/stature-lg:scale-[1.02]"
                loading="eager"
              />
              <div class="absolute left-0 bottom-0 pointer-events-none z-10">
                <div
                  class="origin-bottom-left translate-x-10 -translate-y-10 bg-bone/50 backdrop-blur-sm px-8 py-4 border border-white/10 transition-all duration-1000 group-hover/stature-lg:bg-bone/90 group-hover/stature-lg:backdrop-blur-xl group-hover/stature-lg:border-white/20"
                >
                  <p
                    class="text-[10px] font-semibold uppercase tracking-[0.5em] text-charcoal whitespace-nowrap transition-all duration-1000"
                  >
                    Metaphors Design Studio — Pune
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Dark secondary column -->
          <div
            class="group/stature-sm lg:col-span-3 relative overflow-hidden h-[50vh] lg:h-[80vh] bg-charcoal reveal mt-12 lg:mt-0"
            style="transition-delay: 200ms"
          >
            <img
              src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1000&q=80"
              alt="Precision Backdrop"
              class="absolute inset-0 w-full h-full object-cover grayscale opacity-40 group-hover/stature-sm:opacity-60 transition-all duration-[2s]"
            />
            <div
              class="absolute inset-0 p-8 lg:p-12 bg-linear-to-t from-charcoal via-charcoal/60 to-transparent flex flex-col justify-end z-10"
            >
              <div class="space-y-12 mb-12">
                <div class="h-px w-12 bg-white/20"></div>
                <p
                  class="text-2xl lg:text-4xl text-white font-light tracking-tight"
                >
                  One partner leads your project from first brief to final
                  handover. <p class="italic text-white/40 text-2xl">
                    Every detail is executed with precision, guided by hands-on
                    founder direction.
                  </p>
                </p>
              </div>

              <div class="pt-8 border-t border-white/10">
                <p
                  class="text-[12px] font-bold uppercase tracking-[0.2em] text-white/30 mb-3"
                >
                  The Commitment
                </p>
                <p
                  class="text-[12px] text-white/50 leading-relaxed max-w-[240px]"
                >
                  Full involvement from first site visit through to final
                  handover — without exception.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── 3. CONDITIONS OF PRACTICE ─────────────────────── -->
    <section class="max-w-[1440px] mx-auto px-6 lg:px-12 pb-32 lg:pb-48">
      <div
        class="grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-32 border-t border-charcoal/10 pt-16 lg:pt-24"
      >
        <div class="reveal">
          <p
            class="text-[12px] font-bold uppercase tracking-[0.3em] text-charcoal/40 mb-8 font-inter"
          >
            01 — The Threshold
          </p>
          <h3
            class="text-3xl lg:text-4xl font-light tracking-tight text-charcoal mb-6"
          >
            Selective by Necessity.
          </h3>
          <p class="text-base text-charcoal/60 leading-relaxed max-w-md">
            We do not accept every commission, nor do we participate in
            speculative pitches or ideas without support funding. The level of
            rigour we apply to a project demands a disproportionate investment
            of studio resources. We partner exclusively with clients who
            understand that architecture is a primary vehicle for value
            creation, not a line item to be minimised.
          </p>
        </div>

        <div class="reveal">
          <p
            class="text-[12px] font-bold uppercase tracking-[0.3em] text-charcoal/40 mb-8 font-inter"
          >
            02 — The Authorship
          </p>
          <h3
            class="text-3xl lg:text-4xl font-light tracking-tight text-charcoal mb-6"
          >
            No Delegation of Intent.
          </h3>
          <p class="text-base text-charcoal/60 leading-relaxed max-w-md">
            Traditional architectural studios often rely on partners winning the
            work and juniors executing it. We reject it. The principals who
            interrogate your commercial logic and establish the conceptual
            direction are the same authors who will stand on site to enforce the
            execution of the final detail. All our projects are hands-on
            directed by our principals.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── 4. PROCESS TIMELINE ───────────────────────────── -->
    <section
      class="px-6 py-24 lg:px-12 lg:py-48 bg-[#f2f1ec] text-charcoal relative"
    >
      <div class="mx-auto max-w-[1440px]">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 relative">
          <!-- Left: Sticky Context & CTA -->
          <div class="lg:col-span-5">
            <div class="lg:sticky lg:top-40">
              <p
                class="text-[12px] font-bold uppercase tracking-[0.3em] text-charcoal/40 mb-10 font-inter"
              >
                Six Stages. One Standard.
              </p>
              <h2
                class="text-4xl lg:text-7xl font-light leading-[1.05] tracking-tight mb-8"
              >
                Resolved.<br />
                At Every Stage.
              </h2>
              <p
                class="text-xl text-charcoal/70 font-light leading-relaxed tracking-tight max-w-md mb-12"
              >
                Every project follows six invariant stages. Each one exists to
                protect your interests — not because the process demands it, but
                because the outcome requires it.
              </p>

              <!-- Section Specific Inverted CTA -->
              <div>
                <Cta
                  text="Ask a Question"
                  isContact={true}
                  contactContext="Engagement Process Enquiry"
                  invert={true}
                />
              </div>
            </div>
          </div>

          <!-- Right: Vertical Timeline -->
          <div class="lg:col-span-7 relative pt-24 lg:pt-0">
            <!-- Timeline vertical hairline -->
            <div class="absolute left-0 top-3 bottom-0 w-px bg-charcoal/10">
            </div>

            <div
              class="flex flex-col space-y-24 pl-12 sm:space-y-32 sm:pl-16 lg:pl-24"
            >
              <!-- Timeline Node 01 -->
              <article class="relative group reveal">
                <!-- Timeline dot -->
                <div
                  class="absolute -left-[52px] sm:-left-[68px] lg:-left-[100px] top-1.5 w-2 h-2 rounded-full bg-charcoal ring-[6px] ring-[#f2f1ec] group-hover:scale-[1.8] group-hover:bg-charcoal/80 transition-all duration-700"
                >
                </div>

                <div
                  class="-mx-6 p-6 sm:-mx-8 sm:p-8 lg:-mx-10 lg:p-10 rounded-2xl transition-colors duration-700 group-hover:bg-charcoal/4"
                >
                  <p
                    class="text-[10px] font-bold uppercase tracking-[0.4em] text-charcoal/40 mb-4 font-inter group-hover:text-charcoal/80 transition-colors duration-500"
                  >
                    STAGE 01
                  </p>
                  <h3
                    class="text-3xl lg:text-4xl font-light tracking-tight mb-6"
                  >
                    Brief & Alignment
                  </h3>
                  <div
                    class="space-y-5 text-base leading-relaxed text-charcoal/60 max-w-xl"
                  >
                    <p>
                      Your commercial logic and long-range ambitions must
                      precede the architecture. A brief is never treated as a
                      wish list; it acts as the singular metric for success.
                    </p>
                    <p>
                      <span class="font-medium text-charcoal"
                        >It is the immovable foundation upon which all
                        financial, structural, and creative decisions will be
                        tested throughout the lifespan of the development.</span
                      >
                    </p>
                  </div>
                </div>
              </article>

              <!-- Timeline Node 02 -->
              <article class="relative group reveal">
                <!-- Timeline dot -->
                <div
                  class="absolute -left-[52px] sm:-left-[68px] lg:-left-[100px] top-1.5 w-2 h-2 rounded-full bg-charcoal ring-[6px] ring-[#f2f1ec] group-hover:scale-[1.8] group-hover:bg-charcoal/80 transition-all duration-700"
                >
                </div>

                <div
                  class="-mx-6 p-6 sm:-mx-8 sm:p-8 lg:-mx-10 lg:p-10 rounded-2xl transition-colors duration-700 group-hover:bg-charcoal/4"
                >
                  <p
                    class="text-[10px] font-bold uppercase tracking-[0.4em] text-charcoal/40 mb-4 font-inter group-hover:text-charcoal/80 transition-colors duration-500"
                  >
                    STAGE 02
                  </p>
                  <h3
                    class="text-3xl lg:text-4xl font-light tracking-tight mb-6"
                  >
                    Concept Design
                  </h3>
                  <div
                    class="space-y-5 text-base leading-relaxed text-charcoal/60 max-w-xl"
                  >
                    <p>
                      The spatial idea is formed here — synthesised from the
                      site's environmental data, your programme, and the
                      architectural logic that will govern the project from this
                      point forward.
                    </p>
                    <p>
                      <span class="font-medium text-charcoal"
                        >You will see the reasoning behind every decision.
                        Orientation, proportion, and materiality are established
                        and presented for your review before anything proceeds.</span
                      >
                    </p>
                  </div>
                </div>
              </article>

              <!-- Timeline Node 03 -->
              <article class="relative group reveal">
                <!-- Timeline dot -->
                <div
                  class="absolute -left-[52px] sm:-left-[68px] lg:-left-[100px] top-1.5 w-2 h-2 rounded-full bg-charcoal ring-[6px] ring-[#f2f1ec] group-hover:scale-[1.8] group-hover:bg-charcoal/80 transition-all duration-700"
                >
                </div>

                <div
                  class="-mx-6 p-6 sm:-mx-8 sm:p-8 lg:-mx-10 lg:p-10 rounded-2xl transition-colors duration-700 group-hover:bg-charcoal/4"
                >
                  <p
                    class="text-[10px] font-bold uppercase tracking-[0.4em] text-charcoal/40 mb-4 font-inter group-hover:text-charcoal/80 transition-colors duration-500"
                  >
                    STAGE 03
                  </p>
                  <h3
                    class="text-3xl lg:text-4xl font-light tracking-tight mb-6"
                  >
                    Design Development
                  </h3>
                  <div
                    class="space-y-5 text-base leading-relaxed text-charcoal/60 max-w-xl"
                  >
                    <p>
                      The concept is tested against structural, mechanical, and
                      regulatory requirements. Every technical ambiguity is
                      resolved here — not discovered later on site.
                    </p>
                    <p>
                      <span class="font-medium text-charcoal"
                        >Consultants are coordinated, geometry refined, and the
                        design locked to a level of certainty that protects your
                        budget and timeline.</span
                      >
                    </p>
                  </div>
                </div>
              </article>

              <!-- Timeline Node 04 -->
              <article class="relative group reveal">
                <!-- Timeline dot -->
                <div
                  class="absolute -left-[52px] sm:-left-[68px] lg:-left-[100px] top-1.5 w-2 h-2 rounded-full bg-charcoal ring-[6px] ring-[#f2f1ec] group-hover:scale-[1.8] group-hover:bg-charcoal/80 transition-all duration-700"
                >
                </div>

                <div
                  class="-mx-6 p-6 sm:-mx-8 sm:p-8 lg:-mx-10 lg:p-10 rounded-2xl transition-colors duration-700 group-hover:bg-charcoal/4"
                >
                  <p
                    class="text-[10px] font-bold uppercase tracking-[0.4em] text-charcoal/40 mb-4 font-inter group-hover:text-charcoal/80 transition-colors duration-500"
                  >
                    STAGE 04
                  </p>
                  <h3
                    class="text-3xl lg:text-4xl font-light tracking-tight mb-6"
                  >
                    Detailed Documentation
                  </h3>
                  <div
                    class="space-y-5 text-base leading-relaxed text-charcoal/60 max-w-xl"
                  >
                    <p>
                      The full set of construction drawings and specifications
                      is produced — the binding technical record of the design.
                      Nothing is left to the contractor's interpretation.
                    </p>
                    <p>
                      <span class="font-medium text-charcoal"
                        >Precise documentation means accurate pricing, fewer
                        variations, and a construction process that proceeds as
                        planned.</span
                      >
                    </p>
                  </div>
                </div>
              </article>

              <!-- Timeline Node 05 -->
              <article class="relative group reveal">
                <!-- Timeline dot -->
                <div
                  class="absolute -left-[52px] sm:-left-[68px] lg:-left-[100px] top-1.5 w-2 h-2 rounded-full bg-charcoal ring-[6px] ring-[#f2f1ec] group-hover:scale-[1.8] group-hover:bg-charcoal/80 transition-all duration-700"
                >
                </div>

                <div
                  class="-mx-6 p-6 sm:-mx-8 sm:p-8 lg:-mx-10 lg:p-10 rounded-2xl transition-colors duration-700 group-hover:bg-charcoal/4"
                >
                  <p
                    class="text-[10px] font-bold uppercase tracking-[0.4em] text-charcoal/40 mb-4 font-inter group-hover:text-charcoal/80 transition-colors duration-500"
                  >
                    STAGE 05
                  </p>
                  <h3
                    class="text-3xl lg:text-4xl font-light tracking-tight mb-6"
                  >
                    Site Coordination
                  </h3>
                  <div
                    class="space-y-5 text-base leading-relaxed text-charcoal/60 max-w-xl"
                  >
                    <p>
                      Architectural intent cannot be compromised during
                      execution. The authors of the design remain heavily
                      involved on site to enforce standard, not merely observe
                      progress.
                    </p>
                    <p>
                      <span class="font-medium text-charcoal"
                        >Involvement is maintained to handle rapid technical
                        responses. Your investment is protected against
                        deviation — at every decision made on site.</span
                      >
                    </p>
                  </div>
                </div>
              </article>

              <!-- Timeline Node 06 -->
              <article class="relative group reveal">
                <!-- Timeline dot -->
                <div
                  class="absolute -left-[52px] sm:-left-[68px] lg:-left-[100px] top-1.5 w-2 h-2 rounded-full bg-charcoal ring-[6px] ring-[#f2f1ec] group-hover:scale-[1.8] group-hover:bg-charcoal/80 transition-all duration-700"
                >
                </div>

                <div
                  class="-mx-6 p-6 sm:-mx-8 sm:p-8 lg:-mx-10 lg:p-10 rounded-2xl transition-colors duration-700 group-hover:bg-charcoal/4"
                >
                  <p
                    class="text-[10px] font-bold uppercase tracking-[0.4em] text-charcoal/40 mb-4 font-inter group-hover:text-charcoal/80 transition-colors duration-500"
                  >
                    STAGE 06
                  </p>
                  <h3
                    class="text-3xl lg:text-4xl font-light tracking-tight mb-6"
                  >
                    Completion & Handover
                  </h3>
                  <div
                    class="space-y-5 text-base leading-relaxed text-charcoal/60 max-w-xl"
                  >
                    <p>
                      The project is formally inspected, snagged, and handed
                      over. The built reality is measured against the original
                      proposition.
                    </p>
                    <p>
                      <span class="font-medium text-charcoal"
                        >We close the engagement only when the standard has been
                        met — not approximated.</span
                      >
                    </p>
                  </div>
                </div>
              </article>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── 5. CLOSING CTA ────────────────────────────── -->
    <MainCta
      section={{
        eyebrow: "Commission",
        headline: "Discuss Your Intent.",
        tagline:
          "You don't need a finished brief. Ambition and intent are sufficient. We bring the clarity to carry your project from first conversation to final handover.",
        ctaLabel: "Start a Conversation",
        ctaUrl: "/contact",
      }}
      className="bg-bone"
    />

    <Footer />
  </div>
</Layout>
