---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { client, PROJECT_DETAIL_QUERY, ALL_PROJECTS_SLUGS_QUERY, imageUrl } from "../../lib/sanity";

/*
  RESTORE FOR STATIC MODE:
  export async function getStaticPaths() {
    const projects = await client.fetch(ALL_PROJECTS_SLUGS_QUERY);
    return projects.map((p: any) => ({
      params: { slug: p.slug },
    }));
  }
*/

const { slug } = Astro.params;
const project = await client.fetch(PROJECT_DETAIL_QUERY, { slug });

if (!project) {
  return Astro.redirect("/404");
}

// Check if we have rich narrative content to trigger Mode B (Deep Case Study)
const hasDeepNarrative = !!(project.theBrief || project.theDesignResponse || project.theOutcome);

const title = project.seoTitle || `${project.title} | Metaphors Design`;
const description = project.seoDescription || project.headline || `Explore the spatial execution and architectural credentials of ${project.title} by Metaphors Design.`;
const canonicalURL = `https://metaphors.design/projects/${slug}`;

// Extract and format location values cleanly
const city = project.location?.city || "";
const state = project.location?.indiaState?.name || project.location?.otherState || "";
const country = project.location?.country?.name || "India";
const locationFormatted = [city, state, country].filter(Boolean).join(", ");

// JSON-LD structured data for SEO & AI Crawler friendliness
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://metaphors.design"
        },
        project.sector ? {
          "@type": "ListItem",
          "position": 2,
          "name": project.sector.title,
          "item": `https://metaphors.design/sectors/${project.sector.slug}`
        } : null,
        {
          "@type": "ListItem",
          "position": project.sector ? 3 : 2,
          "name": project.title,
          "item": canonicalURL
        }
      ].filter(Boolean)
    },
    {
      "@type": "ArchitecturalStructure",
      "@id": canonicalURL,
      "name": project.title,
      "description": description,
      "image": project.coverImage ? imageUrl(project.coverImage, { width: 1200 }) : undefined,
      "location": {
        "@type": "PostalAddress",
        "addressLocality": city,
        "addressRegion": state,
        "addressCountry": country
      }
    }
  ]
};
---

<Layout title={title} description={description} canonicalURL={canonicalURL}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <div class="bg-bone relative min-h-screen">
    <Header />

    <main class="pt-28 lg:pt-36">
      {/* ────────────────────────────────────────────────────────
          MODE A: VISUAL FOCUS SHEET (Light Data / Minimalist Portfolio)
          ──────────────────────────────────────────────────────── */}
      {!hasDeepNarrative && (
        <section class="mx-auto max-w-[1440px] px-6 py-12 lg:px-12 lg:py-24">
          <div class="grid grid-cols-1 gap-16 lg:grid-cols-12 lg:gap-24">
            
            {/* Left Column: Vertical Photo Essay (Images scroll naturally) */}
            <div class="space-y-8 md:space-y-12 lg:col-span-7">
              {project.coverImage && (
                <div class="reveal bg-charcoal/5 group aspect-square w-full overflow-hidden sm:aspect-4/3 lg:aspect-4/3">
                  <img
                    src={imageUrl(project.coverImage, { width: 1000 })}
                    alt={project.coverImage.alt || project.title}
                    class="h-full w-full object-cover transition-transform duration-1800 ease-luxury group-hover:scale-102"
                    loading="eager"
                    decoding="async"
                  />
                  {project.coverImage.caption && (
                    <p class="text-charcoal/40 font-sans mt-3 text-[10px] tracking-widest uppercase">
                      {project.coverImage.caption}
                    </p>
                  )}
                </div>
              )}

              {project.gallery?.filter(Boolean).map((img: any, idx: number) => (
                <div class="reveal bg-charcoal/5 group aspect-square w-full overflow-hidden sm:aspect-4/3 lg:aspect-4/3" key={idx}>
                  <img
                    src={imageUrl(img, { width: 1000 })}
                    alt={img.alt || `${project.title} Detail ${idx + 1}`}
                    class="h-full w-full object-cover transition-transform duration-1800 ease-luxury group-hover:scale-102"
                    loading="lazy"
                    decoding="async"
                  />
                  {img.caption && (
                    <p class="text-charcoal/40 font-sans mt-3 text-[10px] tracking-widest uppercase">
                      {img.caption}
                    </p>
                  )}
                </div>
              ))}
            </div>

            {/* Right Column: Sticky Editorial Datasheet */}
            <div class="lg:col-span-5">
              <div class="reveal lg:sticky lg:top-40 space-y-12">
                
                {/* Header Context */}
                <div>
                  {project.sector && (
                    <a
                      href={`/sectors/${project.sector.slug}`}
                      class="text-charcoal/50 hover:text-charcoal font-sans text-[11px] font-bold tracking-[0.4em] uppercase transition-colors"
                    >
                      {project.sector.title}
                    </a>
                  )}
                  <h1 class="text-charcoal mt-4 text-4xl leading-[1.05] font-light tracking-tight md:text-5xl lg:text-6xl">
                    {project.title}
                  </h1>
                  {project.headline && (
                    <p class="text-charcoal/70 font-serif italic mt-6 text-xl leading-relaxed">
                      {project.headline}
                    </p>
                  )}
                </div>

                {/* Stature Statistics Grid (Thin line dividers) */}
                <div class="border-charcoal/10 border-t border-b py-8 space-y-6">
                  <div class="grid grid-cols-2 gap-y-6 gap-x-8 text-sm">
                    {locationFormatted && (
                      <div class="space-y-1">
                        <span class="text-charcoal/40 text-[9px] font-bold tracking-[0.3em] uppercase">Location</span>
                        <p class="text-charcoal font-light">{locationFormatted}</p>
                      </div>
                    )}
                    {project.areaSqFt && (
                      <div class="space-y-1">
                        <span class="text-charcoal/40 text-[9px] font-bold tracking-[0.3em] uppercase">Area</span>
                        <p class="text-charcoal font-light">{project.areaSqFt.toLocaleString("en-GB")} SQFT</p>
                      </div>
                    )}
                    {project.completionYear && (
                      <div class="space-y-1">
                        <span class="text-charcoal/40 text-[9px] font-bold tracking-[0.3em] uppercase">Completed</span>
                        <p class="text-charcoal font-light">{project.completionYear}</p>
                      </div>
                    )}
                    {project.projectDuration && (
                      <div class="space-y-1">
                        <span class="text-charcoal/40 text-[9px] font-bold tracking-[0.3em] uppercase">Timeline</span>
                        <p class="text-charcoal font-light">{project.projectDuration}</p>
                      </div>
                    )}
                    {project.projectStatus && (
                      <div class="space-y-1">
                        <span class="text-charcoal/40 text-[9px] font-bold tracking-[0.3em] uppercase">Status</span>
                        <p class="text-charcoal font-light">{project.projectStatus}</p>
                      </div>
                    )}
                    {project.clientName && (
                      <div class="space-y-1">
                        <span class="text-charcoal/40 text-[9px] font-bold tracking-[0.3em] uppercase">Client</span>
                        <p class="text-charcoal font-light">{project.clientName}</p>
                      </div>
                    )}
                  </div>
                </div>

                {/* Highlights Panel (If available) */}
                {project.highlights && project.highlights.length > 0 && (
                  <div class="space-y-4">
                    <p class="text-charcoal/40 text-[9px] font-bold tracking-[0.3em] uppercase">Project Parameters</p>
                    <ul class="space-y-3">
                      {project.highlights.map((highlight: string, idx: number) => (
                        <li class="text-charcoal/70 flex items-start gap-3 text-sm font-light leading-relaxed" key={idx}>
                          <span class="text-charcoal mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-charcoal/30"></span>
                          <span>{highlight}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {/* Integrated Disciplines */}
                {project.disciplines && project.disciplines.filter(Boolean).length > 0 && (
                  <div class="space-y-4">
                    <p class="text-charcoal/40 text-[9px] font-bold tracking-[0.3em] uppercase">Delivered Disciplines</p>
                    <div class="flex flex-wrap gap-2">
                      {project.disciplines.filter(Boolean).map((disc: any, idx: number) => (
                        <a
                          href={`/disciplines/${disc.slug}`}
                          class="text-charcoal/70 border-charcoal/20 hover:text-charcoal hover:border-charcoal border px-3 py-1.5 text-[9px] font-bold tracking-[0.2em] uppercase transition-colors"
                          key={idx}
                        >
                          {disc.title}
                        </a>
                      ))}
                    </div>
                  </div>
                )}

                {/* Stewardship Stamp & Selection Notice (Selective Policy Core Rule) */}
                <div class="bg-charcoal/5 border-charcoal/5 border p-6 space-y-3">
                  <p class="text-charcoal text-[10px] font-bold tracking-[0.25em] uppercase">Stewardship Selection</p>
                  <p class="text-charcoal/60 text-[11px] font-light leading-relaxed">
                    This commission has been selected under Metaphors Design's rigorous sustainability selection prerogative, matching structural vision with environmental stewardship.
                  </p>
                </div>

                {/* Call To Action (High conversion focus) */}
                <div>
                  <a
                    href="/contact#enquiry"
                    class="group border-charcoal/20 text-bone hover:text-charcoal ease-luxury relative inline-flex h-16 w-full cursor-pointer items-center justify-center border bg-charcoal px-8 text-[10px] font-bold tracking-[0.3em] uppercase transition-all duration-1500"
                  >
                    <div class="bg-charcoal absolute inset-0 opacity-100 transition-all duration-1500 group-hover:opacity-0"></div>
                    <span class="relative z-10 transition-all duration-1500">Inquire About Similar Scale</span>
                  </a>
                </div>

              </div>
            </div>

          </div>
        </section>
      )}

      {/* ────────────────────────────────────────────────────────
          MODE B: EDITORIAL DEEP CASE STUDY (Flagship Deep Narrative Layout)
          ──────────────────────────────────────────────────────── */}
      {hasDeepNarrative && (
        <article class="relative space-y-24 pb-32">
          
          {/* 1. Monumental Hero Section */}
          <section class="relative h-[70vh] w-full overflow-hidden bg-charcoal lg:h-[90vh]">
            {project.coverImage && (
              <div class="absolute inset-0 contrast-104 grayscale-65 saturate-88 transition-all duration-1500">
                <img
                  src={imageUrl(project.coverImage, { width: 1800, height: 1200 })}
                  alt={project.projectName}
                  class="h-full w-full object-cover opacity-60"
                  loading="eager"
                  decoding="async"
                />
              </div>
            )}
            <div class="from-charcoal/90 absolute inset-0 bg-linear-to-t via-charcoal/30 to-transparent"></div>
            
            <div class="absolute bottom-0 left-0 z-10 w-full p-6 md:p-12 lg:p-24">
              <div class="mx-auto max-w-[1440px] space-y-4">
                {project.sector && (
                  <span class="text-bone/60 text-xs font-bold tracking-[0.5em] uppercase">
                    {project.sector.title}
                  </span>
                )}
                <h1 class="text-bone text-4xl leading-[1.05] font-light tracking-tight md:text-6xl lg:text-8xl max-w-4xl">
                  {project.title}
                </h1>
                {project.headline && (
                  <p class="text-bone/80 font-serif italic text-lg md:text-2xl max-w-2xl mt-4">
                    {project.headline}
                  </p>
                )}
              </div>
            </div>
          </section>

          {/* 2. Horizontal Stature Metrics Bar */}
          <section class="border-charcoal/10 border-t border-b bg-charcoal/[0.02]">
            <div class="mx-auto max-w-[1440px] px-6 py-12 lg:px-12">
              <div class="grid grid-cols-2 gap-8 md:grid-cols-4 lg:gap-12">
                {locationFormatted && (
                  <div class="space-y-2">
                    <span class="text-charcoal/40 text-[9px] font-bold tracking-[0.3em] uppercase">Location</span>
                    <p class="text-charcoal text-base font-light">{locationFormatted}</p>
                  </div>
                )}
                {project.areaSqFt && (
                  <div class="space-y-2">
                    <span class="text-charcoal/40 text-[9px] font-bold tracking-[0.3em] uppercase">Area Of Impact</span>
                    <p class="text-charcoal text-base font-light">{project.areaSqFt.toLocaleString("en-GB")} SQFT</p>
                  </div>
                )}
                {project.completionYear && (
                  <div class="space-y-2">
                    <span class="text-charcoal/40 text-[9px] font-bold tracking-[0.3em] uppercase">Year of Delivery</span>
                    <p class="text-charcoal text-base font-light">{project.completionYear}</p>
                  </div>
                )}
                {project.disciplines && project.disciplines.filter(Boolean).length > 0 && (
                  <div class="space-y-2">
                    <span class="text-charcoal/40 text-[9px] font-bold tracking-[0.3em] uppercase">Disciplines</span>
                    <p class="text-charcoal text-base font-light">
                      {project.disciplines.filter(Boolean).map((d: any) => d.title).join(", ")}
                    </p>
                  </div>
                )}
              </div>
            </div>
          </section>

          {/* 3. The Staggered Narrative (Brief & Design Response) */}
          <section class="mx-auto max-w-[1440px] px-6 space-y-24 lg:px-12 lg:space-y-36">
            
            {/* Act I: The Brief */}
            {project.theBrief && (
              <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-24 items-center">
                <div class="reveal lg:col-span-5 space-y-6">
                  <p class="text-charcoal/40 text-[10px] font-bold tracking-[0.4em] uppercase">ACT I / THE BRIEF</p>
                  <h2 class="text-charcoal text-3xl font-light tracking-tight lg:text-5xl">The Challenge & Intent.</h2>
                  <p class="text-charcoal/70 text-lg leading-relaxed font-light">
                    {project.theBrief}
                  </p>
                </div>
                <div class="reveal lg:col-span-7">
                  {project.gallery?.[0] ? (
                    <div class="bg-charcoal/5 group aspect-video overflow-hidden">
                      <img
                        src={imageUrl(project.gallery[0], { width: 900 })}
                        alt={project.gallery[0].alt || `${project.title} Architectural Concept`}
                        class="h-full w-full object-cover transition-transform duration-1800 ease-luxury group-hover:scale-102"
                      />
                    </div>
                  ) : (
                    <div class="bg-charcoal/10 aspect-video w-full" />
                  )}
                </div>
              </div>
            )}

            {/* Act II: The Design Response */}
            {project.theDesignResponse && (
              <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-24 items-center">
                <div class="reveal lg:order-2 lg:col-span-5 space-y-6">
                  <p class="text-charcoal/40 text-[10px] font-bold tracking-[0.4em] uppercase">ACT II / THE DESIGN RESPONSE</p>
                  <h2 class="text-charcoal text-3xl font-light tracking-tight lg:text-5xl">The Execution Strategy.</h2>
                  <p class="text-charcoal/70 text-lg leading-relaxed font-light">
                    {project.theDesignResponse}
                  </p>
                </div>
                <div class="reveal lg:order-1 lg:col-span-7">
                  {project.gallery?.[1] ? (
                    <div class="bg-charcoal/5 group aspect-video overflow-hidden">
                      <img
                        src={imageUrl(project.gallery[1], { width: 900 })}
                        alt={project.gallery[1].alt || `${project.title} Architectural Strategy`}
                        class="h-full w-full object-cover transition-transform duration-1800 ease-luxury group-hover:scale-102"
                      />
                    </div>
                  ) : (
                    <div class="bg-charcoal/10 aspect-video w-full" />
                  )}
                </div>
              </div>
            )}

            {/* Act III: The Outcome */}
            {project.theOutcome && (
              <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-24 items-center">
                <div class="reveal lg:col-span-5 space-y-6">
                  <p class="text-charcoal/40 text-[10px] font-bold tracking-[0.4em] uppercase">ACT III / THE OUTCOME</p>
                  <h2 class="text-charcoal text-3xl font-light tracking-tight lg:text-5xl">Spatial Output.</h2>
                  <p class="text-charcoal/70 text-lg leading-relaxed font-light">
                    {project.theOutcome}
                  </p>
                </div>
                <div class="reveal lg:col-span-7">
                  {project.gallery?.[2] ? (
                    <div class="bg-charcoal/5 group aspect-video overflow-hidden">
                      <img
                        src={imageUrl(project.gallery[2], { width: 900 })}
                        alt={project.gallery[2].alt || `${project.title} Spatial Outcome`}
                        class="h-full w-full object-cover transition-transform duration-1800 ease-luxury group-hover:scale-102"
                      />
                    </div>
                  ) : (
                    <div class="bg-charcoal/10 aspect-video w-full" />
                  )}
                </div>
              </div>
            )}

            {/* Staggered Remaining Gallery Elements */}
            {project.gallery && project.gallery.length > 3 && (
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 pt-12">
                {project.gallery.filter(Boolean).slice(3).map((img: any, idx: number) => (
                  <div class="reveal bg-charcoal/5 group aspect-square overflow-hidden" key={idx}>
                    <img
                      src={imageUrl(img, { width: 850 })}
                      alt={img.alt || `${project.title} Detail Archive ${idx + 4}`}
                      class="h-full w-full object-cover transition-transform duration-1800 ease-luxury group-hover:scale-102"
                      loading="lazy"
                    />
                    {img.caption && (
                      <p class="text-charcoal/40 font-sans mt-3 text-[10px] tracking-widest uppercase">
                        {img.caption}
                      </p>
                    )}
                  </div>
                ))}
              </div>
            )}

          </section>

          {/* 4. Testimonials (If enabled and public) */}
          {project.testimonial && project.testimonial.showPublicly && project.testimonial.quote && (
            <section class="bg-charcoal text-bone relative py-24 lg:py-36 overflow-hidden">
              <div class="absolute inset-0 bg-linear-to-b from-transparent to-black/30 opacity-40"></div>
              <div class="reveal relative z-10 mx-auto max-w-[1000px] px-6 text-center space-y-8">
                <p class="text-bone/40 text-[10px] font-bold tracking-[0.5em] uppercase">CLIENT COMMENDATION</p>
                <blockquote class="text-2xl md:text-4xl font-light leading-snug tracking-tight max-w-3xl mx-auto">
                  “{project.testimonial.quote}”
                </blockquote>
                {project.testimonial.attribution && (
                  <cite class="text-bone/60 font-serif italic text-base md:text-lg block">
                    — {project.testimonial.attribution}
                  </cite>
                )}
              </div>
            </section>
          )}

          {/* 5. Accolades & Distinctions */}
          {project.awards && project.awards.length > 0 && (
            <section class="mx-auto max-w-[1440px] px-6 py-12 lg:px-12">
              <div class="border-charcoal/10 border-t pt-16 space-y-12">
                <div class="reveal space-y-2">
                  <p class="text-charcoal/40 text-[10px] font-bold tracking-[0.4em] uppercase">DISTINCTIONS</p>
                  <h2 class="text-charcoal text-3xl font-light tracking-tight lg:text-5xl">Awards & Accolades</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 pt-6">
                  {project.awards.map((award: any, idx: number) => (
                    <div class="reveal border border-charcoal/10 bg-charcoal/[0.01] p-8 space-y-4" key={idx}>
                      <span class="text-charcoal/40 text-xs font-bold font-sans tracking-widest">{award.year}</span>
                      <h3 class="text-charcoal text-xl font-light tracking-tight">{award.awardName}</h3>
                      {award.awardingBody && (
                        <p class="text-charcoal/60 text-sm font-light">{award.awardingBody}</p>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            </section>
          )}

          {/* 6. Conversion CTA */}
          <section class="mx-auto max-w-[1440px] px-6 lg:px-12 pt-12">
            <div class="bg-charcoal text-bone relative overflow-hidden px-8 py-20 lg:p-24 text-center space-y-8">
              <div class="from-black/40 absolute inset-0 bg-linear-to-b to-transparent opacity-60"></div>
              <div class="reveal relative z-10 max-w-2xl mx-auto space-y-6">
                <p class="text-bone/40 text-[10px] font-bold tracking-[0.5em] uppercase">COLLABORATIVE INTENT</p>
                <h2 class="text-bone text-3xl md:text-5xl font-light tracking-tight leading-none">
                  Begin a Dialogue on Sustainable Stature.
                </h2>
                <p class="text-bone/70 text-sm md:text-base font-light max-w-lg mx-auto leading-relaxed">
                  We align our architectural capabilities exclusively with clients dedicated to structural future-proofing and high-level stewardship.
                </p>
                <div class="pt-6">
                  <a
                    href="/contact#enquiry"
                    class="group border-bone/20 text-charcoal hover:text-bone ease-luxury relative inline-flex h-16 w-full cursor-pointer items-center justify-center border bg-bone px-12 text-[10px] font-bold tracking-[0.3em] uppercase transition-all duration-1500 sm:w-auto"
                  >
                    <div class="bg-bone absolute inset-0 opacity-100 transition-all duration-1500 group-hover:opacity-0"></div>
                    <span class="relative z-10 transition-all duration-1500">Initiate Dialogue</span>
                  </a>
                </div>
              </div>
            </div>
          </section>

        </article>
      )}
    </main>

    <Footer />
  </div>
</Layout>

<script>
  (() => {
    // Reveal animations on scroll utilizing the global luxury easing transition
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
          }
        });
      },
      { threshold: 0.05 }
    );

    document.querySelectorAll(".reveal").forEach((el) => {
      observer.observe(el);
    });
  })();
</script>

<style is:global>
  /* Premium Luxury Transitions */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 1.8s cubic-bezier(0.19, 1, 0.22, 1), transform 1.8s cubic-bezier(0.19, 1, 0.22, 1);
    will-change: opacity, transform;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
