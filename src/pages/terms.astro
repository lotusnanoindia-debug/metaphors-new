---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MainCta from "../components/MainCta.astro";

const title = "Terms of Engagement | Metaphors Design";
const description =
  "Terms of Engagement for Metaphors Design, outlining standard principles and conditions for architectural and design services.";
---

<Layout title={title} description={description} canonicalURL="https://metaphors.design/terms">
  <div class="bg-bone relative min-h-screen overflow-x-hidden">
    <Header />

    <main>
      <!-- HERO SECTION -->
      <section class="relative w-full py-48 lg:py-56">
        <div class="mx-auto max-w-[1440px] px-6 lg:px-12">
          <div class="mx-auto flex max-w-5xl flex-col items-center text-center">
            <p
              class="text-charcoal/40 font-inter mb-8 text-[12px] font-bold tracking-[0.3em] uppercase"
            >
              Effective Date: January 1, 2026
            </p>
            <h1
              class="reveal text-[clamp(3rem,8vw,7rem)] leading-[0.9] font-medium tracking-[-0.045em] select-none"
            >
              <span class="text-charcoal block">Terms of Engagement</span>
            </h1>
            <p
              class="text-charcoal/60 reveal mt-12 max-w-2xl text-xl leading-relaxed font-light tracking-tight lg:text-2xl"
            >
              These terms define the professional framework and partnership principles under which
              Metaphors Design conducts its architectural and consultancy practice.
            </p>
          </div>
        </div>
      </section>

      <!-- TERMS CONTENT GRID -->
      <section class="mx-auto max-w-[1440px] px-6 pb-32 lg:px-12 lg:pb-48">
        <div class="border-charcoal/10 relative pt-16 lg:pt-24">
          <!-- Timeline vertical hairline -->
          <div class="bg-charcoal/10 absolute top-16 bottom-0 left-0 w-px lg:top-24"></div>

          <div class="space-y-24 lg:space-y-32">
            <!-- Section 01 -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div
                class="group-hover:bg-charcoal/4 -mx-6 flex flex-col gap-8 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:col-span-12 lg:-mx-10 lg:grid lg:grid-cols-12 lg:gap-24 lg:p-10"
              >
                <div class="lg:col-span-4">
                  <p
                    class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                  >
                    01 — Partnership
                  </p>
                  <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                    Professional Framework
                  </h3>
                </div>
                <div
                  class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
                >
                  <p>
                    Metaphors Design operates under the professional standards prescribed by the <strong
                      class="text-charcoal font-medium">Council of Architecture (CoA), India</strong
                    >. Our engagement is a partnership defined by architectural precision and
                    long-term stewardship.
                  </p>
                  <p>
                    Services generally follow established industry phases: Conceptual Design,
                    Schematic Design, Design Development, Construction Documentation, and
                    Administration. Any alterations to the agreed scope must be formalised in
                    writing and may necessitate fee adjustments.
                  </p>
                </div>
              </div>
            </div>

            <!-- Section 02 -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div
                class="group-hover:bg-charcoal/4 -mx-6 flex flex-col gap-8 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:col-span-12 lg:-mx-10 lg:grid lg:grid-cols-12 lg:gap-24 lg:p-10"
              >
                <div class="lg:col-span-4">
                  <p
                    class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                  >
                    02 — Client
                  </p>
                  <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                    Client Responsibilities
                  </h3>
                </div>
                <div
                  class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
                >
                  <p>To ensure a successful project, the Client agrees to:</p>
                  <ul class="list-disc space-y-3 pl-6">
                    <li>
                      Provide complete and accurate information regarding project requirements, site
                      conditions, and budget.
                    </li>
                    <li>Make timely decisions to keep the project on schedule.</li>
                    <li>
                      Appoint and coordinate with necessary specialised consultants or contractors
                      when required, unless otherwise agreed upon.
                    </li>
                    <li>
                      Secure required permits, approvals, and variances from local authorities
                      (e.g., Pune Municipal Corporation), with our assistance as outlined in the
                      specific project agreement.
                    </li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Section 03 -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div
                class="group-hover:bg-charcoal/4 -mx-6 flex flex-col gap-8 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:col-span-12 lg:-mx-10 lg:grid lg:grid-cols-12 lg:gap-24 lg:p-10"
              >
                <div class="lg:col-span-4">
                  <p
                    class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                  >
                    03 — Fees
                  </p>
                  <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                    Professional Fees
                  </h3>
                </div>
                <div
                  class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
                >
                  <p>
                    Fees are determined based on the scope, scale, and complexity of the project.
                    They may be structured as a lump sum, a percentage of the construction cost, or
                    an hourly rate, as detailed in the formal contract.
                  </p>
                  <p>
                    Invoices are issued based on project milestones or monthly progress and are
                    payable within the timeframe stipulated in the invoice.
                  </p>
                </div>
              </div>
            </div>

            <!-- Section 04 -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div
                class="group-hover:bg-charcoal/4 -mx-6 flex flex-col gap-8 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:col-span-12 lg:-mx-10 lg:grid lg:grid-cols-12 lg:gap-24 lg:p-10"
              >
                <div class="lg:col-span-4">
                  <p
                    class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                  >
                    04 — Integrity
                  </p>
                  <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                    Design Narrative & IP
                  </h3>
                </div>
                <div
                  class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
                >
                  <p>
                    The intellectual rigour and design narrative of each project remain the property
                    of Metaphors Design. All concepts, drawings, and specifications are instruments
                    of professional service.
                  </p>
                  <p>
                    Partners are granted a non-exclusive licence for the construction and
                    maintenance of the specific project, provided all professional fees are settled.
                    The integrity of the architectural intent must be maintained; Metaphors Design
                    reserves moral rights over the design's public representation and execution.
                  </p>
                </div>
              </div>
            </div>

            <!-- Section 05 -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div
                class="group-hover:bg-charcoal/4 -mx-6 flex flex-col gap-8 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:col-span-12 lg:-mx-10 lg:grid lg:grid-cols-12 lg:gap-24 lg:p-10"
              >
                <div class="lg:col-span-4">
                  <p
                    class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                  >
                    05 — Stewardship
                  </p>
                  <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                    Future-Proofing
                  </h3>
                </div>
                <div
                  class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
                >
                  <p>
                    Metaphors Design operates with a mandate of long-term stewardship. Design
                    decisions are frequently weighted towards sustainability, ecological impact, and
                    future-proofing.
                  </p>
                  <p>
                    While we collaborate closely with our partners, departures from sustainability
                    parameters at the Client’s request may be documented as a deviation from the
                    studio's primary design philosophy.
                  </p>
                </div>
              </div>
            </div>

            <!-- Section 06 -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div
                class="group-hover:bg-charcoal/4 -mx-6 flex flex-col gap-8 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:col-span-12 lg:-mx-10 lg:grid lg:grid-cols-12 lg:gap-24 lg:p-10"
              >
                <div class="lg:col-span-4">
                  <p
                    class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                  >
                    06 — Liability
                  </p>
                  <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                    Professional Care
                  </h3>
                </div>
                <div
                  class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
                >
                  <p>
                    We perform our services with the reasonable standard of care expected of a
                    leading architectural practice. Metaphors Design is not liable for the
                    performance, quality, or safety protocols of third-party contractors or
                    consultants.
                  </p>
                </div>
              </div>
            </div>

            <!-- Section 07 -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div
                class="group-hover:bg-charcoal/4 -mx-6 flex flex-col gap-8 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:col-span-12 lg:-mx-10 lg:grid lg:grid-cols-12 lg:gap-24 lg:p-10"
              >
                <div class="lg:col-span-4">
                  <p
                    class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                  >
                    07 — Resolution
                  </p>
                  <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                    Amicable Settlement
                  </h3>
                </div>
                <div
                  class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
                >
                  <p>
                    We value dialogue. In the event of a dispute, both parties agree to attempt an
                    amicable settlement through professional mediation before seeking legal
                    recourse.
                  </p>
                  <p>
                    These terms are governed by the laws of India, with exclusive jurisdiction
                    granted to the courts of Pune, Maharashtra.
                  </p>
                </div>
              </div>
            </div>

            <!-- Contact Section -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div
                class="group-hover:bg-charcoal/4 -mx-6 flex flex-col gap-8 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:col-span-12 lg:-mx-10 lg:grid lg:grid-cols-12 lg:gap-24 lg:p-10"
              >
                <div class="lg:col-span-4">
                  <p
                    class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                  >
                    08 — Dialogue
                  </p>
                  <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                    Clarifications
                  </h3>
                </div>
                <div
                  class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
                >
                  <p>
                    If you have questions or require clarification regarding these terms, please
                    contact us at:
                  </p>
                  <div class="bg-charcoal/5 mt-8 p-8 lg:p-12">
                    <address class="space-y-2 not-italic">
                      <p><strong class="text-charcoal font-medium">Metaphors Design</strong></p>
                      <p>Pune, Maharashtra, India</p>
                      <p>Phone: (+91) 96653 55522 / (+91) 98222 79173</p>
                      <p>
                        Email: <a
                          href="mailto:info@metaphors-design.com"
                          class="text-charcoal hover:text-charcoal/60 underline transition-colors"
                          >info@metaphors-design.com</a>
                      </p>
                    </address>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <MainCta
        section={{
          eyebrow: "Engagement",
          headline: "Begin the Dialogue.",
          tagline:
            "You don't need a finished brief. Ambition and intent are enough to start the conversation.",
          ctaLabel: "Start the Conversation",
          ctaUrl: "/contact",
        }}
        className="border-charcoal/5 border-t bg-[#f2f1ec]"
      />

      <Footer />
    </main>
  </div>
</Layout>
