---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MainCta from "../components/MainCta.astro";

const title = "Terms of Engagement | Metaphors Design";
const description = "Terms of Engagement for Metaphors Design, outlining standard principles and conditions for architectural and design services.";
---

<Layout title={title} description={description} canonicalURL="https://metaphors.design/terms">
  <div class="bg-bone relative min-h-screen overflow-x-hidden">
    <Header />

    <main>
      <!-- HERO SECTION -->
      <section class="relative w-full py-48 lg:py-56">
        <div class="mx-auto max-w-[1440px] px-6 lg:px-12">
          <div class="mx-auto flex max-w-5xl flex-col items-center text-center">
            <p class="text-charcoal/40 font-inter mb-8 text-[12px] font-bold tracking-[0.3em] uppercase">
              Effective Date: January 1, 2026
            </p>
            <h1 class="reveal text-[clamp(3rem,8vw,7rem)] leading-[0.9] font-medium tracking-[-0.045em] select-none">
              <span class="text-charcoal block">Terms of Engagement</span>
            </h1>
            <p class="text-charcoal/60 reveal mt-12 max-w-2xl text-xl leading-relaxed font-light tracking-tight lg:text-2xl">
              Welcome to Metaphors Design. These Terms outline the standard principles and conditions under which our architectural, interior design, and masterplanning services are provided.
            </p>
          </div>
        </div>
      </section>

      <!-- TERMS CONTENT GRID -->
      <section class="mx-auto max-w-[1440px] px-6 pb-32 lg:px-12 lg:pb-48">
        <div class="border-charcoal/10 space-y-24 border-t pt-16 lg:space-y-32 lg:pt-24">

          <!-- Section 01 -->
          <div class="reveal grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-24">
            <div class="lg:col-span-4">
              <p class="text-charcoal/40 font-inter mb-4 text-[12px] font-bold tracking-[0.3em] uppercase">
                01 — Scope
              </p>
              <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                Scope of Services
              </h3>
            </div>
            <div class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl">
              <p>
                Metaphors Design offers a range of design and consultancy services as agreed upon in a formal proposal or contract. Our services generally follow industry-standard phases including conceptual design, schematic design, design development, construction documentation, and construction administration.
              </p>
              <p>
                Any changes or additions to the scope of work will require written approval and may incur additional fees. These terms apply generally, though specific project details will be formalized in an individual Client Agreement.
              </p>
            </div>
          </div>

          <!-- Section 02 -->
          <div class="reveal grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-24">
            <div class="lg:col-span-4">
              <p class="text-charcoal/40 font-inter mb-4 text-[12px] font-bold tracking-[0.3em] uppercase">
                02 — Client
              </p>
              <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                Client Responsibilities
              </h3>
            </div>
            <div class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl">
              <p>
                To ensure a successful project, the Client agrees to:
              </p>
              <ul class="list-disc space-y-3 pl-6">
                <li>Provide complete and accurate information regarding project requirements, site conditions, and budget.</li>
                <li>Make timely decisions to keep the project on schedule.</li>
                <li>Appoint and coordinate with necessary specialized consultants or contractors when required, unless otherwise agreed upon.</li>
                <li>Secure required permits, approvals, and variances from local authorities (e.g., Pune Municipal Corporation), with our assistance as outlined in the specific project agreement.</li>
              </ul>
            </div>
          </div>

          <!-- Section 03 -->
          <div class="reveal grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-24">
            <div class="lg:col-span-4">
              <p class="text-charcoal/40 font-inter mb-4 text-[12px] font-bold tracking-[0.3em] uppercase">
                03 — Fees
              </p>
              <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                Professional Fees
              </h3>
            </div>
            <div class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl">
              <p>
                Fees are determined based on the scope, scale, and complexity of the project. They may be structured as a lump sum, a percentage of the construction cost, or an hourly rate, as detailed in the formal contract.
              </p>
              <p>
                Invoices are issued based on project milestones or monthly progress and are payable within the timeframe stipulated in the invoice.
              </p>
            </div>
          </div>

          <!-- Section 04 -->
          <div class="reveal grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-24">
            <div class="lg:col-span-4">
              <p class="text-charcoal/40 font-inter mb-4 text-[12px] font-bold tracking-[0.3em] uppercase">
                04 — IP
              </p>
              <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                Intellectual Property
              </h3>
            </div>
            <div class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl">
              <p>
                All design concepts, drawings, models, specifications, and other documents prepared by Metaphors Design are instruments of our professional service and remain the intellectual property of Metaphors Design.
              </p>
              <p>
                Clients are granted a non-exclusive license to use these documents solely for the purpose of constructing, using, and maintaining the specific project for which they were created, provided that all fees owed have been paid in full.
              </p>
            </div>
          </div>

          <!-- Section 05 -->
          <div class="reveal grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-24">
            <div class="lg:col-span-4">
              <p class="text-charcoal/40 font-inter mb-4 text-[12px] font-bold tracking-[0.3em] uppercase">
                05 — Liability
              </p>
              <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                Limitation of Liability
              </h3>
            </div>
            <div class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl">
              <p>
                Metaphors Design performs its services with the reasonable standard of care expected of professionals practicing in Pune, India. However, we cannot guarantee the performance, quality, or timely completion of work by third-party contractors or consultants.
              </p>
              <p>
                Our liability for any claims arising from the project is limited as defined in the specific Client Agreement.
              </p>
            </div>
          </div>

          <!-- Section 06 & 07 -->
          <div class="reveal grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-24">
            <div class="lg:col-span-4">
              <p class="text-charcoal/40 font-inter mb-4 text-[12px] font-bold tracking-[0.3em] uppercase">
                06 — Termination
              </p>
              <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                Termination & Law
              </h3>
            </div>
            <div class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl">
              <p>
                Either party may terminate the engagement with reasonable written notice should the other party fail substantially to perform in accordance with the agreed terms through no fault of the terminating party. In the event of termination, Metaphors Design shall be compensated for all services performed and expenses incurred up to the date of termination.
              </p>
              <p>
                These terms, and any disputes arising out of or related to our services, shall be governed by and construed in accordance with the laws of India. Any legal proceedings shall be subject to the exclusive jurisdiction of the courts in Pune, Maharashtra.
              </p>
            </div>
          </div>

          <!-- Contact Section -->
          <div class="reveal grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-24">
            <div class="lg:col-span-4">
              <p class="text-charcoal/40 font-inter mb-4 text-[12px] font-bold tracking-[0.3em] uppercase">
                07 — Contact
              </p>
              <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                Clarifications
              </h3>
            </div>
            <div class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl">
              <p>
                If you have questions or require clarification regarding these terms, please contact us at:
              </p>
              <div class="bg-charcoal/5 mt-8 p-8 lg:p-12">
                <address class="not-italic space-y-2">
                  <p><strong class="text-charcoal font-medium">Metaphors Design</strong></p>
                  <p>Pune, Maharashtra, India</p>
                  <p>Phone: (+91) 96653 55522 / (+91) 98222 79173</p>
                  <p>Email: <a href="mailto:info@metaphors-design.com" class="text-charcoal hover:text-charcoal/60 underline transition-colors">info@metaphors-design.com</a></p>
                </address>
              </div>
            </div>
          </div>

        </div>
      </section>
    </main>

    <MainCta
      section={{
        eyebrow: "Engagement",
        headline: "Begin the Dialogue.",
        tagline: "You don't need a finished brief. Ambition and intent are enough to start the conversation.",
        ctaLabel: "Start the Conversation",
        ctaUrl: "/contact",
      }}
      className="bg-[#f2f1ec] border-charcoal/5 border-t"
    />

    <Footer />
  </div>
</Layout>
