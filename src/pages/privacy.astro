---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MainCta from "../components/MainCta.astro";

const title = "Privacy Policy | Metaphors Design";
const description = "Privacy Policy for Metaphors Design, an architectural practice based in Pune, India.";
---

<Layout title={title} description={description} canonicalURL="https://metaphors.design/privacy">
  <div class="bg-bone relative min-h-screen overflow-x-hidden">
    <Header />

    <main>
      <!-- HERO SECTION -->
      <section class="relative w-full py-48 lg:py-56">
        <div class="mx-auto max-w-[1440px] px-6 lg:px-12">
          <div class="mx-auto flex max-w-5xl flex-col items-center text-center">
            <p class="text-charcoal/40 font-inter mb-8 text-[12px] font-bold tracking-[0.3em] uppercase">
              Effective Date: January 1, 2026
            </p>
            <h1 class="reveal text-[clamp(3rem,8vw,7rem)] leading-[0.9] font-medium tracking-[-0.045em] select-none">
              <span class="text-charcoal block">Privacy Policy</span>
            </h1>
            <p class="text-charcoal/60 reveal mt-12 max-w-2xl text-xl leading-relaxed font-light tracking-tight lg:text-2xl">
              At Metaphors Design, we are committed to protecting the privacy and security of our clients, partners, and website visitors. This policy outlines how we handle your information.
            </p>
          </div>
        </div>
      </section>

      <!-- POLICY CONTENT GRID -->
      <section class="mx-auto max-w-[1440px] px-6 pb-32 lg:px-12 lg:pb-48">
        <div class="border-charcoal/10 space-y-24 border-t pt-16 lg:space-y-32 lg:pt-24">

          <!-- Section 01 -->
          <div class="reveal grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-24">
            <div class="lg:col-span-4">
              <p class="text-charcoal/40 font-inter mb-4 text-[12px] font-bold tracking-[0.3em] uppercase">
                01 — Collection
              </p>
              <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                Information We Collect
              </h3>
            </div>
            <div class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl">
              <p>
                We may collect personal information that you voluntarily provide to us when you:
              </p>
              <ul class="list-disc space-y-3 pl-6">
                <li>Contact us via email, phone, or through our website contact forms.</li>
                <li>Engage our architectural, interior design, or consultancy services.</li>
                <li>Subscribe to our newsletters or updates.</li>
              </ul>
              <p>
                This information may include your name, email address, phone number, physical address, and details related to your project inquiries.
              </p>
            </div>
          </div>

          <!-- Section 02 -->
          <div class="reveal grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-24">
            <div class="lg:col-span-4">
              <p class="text-charcoal/40 font-inter mb-4 text-[12px] font-bold tracking-[0.3em] uppercase">
                02 — Usage
              </p>
              <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                How We Use Your Information
              </h3>
            </div>
            <div class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl">
              <p>
                The information we collect is used in the following ways:
              </p>
              <ul class="list-disc space-y-3 pl-6">
                <li>To provide, operate, and maintain our services.</li>
                <li>To respond to your inquiries and offer customer support.</li>
                <li>To communicate with you regarding project updates, proposals, and relevant architectural insights.</li>
                <li>To improve our website and tailor our content to better serve our audience.</li>
              </ul>
            </div>
          </div>

          <!-- Section 03 -->
          <div class="reveal grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-24">
            <div class="lg:col-span-4">
              <p class="text-charcoal/40 font-inter mb-4 text-[12px] font-bold tracking-[0.3em] uppercase">
                03 — Sharing
              </p>
              <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                Information Sharing
              </h3>
            </div>
            <div class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl">
              <p>
                As a professional architectural practice, client confidentiality is paramount. We do not sell, trade, or rent your personal information to third parties. We may share your information only under the following circumstances:
              </p>
              <ul class="list-disc space-y-3 pl-6">
                <li><strong class="text-charcoal font-medium">Service Providers:</strong> With trusted third-party contractors and consultants (e.g., structural engineers, landscape architects) who assist us in operating our business and delivering your project, provided they agree to keep this information confidential.</li>
                <li><strong class="text-charcoal font-medium">Legal Requirements:</strong> When required by law or in response to a valid legal request from authorities in India.</li>
              </ul>
            </div>
          </div>

          <!-- Section 04 -->
          <div class="reveal grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-24">
            <div class="lg:col-span-4">
              <p class="text-charcoal/40 font-inter mb-4 text-[12px] font-bold tracking-[0.3em] uppercase">
                04 — Protection
              </p>
              <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                Data Security
              </h3>
            </div>
            <div class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl">
              <p>
                We implement appropriate technical and organizational security measures designed to protect the security of any personal information we process. However, please be aware that no electronic transmission over the internet or information storage technology can be guaranteed to be 100% secure.
              </p>
            </div>
          </div>

          <!-- Section 05 -->
          <div class="reveal grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-24">
            <div class="lg:col-span-4">
              <p class="text-charcoal/40 font-inter mb-4 text-[12px] font-bold tracking-[0.3em] uppercase">
                05 — Your Rights
              </p>
              <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                Access & Control
              </h3>
            </div>
            <div class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl">
              <p>
                Depending on your jurisdiction, you may have rights regarding your personal information, including the right to access, correct, or delete the personal data we hold about you. To exercise these rights, please contact us.
              </p>
              <p>
                We may update this Privacy Policy from time to time to reflect changes in our practices or for other operational, legal, or regulatory reasons.
              </p>
            </div>
          </div>

          <!-- Contact Section -->
          <div class="reveal grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-24">
            <div class="lg:col-span-4">
              <p class="text-charcoal/40 font-inter mb-4 text-[12px] font-bold tracking-[0.3em] uppercase">
                06 — Contact
              </p>
              <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                Get In Touch
              </h3>
            </div>
            <div class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl">
              <p>
                If you have questions or comments about this Privacy Policy, please contact us at:
              </p>
              <div class="bg-charcoal/5 mt-8 p-8 lg:p-12">
                <address class="not-italic space-y-2">
                  <p><strong class="text-charcoal font-medium">Metaphors Design</strong></p>
                  <p>Pune, Maharashtra, India</p>
                  <p>Phone: (+91) 96653 55522 / (+91) 98222 79173</p>
                  <p>Email: <a href="mailto:info@metaphors-design.com" class="text-charcoal hover:text-charcoal/60 underline transition-colors">info@metaphors-design.com</a></p>
                </address>
              </div>
            </div>
          </div>

        </div>
      </section>
    </main>

    <MainCta
      section={{
        eyebrow: "Engagement",
        headline: "Begin the Dialogue.",
        tagline: "You don't need a finished brief. Ambition and intent are enough to start the conversation.",
        ctaLabel: "Start the Conversation",
        ctaUrl: "/contact",
      }}
      className="bg-[#f2f1ec] border-charcoal/5 border-t"
    />

    <Footer />
  </div>
</Layout>
