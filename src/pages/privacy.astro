---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MainCta from "../components/MainCta.astro";

const title = "Privacy Policy | Metaphors Design";
const description =
  "Privacy Policy for Metaphors Design, an architectural practice based in Pune, India.";
---

<Layout title={title} description={description} canonicalURL="https://metaphors.design/privacy">
  <div class="bg-bone relative min-h-screen overflow-x-hidden">
    <Header />

    <main>
      <!-- HERO SECTION -->
      <section class="relative w-full py-48 lg:py-56">
        <div class="mx-auto max-w-[1440px] px-6 lg:px-12">
          <div class="mx-auto flex max-w-5xl flex-col items-center text-center">
            <p
              class="text-charcoal/40 font-inter mb-8 text-[12px] font-bold tracking-[0.3em] uppercase"
            >
              Effective Date: January 1, 2026
            </p>
            <h1
              class="reveal text-[clamp(3rem,8vw,7rem)] leading-[0.9] font-medium tracking-[-0.045em] select-none"
            >
              <span class="text-charcoal block">Privacy Policy</span>
            </h1>
            <p
              class="text-charcoal/60 reveal mt-12 max-w-2xl text-xl leading-relaxed font-light tracking-tight lg:text-2xl"
            >
              At Metaphors Design, we are committed to protecting the privacy and security of our
              clients, partners, and website visitors. This policy outlines how we handle your
              information.
            </p>
          </div>
        </div>
      </section>

      <!-- POLICY CONTENT GRID -->
      <section class="mx-auto max-w-[1440px] px-6 pb-32 lg:px-12 lg:pb-48">
        <div class="border-charcoal/10 relative pt-16 lg:pt-24">
          <!-- Timeline vertical hairline -->
          <div class="bg-charcoal/10 absolute top-16 bottom-0 left-0 w-px lg:top-24"></div>

          <div class="space-y-24 lg:space-y-32">
            <!-- Section 01 -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div class="lg:col-span-4">
                <p
                  class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                >
                  01 — Collection
                </p>
                <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                  Information We Collect
                </h3>
              </div>
              <div
                class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
              >
                <p>
                  We may collect personal information that you voluntarily provide to us when you:
                </p>
                <ul class="list-disc space-y-3 pl-6">
                  <li>Contact us via email, phone, or through our website contact forms.</li>
                  <li>Engage our architectural, interior design, or consultancy services.</li>
                  <li>Subscribe to our newsletters or updates.</li>
                </ul>
                <p>
                  This information may include your name, email address, phone number, physical
                  address, and details related to your project enquiries.
                </p>
              </div>
            </div>

            <!-- Section 02 -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div
                class="group-hover:bg-charcoal/4 -mx-6 flex flex-col gap-8 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:col-span-12 lg:-mx-10 lg:grid lg:grid-cols-12 lg:gap-24 lg:p-10"
              >
                <div class="lg:col-span-4">
                  <p
                    class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                  >
                    02 — Usage
                  </p>
                  <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                    How We Use Your Information
                  </h3>
                </div>
                <div
                  class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
                >
                  <p>
                    Your information is used exclusively to facilitate the design narrative and
                    professional stewardship of your project. This includes:
                  </p>
                  <ul class="list-disc space-y-3 pl-6">
                    <li>
                      Direct communication regarding project milestones and technical requirements.
                    </li>
                    <li>
                      Coordination with specialised consultants and contractors necessary for
                      execution.
                    </li>
                    <li>Legal compliance with building authorities and professional bodies.</li>
                    <li>
                      Long-term archiving of project history to ensure future-proofing and
                      maintenance continuity.
                    </li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Section 03 -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div
                class="group-hover:bg-charcoal/4 -mx-6 flex flex-col gap-8 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:col-span-12 lg:-mx-10 lg:grid lg:grid-cols-12 lg:gap-24 lg:p-10"
              >
                <div class="lg:col-span-4">
                  <p
                    class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                  >
                    03 — Sharing
                  </p>
                  <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                    Information Sharing
                  </h3>
                </div>
                <div
                  class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
                >
                  <p>
                    Metaphors Design values professional discretion. We do not sell or trade your
                    information. Sharing occurs only when essential for project
                    delivery—specifically with authorised consultants, engineering partners, and
                    regulatory agencies.
                  </p>
                  <ul class="list-disc space-y-3 pl-6">
                    <li>
                      <strong class="text-charcoal font-medium">Professional Collaboration:</strong> With
                      trusted consultants (e.g., structural engineers, MEP consultants) necessary for
                      project execution, bound by confidentiality agreements.
                    </li>
                    <li>
                      <strong class="text-charcoal font-medium">Discreet Publication:</strong> Project
                      imagery or data is only shared for editorial or portfolio purposes with the explicit
                      or understood consent of the partner, maintaining the discreet nature of the studio.
                    </li>
                    <li>
                      <strong class="text-charcoal font-medium">Legal Mandate:</strong> When required
                      by the laws of India.
                    </li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Section 04 -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div
                class="group-hover:bg-charcoal/4 -mx-6 flex flex-col gap-8 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:col-span-12 lg:-mx-10 lg:grid lg:grid-cols-12 lg:gap-24 lg:p-10"
              >
                <div class="lg:col-span-4">
                  <p
                    class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                  >
                    04 — Protection
                  </p>
                  <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                    Data Security
                  </h3>
                </div>
                <div
                  class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
                >
                  <p>
                    We implement technical and organisational measures to secure your data. Our
                    commitment to security extends to our <strong class="text-charcoal font-medium"
                      >Physical Archives</strong
                    > (drawings, surveys, and site documents) which are maintained with the same rigour
                    as our digital infrastructure.
                  </p>
                </div>
              </div>
            </div>

            <!-- Section 05 -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div
                class="group-hover:bg-charcoal/4 -mx-6 flex flex-col gap-8 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:col-span-12 lg:-mx-10 lg:grid lg:grid-cols-12 lg:gap-24 lg:p-10"
              >
                <div class="lg:col-span-4">
                  <p
                    class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                  >
                    05 — Your Rights
                  </p>
                  <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                    Access & Control
                  </h3>
                </div>
                <div
                  class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
                >
                  <p>
                    You retain the right to access, rectify, or request the erasure of your personal
                    data held within our records. For enquiries regarding your data or our
                    professional confidentiality standards, please contact our administrative
                    office.
                  </p>
                  <p>
                    We may update this Privacy Policy from time to time to reflect changes in our
                    practices or for other operational, legal, or regulatory reasons.
                  </p>
                </div>
              </div>
            </div>

            <!-- Contact Section -->
            <div
              class="group reveal relative grid grid-cols-1 gap-8 pl-12 lg:grid-cols-12 lg:gap-24 lg:pl-24"
            >
              <!-- Timeline dot -->
              <div
                class="bg-charcoal group-hover:bg-charcoal/80 ring-bone absolute top-1.5 -left-[4px] h-2 w-2 rounded-full ring-[6px] transition-all duration-700 group-hover:scale-[1.8]"
              >
              </div>
              <div
                class="group-hover:bg-charcoal/4 -mx-6 flex flex-col gap-8 rounded-2xl p-6 transition-colors duration-700 sm:-mx-8 sm:p-8 lg:col-span-12 lg:-mx-10 lg:grid lg:grid-cols-12 lg:gap-24 lg:p-10"
              >
                <div class="lg:col-span-4">
                  <p
                    class="text-charcoal/40 font-inter group-hover:text-charcoal/80 mb-4 text-[12px] font-bold tracking-[0.3em] uppercase transition-colors duration-500"
                  >
                    06 — Contact
                  </p>
                  <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
                    Get In Touch
                  </h3>
                </div>
                <div
                  class="text-charcoal/60 space-y-6 text-lg leading-relaxed lg:col-span-8 lg:text-xl"
                >
                  <p>For any privacy-related enquiries, please reach out to us:</p>
                  <div class="bg-charcoal/5 mt-8 p-8 lg:p-12">
                    <address class="space-y-2 not-italic">
                      <p><strong class="text-charcoal font-medium">Metaphors Design</strong></p>
                      <p>Pune, Maharashtra, India</p>
                      <p>
                        Email: <a
                          href="mailto:info@metaphors-design.com"
                          class="text-charcoal hover:text-charcoal/60 underline transition-colors"
                          >info@metaphors-design.com</a>
                      </p>
                    </address>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <MainCta
        section={{
          eyebrow: "Engagement",
          headline: "Begin the Dialogue.",
          tagline:
            "You don't need a finished brief. Ambition and intent are enough to start the conversation.",
          ctaLabel: "Start the Conversation",
          ctaUrl: "/contact",
        }}
        className="border-charcoal/5 border-t bg-[#f2f1ec]"
      />

      <Footer />
    </main>
  </div>
</Layout>
