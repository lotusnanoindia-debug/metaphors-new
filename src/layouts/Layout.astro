---
import ContactModal from "../components/ContactModal.astro";
import "@fontsource-variable/inter";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title,
  description = "Architectural precision for high-stakes Indian developments. ROI-driven design, engineered for execution certainty.",
  image = "/og-default.png",
  canonicalURL = Astro.url.href,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/logo-v1.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@metaphorsdesign" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <slot name="head" />
  </head>
  <body
    class="bg-bone text-charcoal overflow-x-hidden antialiased selection:bg-black selection:text-white"
  >
    <slot />
    <ContactModal />

    <script>
      // Global intersection observer for reveal animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.1 },
      );

      // Initialize on load and re-initialize after ViewTransitions (if ever added)
      document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
      });
    </script>
  </body>
</html>
