---
import { SEO } from "astro-seo";
import "@fontsource-variable/inter";
import "@fontsource/instrument-serif/400.css";
import "@fontsource/instrument-serif/400-italic.css";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={title}
      description="Architectural precision for high-stakes Indian developments. ROI-driven design, engineered for execution certainty."
    />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/logo-v1.png" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body
    class="bg-bone text-charcoal antialiased font-sans selection:bg-black selection:text-white overflow-x-hidden"
  >
    <slot />
    
    <script>
      // Global intersection observer for reveal animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.1 },
      );

      // Initialize on load and re-initialize after ViewTransitions (if ever added)
      document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
      });
    </script>
  </body>
</html>
