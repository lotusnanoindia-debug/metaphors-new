---
import ContactModal from "../components/ContactModal.astro";
import { SEO } from "astro-seo";
import "@fontsource-variable/inter";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title,
  description = "Architectural precision for high-stakes Indian developments. ROI-driven design, engineered for execution certainty.",
  image = "/og-default.png",
  canonicalURL = Astro.url.href,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          title: title,
          type: "website",
          image: image,
          url: canonicalURL,
        },
        image: {
          alt: title,
        },
      }}
      twitter={{
        creator: "@metaphor-design",
        card: "summary_large_image",
        title: title,
        description: description,
        image: image,
      }}
    />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/logo-v1.png" />
    <meta name="generator" content={Astro.generator} />
    <slot name="head" />
  </head>
  <body
    class="bg-bone text-charcoal antialiased selection:bg-black selection:text-white overflow-x-hidden"
  >
    <slot />
    <ContactModal />

    <script>
      // Global intersection observer for reveal animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.1 },
      );

      // Initialize on load and re-initialize after ViewTransitions (if ever added)
      document.addEventListener("DOMContentLoaded", () => {
        document
          .querySelectorAll(".reveal")
          .forEach((el) => observer.observe(el));
      });
    </script>
  </body>
</html>
