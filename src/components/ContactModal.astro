---
import Icon from "./Icon.astro";
import { client, SECTORS_QUERY, DISCIPLINES_QUERY } from "../lib/sanity";

const sectorsData = await client.fetch(SECTORS_QUERY);
const disciplinesData = await client.fetch(DISCIPLINES_QUERY);

const sectors = sectorsData.map((s: any) => s.title);
const disciplines = disciplinesData.map((d: any) => d.title);
---

<dialog
  id="contact-modal"
  class="backdrop:bg-charcoal/90 fixed inset-0 z-500 m-auto h-full w-full bg-transparent p-0 backdrop:backdrop-blur-2xl open:flex open:items-center open:justify-center"
>
  <div
    class="bg-bone luxury-reveal reveal sm:border-charcoal/10 relative flex h-full w-full flex-col overflow-y-auto border-none sm:h-auto sm:max-h-[90vh] sm:min-h-[750px] sm:w-[95vw] sm:max-w-[1280px] sm:overflow-hidden sm:border sm:shadow-2xl lg:flex-row"
    id="modal-content"
  >
    {/* Close Button */}
    <button
      id="close-modal"
      class="group absolute top-6 right-6 z-30 flex h-10 w-10 cursor-pointer items-center justify-center transition-all duration-500 hover:rotate-90"
      aria-label="Close modal"
    >
      <svg
        viewBox="0 0 24 24"
        class="text-charcoal/40 group-hover:text-charcoal h-5 w-5 fill-none stroke-current stroke-[1.2] transition-colors"
      >
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>

    {/* Branding & Info Section */}
    <div
      class="border-charcoal/5 flex w-full shrink-0 flex-col justify-between border-b bg-[#f2f1ec] p-8 lg:w-[35%] lg:shrink lg:border-r lg:border-b-0 lg:p-14"
    >
      <div class="space-y-12">
        <div class="flex items-center gap-3">
          <img
            alt=""
            aria-hidden="true"
            class="h-6 w-auto grayscale-30"
            src="/metaphors-design-logo.svg"
          />
          <span class="text-xl font-medium tracking-tight text-black">metaphors design</span>
        </div>

        <div class="space-y-4">
          <h2 class="text-charcoal text-3xl leading-[1.1] font-light tracking-tighter lg:text-4xl">
            Connect with us.
          </h2>
        </div>

        <p
          class="text-charcoal/50 max-w-[240px] text-[11px] leading-relaxed font-medium tracking-widest uppercase"
        >
          Four decades of architectural precision and long-term stewardship.
        </p>
      </div>

      <div class="border-charcoal/10 space-y-6 border-t pt-10">
        <div class="space-y-2">
          <p
            class="text-charcoal/30 flex items-center gap-2 text-[9px] font-bold tracking-[0.3em] uppercase"
          >
            <Icon name="ph:map-pin-light" class="text-charcoal/40 h-3 w-3" />
            Studio
          </p>
          <p class="text-charcoal text-[13px] font-light tracking-tight">Pune, India</p>
        </div>

        <div class="space-y-2">
          <p
            class="text-charcoal/30 flex items-center gap-2 text-[9px] font-bold tracking-[0.3em] uppercase"
          >
            <Icon name="ph:envelope-light" class="text-charcoal/40 h-3 w-3" />
            Liaison
          </p>
          <a
            href="mailto:info@metaphors-design.com"
            class="text-charcoal text-[13px] font-light tracking-tight hover:underline"
            >info@metaphors-design.com</a
          >
        </div>

        <div class="space-y-2">
          <p
            class="text-charcoal/30 flex items-center gap-2 text-[9px] font-bold tracking-[0.3em] uppercase"
          >
            <Icon name="ph:phone-light" class="text-charcoal/40 h-3 w-3" />
            Engage
          </p>
          <div class="flex flex-col gap-1.5">
            <a
              href="tel:+919665355522"
              class="text-charcoal text-[13px] font-light tracking-tight hover:underline"
            >
              (+91) 96653 55522
            </a>
            <a
              href="tel:+919822279173"
              class="text-charcoal text-[13px] font-light tracking-tight hover:underline"
            >
              (+91) 98222 79173
            </a>
          </div>
        </div>

        <p class="text-charcoal/20 text-[8px] font-bold tracking-[0.3em] uppercase">
          Established 1989
        </p>
      </div>
    </div>

    {/* Form Section */}
    <div class="bg-bone flex flex-1 flex-col justify-center overflow-visible p-8 lg:p-12 lg:px-20">
      <div class="mb-10" id="form-header">
        <p
          class="text-charcoal/90 text-3xl font-light tracking-tight lg:text-4xl"
          id="modal-eyebrow"
        >
          Direct Enquiry
        </p>
      </div>

      <!-- Success State -->
      <div id="contact-modal-success" class="reveal hidden flex-col items-start gap-8 py-10">
        <div class="space-y-4">
          <h3 class="text-charcoal text-3xl font-light tracking-tight lg:text-4xl">
            Acknowledged.
          </h3>
          <p class="text-charcoal/60 max-w-md text-base leading-relaxed font-light">
            Your enquiry has been received and a confirmation has been sent to the email address you
            provided. A senior member of our team will review the details and respond within two
            working days.
          </p>
        </div>
        <button
          id="contact-modal-reset"
          class="text-charcoal border-charcoal/20 cursor-pointer border-b pb-1 text-[10px] font-bold tracking-[0.3em] uppercase transition-all hover:text-black"
        >
          Send another message
        </button>
      </div>

      <form id="contact-form" class="flex flex-col gap-8" action="#" method="POST" novalidate>
        <input type="hidden" name="contactContext" id="form-context" value="Contact Modal" />
        <input type="hidden" name="originatingPage" id="contact-modal-origin" value="" />

        <!-- Spam Prevention -->
        <div class="hidden" aria-hidden="true">
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:gap-10">
          <div class="flex flex-col gap-2" data-field>
            <label
              for="full-name"
              class="text-charcoal/60 flex items-center justify-between text-[12px] font-bold tracking-[0.25em] uppercase"
            >
              Name
              <span class="text-charcoal/30">*</span>
            </label>
            <input
              type="text"
              id="full-name"
              name="full-name"
              required
              class="border-charcoal/20 text-charcoal focus:border-charcoal w-full border-b bg-transparent py-4 text-xl font-light transition-all outline-none"
            />
            <p
              class="error-msg text-ink mt-1 hidden text-[10px] font-medium tracking-widest uppercase"
            >
              Please enter your full name
            </p>
          </div>

          <div class="flex flex-col gap-2" data-field>
            <label
              for="email"
              class="text-charcoal/60 flex items-center justify-between text-[12px] font-bold tracking-[0.25em] uppercase"
            >
              Email
              <span class="text-charcoal/30">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              pattern="[^@\\s]+@[^@\\s]+\\.[^@\\s]+"
              class="border-charcoal/20 text-charcoal focus:border-charcoal w-full border-b bg-transparent py-4 text-xl font-light transition-all outline-none"
            />
            <p
              class="error-msg text-ink mt-1 hidden text-[10px] font-medium tracking-widest uppercase"
            >
              Please enter a valid email address
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:gap-10">
          {/* Custom Sector Dropdown */}
          <div class="relative z-30 flex flex-col gap-2">
            <label class="text-charcoal/50 text-[12px] font-bold tracking-[0.25em] uppercase">
              Sector of Interest
            </label>
            <div class="custom-dropdown relative" id="sector-dropdown">
              <button
                type="button"
                class="dropdown-trigger border-charcoal/20 text-charcoal hover:border-charcoal flex w-full cursor-pointer items-center justify-between border-b bg-transparent py-4 text-xl font-light transition-colors"
              >
                <span class="selected-value text-charcoal/40"></span>
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5 fill-none stroke-current stroke-1 transition-transform duration-300"
                >
                  <path d="M6 9l6 6 6-6"></path>
                </svg>
              </button>
              <div
                class="dropdown-menu border-charcoal/10 invisible absolute top-full left-0 z-50 w-full translate-y-2 overflow-hidden border border-t-0 bg-white opacity-0 shadow-xl transition-all duration-300"
              >
                <div class="custom-scrollbar max-h-60 overflow-y-auto">
                  <div
                    class="text-charcoal/20 border-charcoal/5 border-b px-5 py-3 text-[10px] font-bold tracking-widest uppercase"
                  >
                    Which Sector are you enquiring about?
                  </div>
                  {
                    sectors.map((s: string) => (
                      <button
                        type="button"
                        class="option text-charcoal/60 hover:text-charcoal hover:bg-charcoal/5 w-full px-5 py-3.5 text-left text-sm font-light transition-colors"
                        data-value={s}
                      >
                        {s}
                      </button>
                    ))
                  }
                  <button
                    type="button"
                    class="option text-charcoal/60 hover:text-charcoal hover:bg-charcoal/5 border-charcoal/5 w-full border-t px-5 py-3.5 text-left text-sm font-light transition-colors"
                    data-value="Other"
                  >
                    Other
                  </button>
                </div>
              </div>
              <input type="hidden" name="sector" value="" />
            </div>
          </div>

          {/* Custom Discipline Dropdown */}
          <div class="relative z-20 flex flex-col gap-2">
            <label class="text-charcoal/50 text-[12px] font-bold tracking-[0.25em] uppercase">
              Discipline of Interest
            </label>
            <div class="custom-dropdown relative" id="discipline-dropdown">
              <button
                type="button"
                class="dropdown-trigger border-charcoal/20 text-charcoal hover:border-charcoal flex w-full cursor-pointer items-center justify-between border-b bg-transparent py-4 text-xl font-light transition-colors"
              >
                <span class="selected-value text-charcoal/40"></span>
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5 fill-none stroke-current stroke-1 transition-transform duration-300"
                >
                  <path d="M6 9l6 6 6-6"></path>
                </svg>
              </button>
              <div
                class="dropdown-menu border-charcoal/10 invisible absolute top-full left-0 z-50 w-full translate-y-2 overflow-hidden border border-t-0 bg-white opacity-0 shadow-xl transition-all duration-300"
              >
                <div class="custom-scrollbar max-h-60 overflow-y-auto">
                  <div
                    class="text-charcoal/20 border-charcoal/5 border-b px-5 py-3 text-[10px] font-bold tracking-widest uppercase"
                  >
                    Which Discipline are you enquiring about?
                  </div>
                  {
                    disciplines.map((d: string) => (
                      <button
                        type="button"
                        class="option text-charcoal/60 hover:text-charcoal hover:bg-charcoal/2 w-full px-5 py-3.5 text-left text-sm font-light transition-colors"
                        data-value={d}
                      >
                        {d}
                      </button>
                    ))
                  }
                </div>
              </div>
              <input type="hidden" name="discipline" value="" />
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:gap-10">
          <div class="flex flex-col gap-2" data-field>
            <label
              for="phone"
              class="text-charcoal/50 flex items-center justify-between text-[12px] font-bold tracking-[0.25em] uppercase"
            >
              Contact Number
              <span class="text-charcoal/30">*</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              class="border-charcoal/20 text-charcoal focus:border-charcoal w-full border-b bg-transparent py-4 text-xl font-light transition-all outline-none"
            />
            <p
              class="error-msg text-ink mt-1 hidden text-[10px] font-medium tracking-widest uppercase"
            >
              Please enter your contact number
            </p>
          </div>
          <div class="flex flex-col gap-2" data-field>
            <label
              for="organisation"
              class="text-charcoal/60 flex items-center justify-between text-[12px] font-bold tracking-[0.25em] uppercase"
            >
              Organisation
              <span class="text-charcoal/30">*</span>
            </label>
            <input
              type="text"
              id="organisation"
              name="organisation"
              required
              class="border-charcoal/20 text-charcoal focus:border-charcoal w-full border-b bg-transparent py-4 text-xl font-light transition-all outline-none"
            />
            <p
              class="error-msg text-ink mt-1 hidden text-[10px] font-medium tracking-widest uppercase"
            >
              Please enter your organisation
            </p>
          </div>
        </div>

        <div class="flex flex-col gap-3" data-field>
          <label
            for="message"
            class="text-charcoal/60 flex items-center justify-between text-[12px] font-bold tracking-[0.25em] uppercase"
          >
            Your Enquiry
            <span class="text-charcoal/30">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            rows="2"
            required
            placeholder="Describe your project intent..."
            class="border-charcoal/20 text-charcoal focus:border-charcoal placeholder:text-charcoal/20 w-full resize-none border-b bg-transparent py-4 text-xl font-light transition-all outline-none"
          ></textarea>
          <p
            class="error-msg text-ink mt-1 hidden text-[10px] font-medium tracking-widest uppercase"
          >
            Please provide a brief message
          </p>
        </div>

        <div class="flex flex-col items-center justify-between gap-10 pt-4 sm:flex-row">
          <p class="text-charcoal/30 max-w-xs text-[9px] font-medium tracking-[0.2em] uppercase">
            A partner will review your enquiry and respond within two working days. All enquiries
            are treated confidentially.
          </p>
          <div id="contact-modal-submit-wrapper" class="relative w-full sm:w-[240px]">
            <button
              type="submit"
              id="contact-modal-submit"
              class="group bg-charcoal text-bone relative inline-flex h-14 w-full shrink-0 cursor-pointer items-center justify-center text-[10px] font-bold tracking-[0.4em] uppercase transition-all duration-500 hover:bg-black"
            >
              Send Enquiry
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</dialog>

<script>
  const modal = document.getElementById("contact-modal") as HTMLDialogElement;
  const closeBtn = document.getElementById("close-modal");
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const content = document.getElementById("modal-content");
  const modalEyebrow = document.getElementById("modal-eyebrow");
  const formHiddenContext = document.getElementById("form-context") as HTMLInputElement;
  const formHiddenOrigin = document.getElementById("contact-modal-origin") as HTMLInputElement;

  function openModal(context = "General", preselectedSector: string | null = null) {
    if (!modal) return;

    // Handle broad section contexts or specific slugs
    let label = context;
    if (context === "Disciplines") label = "Studio Disciplines";
    if (context === "Sectors" || context === "Specialised Sectors") label = "Specialised Sectors";
    if (context === "General" || !context) label = "Direct Enquiry";

    if (modalEyebrow) {
      modalEyebrow.textContent = label.includes("Enquiry") ? label : `${label}`;
    }

    if (formHiddenContext) formHiddenContext.value = context;
    if (formHiddenOrigin) formHiddenOrigin.value = window.location.pathname;

    // Handle Preselection
    if (preselectedSector) {
      const sectorDropdown = document.getElementById("sector-dropdown");
      const hiddenInput = sectorDropdown?.querySelector('input[type="hidden"]');
      const selectedText = sectorDropdown?.querySelector(".selected-value");

      if (hiddenInput instanceof HTMLInputElement && selectedText instanceof HTMLElement) {
        hiddenInput.value = preselectedSector;
        selectedText.textContent = preselectedSector;
        selectedText.classList.remove("text-charcoal/40");
        selectedText.classList.add("text-charcoal");
      }
    }

    modal.showModal();
    setTimeout(() => content?.classList.add("visible"), 10);
  }

  function closeModal() {
    content?.classList.remove("visible");
    setTimeout(() => modal?.close(), 500);
  }

  modal?.addEventListener("click", (e) => {
    const rect = modal.getBoundingClientRect();
    if (
      e.clientX < rect.left ||
      e.clientX > rect.right ||
      e.clientY < rect.top ||
      e.clientY > rect.bottom
    )
      closeModal();
  });

  closeBtn?.addEventListener("click", closeModal);
  (window as any).openContactModal = openModal;

  const formHeader = document.getElementById("form-header");
  const successState = document.getElementById("contact-modal-success");
  const resetBtn = document.getElementById("contact-modal-reset");
  const submitBtn = document.getElementById("contact-modal-submit") as HTMLButtonElement | null;
  const requiredFields = Array.from(
    form?.querySelectorAll("input[required], textarea[required]") ?? [],
  ).filter(
    (field): field is HTMLInputElement | HTMLTextAreaElement =>
      field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement,
  );

  const getFieldWrap = (field: HTMLInputElement | HTMLTextAreaElement) =>
    field.closest("[data-field]");

  const getErrorMessage = (field: HTMLInputElement | HTMLTextAreaElement) =>
    getFieldWrap(field)?.querySelector(".error-msg");

  const getFieldMessage = (field: HTMLInputElement | HTMLTextAreaElement) => {
    const authoredMessage =
      getErrorMessage(field)?.textContent?.trim() || "Please complete this field";

    if (field.validity.valueMissing) return authoredMessage;

    if (field.type === "email") {
      if (
        field.validity.typeMismatch ||
        field.validity.patternMismatch ||
        field.validity.customError
      ) {
        return "Please enter a valid email address";
      }
    }

    return "";
  };

  const showFieldState = (
    field: HTMLInputElement | HTMLTextAreaElement,
    shouldShowError: boolean,
  ) => {
    const errorMessage = getErrorMessage(field);
    const message = getFieldMessage(field);

    field.setAttribute("aria-invalid", shouldShowError ? "true" : "false");
    field.classList.toggle("border-charcoal/40", shouldShowError);
    field.classList.toggle("border-charcoal/10", !shouldShowError);

    if (errorMessage instanceof HTMLElement) {
      errorMessage.textContent = message;
      errorMessage.classList.toggle("hidden", !shouldShowError);
    }
  };

  const validateField = (field: HTMLInputElement | HTMLTextAreaElement) => {
    field.value = field.value.trim();

    // Manual bulletproof email check
    if (field.type === "email" && field.value) {
      const emailRegex = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;
      if (!emailRegex.test(field.value)) {
        field.setCustomValidity("Invalid pattern");
      } else {
        field.setCustomValidity("");
      }
    } else {
      field.setCustomValidity("");
    }

    const isValid = field.checkValidity();
    showFieldState(field, !isValid);
    return isValid;
  };

  const resetFieldState = (field: HTMLInputElement | HTMLTextAreaElement) => {
    field.removeAttribute("aria-invalid");
    field.classList.remove("border-charcoal/40");
    field.classList.add("border-charcoal/10");

    const errorMessage = getErrorMessage(field);
    if (errorMessage instanceof HTMLElement) {
      errorMessage.classList.add("hidden");
    }
  };

  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest("[data-contact-modal]");
    if (btn) {
      e.preventDefault();
      openModal(
        btn.getAttribute("data-contact-context") || "Direct Enquiry",
        btn.getAttribute("data-contact-sector"),
      );
    }
  });

  // Custom Dropdown Logic
  const dropdowns = document.querySelectorAll(".custom-dropdown");

  dropdowns.forEach((dropdown) => {
    const trigger = dropdown.querySelector(".dropdown-trigger");
    const menu = dropdown.querySelector(".dropdown-menu");
    const options = dropdown.querySelectorAll(".option");
    const selectedText = dropdown.querySelector(".selected-value");
    const hiddenInput = dropdown.querySelector('input[type="hidden"]') as HTMLInputElement;
    const arrow = trigger?.querySelector("svg");

    trigger?.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = dropdown.classList.contains("active");

      // Close all other dropdowns
      dropdowns.forEach((d) => {
        d.classList.remove("active");
        d.querySelector("svg")?.classList.remove("rotate-180");
      });

      if (!isOpen) {
        dropdown.classList.add("active");
        arrow?.classList.add("rotate-180");
      }
    });

    options.forEach((option) => {
      option.addEventListener("click", (e) => {
        e.stopPropagation();
        const value = (option as HTMLElement).dataset.value || "";
        const text = option.textContent || "";

        // Use empty string for general selection
        if (selectedText) {
          selectedText.textContent = text.includes("General") ? "" : text;
        }
        if (hiddenInput) hiddenInput.value = value;

        dropdown.classList.remove("active");
        arrow?.classList.remove("rotate-180");
      });
    });
  });

  requiredFields.forEach((field) => {
    resetFieldState(field);

    field.addEventListener("blur", () => {
      validateField(field);
    });

    field.addEventListener("input", () => {
      if (field.getAttribute("aria-invalid") === "true") {
        validateField(field);
      }
    });
  });

  const resetModalForm = () => {
    form?.reset();
    requiredFields.forEach((field) => resetFieldState(field));

    dropdowns.forEach((dropdown) => {
      dropdown.classList.remove("active");
      dropdown.querySelector("svg")?.classList.remove("rotate-180");

      const selectedText = dropdown.querySelector(".selected-value");
      const hiddenInput = dropdown.querySelector('input[type="hidden"]');

      if (selectedText instanceof HTMLElement) {
        selectedText.textContent = "";
      }

      if (hiddenInput instanceof HTMLInputElement) {
        hiddenInput.value = "";
      }
    });
  };

  const submitForm = async () => {
    if (!form) return;

    let firstInvalidField: HTMLInputElement | HTMLTextAreaElement | null = null;
    const isFormValid = requiredFields.every((field) => {
      const isValid = validateField(field);
      if (!isValid && !firstInvalidField) firstInvalidField = field;
      return isValid;
    });

    if (!isFormValid) {
      firstInvalidField?.focus();
      firstInvalidField?.scrollIntoView({
        behavior: "smooth",
        block: "center",
      });
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending...";
    }

    try {
      const response = await fetch("/api/contact", {
        method: "POST",
        body: new FormData(form),
      });

      const result = await response.json();

      if (!result.success) throw new Error("Failed to send");

      form.classList.add("hidden");
      formHeader?.classList.add("hidden");
      successState?.classList.remove("hidden");
      successState?.classList.add("flex");

      resetModalForm();

      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send Enquiry";
      }
    } catch (err) {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "Connection Error";
        setTimeout(() => {
          if (submitBtn) submitBtn.textContent = "Send Enquiry";
        }, 2000);
      }
    }
  };

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    void submitForm();
  });

  resetBtn?.addEventListener("click", () => {
    form?.classList.remove("hidden");
    formHeader?.classList.remove("hidden");
    successState?.classList.add("hidden");
    successState?.classList.remove("flex");
    resetModalForm();
  });

  document.addEventListener("click", () => {
    dropdowns.forEach((d) => {
      d.classList.remove("active");
      d.querySelector("svg")?.classList.remove("rotate-180");
    });
  });
</script>

<style>
  #contact-modal {
    z-index: 9999;
  }
  #contact-modal::backdrop {
    background: rgba(17, 17, 17, 0.85);
    backdrop-filter: blur(20px);
    animation: fade-in 0.8s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }
  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  dialog:not([open]) {
    display: none;
  }
  html:has(dialog[open]) {
    overflow: hidden;
  }

  /* Submit Button States */
  button[type="submit"]:disabled {
    background-color: #c5c5c5;
    color: #737373;
    cursor: not-allowed;
    opacity: 1;
  }

  /* Custom Dropdown Styles */
  .custom-dropdown.active .dropdown-menu {
