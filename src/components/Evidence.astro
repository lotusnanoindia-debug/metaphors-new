---
const projects = [
  {
    title: "Phoenix Citadel.",
    location: "Indore / Lucknow / Pune",
    category: "Commercial & Retail",
    intent: "Engineering high-velocity retail destinations that redefine regional commerce through massive scale and operational fluidity.",
    image: "/phoenix-atrium.png",
    stats: [
      { label: "Yield", value: "94% Floor Efficiency" },
      { label: "Scale", value: "1.2M Sq. Ft. Operational" }
    ]
  },
  {
    title: "The Corinthians.",
    location: "Pune, India",
    category: "Hospitality & Leisure",
    intent: "Architecting a lifestyle estate that balances premium guest experience with long-term durability and emotional resonance.",
    image: "https://images.unsplash.com/photo-1582719508461-905c673771fd?auto=format&fit=crop&q=80&w=2000",
    stats: [
      { label: "Materials", value: "100% Hand-cut Stone" },
      { label: "Estate", value: "100+ Acre Deployment" }
    ]
  },
  {
    title: "Wipro Global Headquarters.",
    location: "Pune, India",
    category: "Institutional & Corporate",
    intent: "Design for institutional stature and structural resilience, housing the operations of a global technological leader.",
    image: "/wipro-hq.png",
    stats: [
      { label: "Carbon", value: "Net-Zero Infrastructure" },
      { label: "Stability", value: "Seismic Zone 4 Tolerance" }
    ]
  }
];
---

<section class="bg-bone py-24 lg:py-32">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div class="flex flex-col lg:flex-row justify-between items-end mb-24 gap-8">
      <div class="max-w-xl">
        <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-charcoal/40 mb-8">Selected Evidence</p>
        <h2 class="text-5xl lg:text-7xl mb-8 leading-[0.9]">Flagship Landmark Deployments.</h2>
      </div>
      <a href="#" class="text-[10px] font-bold uppercase tracking-[0.2em] border-b border-charcoal pb-1 transition-all hover:border-charcoal/20">
        Filter All Projects
      </a>
    </div>

    <div class="space-y-48 lg:space-y-64">
      {projects.map((project, index) => (
        <div class={`flex flex-col ${index % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-12 lg:gap-24 items-start`}>
          <div class="w-full lg:w-3/5 overflow-hidden group relative">
            <img 
              src={project.image} 
              alt={project.title} 
              class="w-full aspect-[16/10] object-cover grayscale transition-all duration-1000 group-hover:grayscale-0 group-hover:scale-105" 
            />
            <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-all duration-1000 pointer-events-none"></div>
          </div>
          <div class="w-full lg:w-2/5 pt-4">
            <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-charcoal/40 block mb-6">{project.category}</span>
            <h3 class="text-4xl lg:text-5xl mb-8 leading-tight font-serif italic">{project.title}</h3>
            <p class="text-xl text-charcoal font-light leading-relaxed mb-10">
              {project.intent}
            </p>
            
            <div class="grid grid-cols-2 gap-8 mb-12 border-t border-charcoal/5 pt-8">
              {project.stats.map(stat => (
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 mb-1">{stat.label}</p>
                  <p class="text-sm font-medium">{stat.value}</p>
                </div>
              ))}
              <div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 mb-1">Status</p>
                <p class="text-sm font-medium">Flagship Operational</p>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-charcoal/40 mb-1">Location</p>
                <p class="text-sm font-medium">{project.location}</p>
              </div>
            </div>

            <a
              href="#"
              class="inline-block text-[10px] font-bold uppercase tracking-[0.3em] text-charcoal border border-charcoal/20 px-8 py-4 luxury-transition hover:bg-charcoal hover:text-bone"
            >
              Examine Full Strategy
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
