---
import { imageUrl } from "../lib/sanity";

const {
  eyebrow = "Project Archive",
  headline = "Selected Landmark Deployments.",
  projects = [],
} = Astro.props;
---

<section class="w-full bg-bone py-24 lg:py-32">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div
      class="flex flex-col lg:flex-row justify-between items-end mb-20 gap-8"
    >
      <div class="reveal">
        <p
          class="text-[10px] font-medium uppercase tracking-[0.4em] text-charcoal/40 mb-6"
        >
          {eyebrow}
        </p>
        <h2 class="text-5xl lg:text-7xl leading-[0.95] tracking-tighter">
          {headline}
        </h2>
      </div>
      <div class="reveal">
        <a
          href="/archive"
          class="group flex items-center gap-4 text-[11px] font-medium uppercase tracking-[0.3em] text-charcoal/60 hover:text-charcoal transition-colors duration-500"
        >
          View Full Archive
          <span
            class="transition-transform duration-500 group-hover:translate-x-3"
            >→</span
          >
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        projects.map((project: any) => (
          <div class="group reveal flex flex-col h-full bg-charcoal/2 p-6 lg:p-8 hover:bg-charcoal/4 transition-all duration-700">
            <div class="relative aspect-4/5 overflow-hidden mb-10 luxury-grayscale">
              <img
                src={imageUrl(project.image, { width: 800 })}
                alt={project.title}
                class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110"
              />
              <div class="absolute top-6 left-6">
                <span class="px-3 py-1.5 bg-bone/90 backdrop-blur-md text-[9px] font-medium uppercase tracking-[0.2em] text-charcoal">
                  {project.sectorLabel}
                </span>
              </div>
            </div>

            <div class="flex flex-col grow">
              <div class="flex justify-between items-start mb-6">
                <div>
                  <h3 class="text-2xl lg:text-3xl font-medium tracking-tight mb-2">
                    {project.title}
                  </h3>
                  <p class="text-[10px] uppercase tracking-widest text-charcoal/40">
                    {project.location}
                  </p>
                </div>
                <div class="flex flex-col items-end">
                  {project.stats?.map((stat: any) => (
                    <div class="text-right mb-1">
                      <p class="text-[9px] font-medium text-charcoal/30 uppercase tracking-tighter">
                        {stat.label}
                      </p>
                      <p class="text-[11px] font-medium text-charcoal/70">
                        {stat.value}
                      </p>
                    </div>
                  ))}
                </div>
              </div>

              <p class="text-sm lg:text-base text-charcoal/60 leading-relaxed mb-10 line-clamp-3">
                {project.intent}
              </p>

              <div class="mt-auto pt-6 border-t border-charcoal/5">
                <a
                  href={project.linkUrl}
                  class="group/link inline-flex items-center gap-3 text-[10px] font-medium uppercase tracking-[0.3em] text-charcoal"
                >
                  Project Details
                  <span class="transition-transform duration-300 group-hover/link:translate-x-2">
                    →
                  </span>
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
