---
import { client, PROJECTS_QUERY, imageUrl } from "../lib/sanity";

const projects = await client.fetch(PROJECTS_QUERY);
---

<section class="bg-bone py-24 lg:py-32">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div
      class="flex flex-col lg:flex-row justify-between items-end mb-24 gap-8"
    >
      <div class="max-w-xl">
        <p
          class="text-[10px] font-medium uppercase tracking-[0.3em] text-charcoal/40 mb-8"
        >
          Project Archive
        </p>
        <h2 class="text-5xl lg:text-7xl mb-8 leading-[0.9]">
          Selected Landmark Deployments.
        </h2>
      </div>
      <a
        href="/archive"
        class="text-[10px] font-medium uppercase tracking-[0.2em] border-b border-charcoal pb-1 transition-all hover:border-charcoal/20"
      >
        View Full Archive
      </a>
    </div>

    <div class="space-y-48 lg:space-y-64">
      {
        projects.map((project: any, index: number) => (
          <div
            class={`flex flex-col ${index % 2 === 0 ? "lg:flex-row" : "lg:flex-row-reverse"} gap-12 lg:gap-24 items-start`}
          >
            <div class="w-full lg:w-3/5 overflow-hidden group relative">
              {project.mainImage && (
                <img
                  src={imageUrl(project.mainImage, { width: 800 })}
                  alt={project.title}
                  loading="lazy"
                  decoding="async"
                  class="w-full aspect-16/10 object-cover grayscale transition-all duration-1000 group-hover:grayscale-0 group-hover:scale-105"
                />
              )}
              <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-all duration-1000 pointer-events-none" />
            </div>
            <div class="w-full lg:w-2/5">
              <span class="text-[10px] font-medium uppercase tracking-[0.3em] text-charcoal/40 block mb-6">
                {project.sector}
              </span>
              <h3 class="text-4xl lg:text-5xl mb-8 leading-tight font-serif italic">
                {project.title}
              </h3>
              <p class="text-xl text-charcoal font-light leading-relaxed mb-10">
                {project.intent}
              </p>

              <div class="grid grid-cols-2 gap-8 mb-8 border-t border-charcoal/5 pt-4">
                {project.stats &&
                  project.stats.map((stat: any) => (
                    <div>
                      <p class="text-[10px] font-medium uppercase tracking-widest text-charcoal/40 mb-1">
                        {stat.label}
                      </p>
                      <p class="text-sm font-medium">{stat.value}</p>
                    </div>
                  ))}
                <div>
                  <p class="text-[10px] font-medium uppercase tracking-widest text-charcoal/40 mb-1">
                    Location
                  </p>
                  <p class="text-sm font-medium">{project.location}</p>
                </div>
              </div>

              <a
                href={`/archive/${project.slug}`}
                class="inline-block text-[10px] font-medium uppercase tracking-[0.3em] text-charcoal border border-charcoal/20 px-8 py-4 luxury-transition hover:bg-charcoal hover:text-bone"
              >
                Project Details
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
