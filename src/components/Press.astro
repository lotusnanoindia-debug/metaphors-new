---
import { imageUrl } from "../lib/sanity";

interface Props {
  quotes: any[];
  layout?: "grid" | "sidebar" | "stack" | "ledger" | "minimal";
}

const { quotes = [], layout = "minimal" } = Astro.props;

if (!quotes || quotes.length === 0) return null;

// Layout-specific container
const containerClass =
  layout === "minimal" || layout === "grid"
    ? "grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-24"
    : "flex flex-col gap-12 lg:gap-24";
---

<div class={containerClass}>
  {
    quotes.map((item: any, index: number) => {
      // --- MINIMAL / FOOTNOTE LAYOUT (THE SUBTLE RECORD) ---
      if (layout === "minimal" || layout === "grid") {
        return (
          <div
            class="flex flex-col gap-6 group reveal items-center text-center"
            style={`transition-delay: ${index * 150}ms`}
          >
            {/* Logo/Source — Barely visible anchor */}
            <div class="h-5 flex items-center justify-center opacity-20 grayscale group-hover:opacity-60 transition-all duration-700">
              {item.logo ? (
                <img
                  src={imageUrl(item.logo, { height: 16 })}
                  alt={item.publication}
                  class="h-full w-auto object-contain"
                />
              ) : (
                <span class="text-[8px] font-bold uppercase tracking-[0.4em] text-charcoal/40">
                  {item.publication}
                </span>
              )}
            </div>

            {/* The Quote — Technical Caps */}
            <p class="text-[12px] sm:text-[11px] font-semibold uppercase tracking-[0.25em] leading-relaxed text-charcoal/40 group-hover:text-charcoal/70 transition-colors duration-500 font-serif italic">
              “{item.quote}”
            </p>
          </div>
        );
      }

      // --- LEGGER / STACK / SIDEBAR (LEGACY SUPPORT) ---
      return (
        <div
          class="flex flex-col gap-8 group reveal"
          style={`transition-delay: ${index * 150}ms`}
        >
          <div class="h-5 flex items-center opacity-30 grayscale group-hover:opacity-100 transition-all">
            {item.logo ? (
              <img
                src={imageUrl(item.logo, { height: 20 })}
                alt={item.publication}
                class="h-full w-auto object-contain"
              />
            ) : (
              <span class="text-[9px] font-bold uppercase tracking-[0.3em] text-charcoal/40">
                {item.publication}
              </span>
            )}
          </div>
          <p class="text-xl lg:text-3xl font-light italic tracking-tight leading-relaxed text-charcoal/60 group-hover:text-charcoal transition-all">
            “{item.quote}”
          </p>
        </div>
      );
    })
  }
</div>
