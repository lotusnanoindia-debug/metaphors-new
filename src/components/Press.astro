---
import { imageUrl } from "../lib/sanity";

interface Props {
  quotes: any[];
  layout?: "grid" | "sidebar" | "stack" | "ledger" | "minimal";
}

const { quotes = [], layout = "minimal" } = Astro.props;

if (!quotes || quotes.length === 0) return null;

// Layout-specific container
const containerClass =
  layout === "minimal" || layout === "grid"
    ? "grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-24"
    : "flex flex-col gap-12 lg:gap-24";
---

<div class={containerClass}>
  {
    quotes.map((item: any, index: number) => {
      // --- MINIMAL / FOOTNOTE LAYOUT (THE SUBTLE RECORD) ---
      if (layout === "minimal" || layout === "grid") {
        return (
          <div
            class="group reveal flex flex-col items-center gap-6 text-center"
            style={`transition-delay: ${index * 150}ms`}
          >
            {/* Logo/Source — Barely visible anchor */}
            <div class="flex h-5 items-center justify-center opacity-20 grayscale transition-all duration-700 group-hover:opacity-60">
              {item.logo ? (
                <img
                  src={imageUrl(item.logo, { height: 16 })}
                  alt={item.publication}
                  class="h-full w-auto object-contain"
                />
              ) : (
                <span class="text-charcoal/40 text-[8px] font-bold tracking-[0.4em] uppercase">
                  {item.publication}
                </span>
              )}
            </div>

            {/* The Quote — Technical Caps */}
            <p class="text-charcoal/40 group-hover:text-charcoal/70 font-serif text-[12px] leading-relaxed font-semibold tracking-[0.25em] uppercase italic transition-colors duration-500 sm:text-[11px]">
              “{item.quote}”
            </p>
          </div>
        );
      }

      // --- LEGGER / STACK / SIDEBAR (LEGACY SUPPORT) ---
      return (
        <div class="group reveal flex flex-col gap-8" style={`transition-delay: ${index * 150}ms`}>
          <div class="flex h-5 items-center opacity-30 grayscale transition-all group-hover:opacity-100">
            {item.logo ? (
              <img
                src={imageUrl(item.logo, { height: 20 })}
                alt={item.publication}
                class="h-full w-auto object-contain"
              />
            ) : (
              <span class="text-charcoal/40 text-[9px] font-bold tracking-[0.3em] uppercase">
                {item.publication}
              </span>
            )}
          </div>
          <p class="text-charcoal/60 group-hover:text-charcoal text-xl leading-relaxed font-light tracking-tight italic transition-all lg:text-3xl">
            “{item.quote}”
          </p>
        </div>
      );
    })
  }
</div>
