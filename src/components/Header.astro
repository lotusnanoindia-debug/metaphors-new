---
import Icon from "./Icon.astro";
import Cta from "./Cta.astro";
import { client, SECTORS_QUERY, DISCIPLINES_QUERY, imageUrl } from "../lib/sanity";

const sectorsData = await client.fetch(SECTORS_QUERY);
const disciplinesData = await client.fetch(DISCIPLINES_QUERY);

const sectors = sectorsData.map((sector: any) => ({
  title: sector.title,
  tagline: sector.homeHeadline || "Expert Architectural Solutions",
  path: `/sectors/${sector.slug}`,
  image: sector.image,
}));

const disciplines = disciplinesData.map((d: any) => ({
  title: d.title,
  path: `/disciplines/${d.slug}`,
  image: d.mainImage,
  tagline: d.valueProposition,
}));

const menuItems = [
  { name: "Engagement", path: "/engagement" },
  { name: "About", path: "/about" },
];
---

<!-- HEADER BAR -->
<header
  id="site-header"
  class="border-charcoal/5 fixed top-0 left-0 z-400 w-full border-b bg-white/80 backdrop-blur-md transition-all duration-700"
  aria-label="Site Header"
>
  <div class="relative mx-auto max-w-[1440px] px-6 lg:px-12">
    <div class="flex h-20 items-center justify-between">
      <!-- Logo -->
      <a
        href="/"
        class="group/logo relative z-10 flex items-center gap-3"
        aria-label="Metaphors Design — Home"
      >
        <img
          alt=""
          aria-hidden="true"
          class="h-6 w-auto grayscale-30 transition-transform duration-700 group-hover/logo:scale-110 group-hover/logo:grayscale-0"
          src="/metaphors-design-logo.svg"
        />
        <span class="text-xl font-medium tracking-tight text-black">metaphors design</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden h-full items-center gap-12 lg:flex" aria-label="Primary">
        <!-- Sectors Trigger -->
        <div class="menu-trigger-container projects flex h-full items-center" id="sectors-trigger">
          <button
            class="text-charcoal/60 relative flex h-full cursor-pointer items-center gap-2 text-[10px] font-medium tracking-[0.3em] uppercase transition-colors duration-300 hover:text-black"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Portfolio
            <Icon name="ph:caret-down" class="h-2.5 w-2.5" />
            <span
              class="nav-underline absolute bottom-[28px] left-0 h-[1.5px] w-full origin-left scale-x-0 bg-black transition-transform duration-400"
            ></span>
          </button>
        </div>

        <!-- Disciplines Trigger -->
        <div
          class="menu-trigger-container disciplines flex h-full items-center"
          id="disciplines-trigger"
        >
          <button
            class="text-charcoal/60 relative flex h-full cursor-pointer items-center gap-2 text-[10px] font-medium tracking-[0.3em] uppercase transition-colors duration-300 hover:text-black"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Disciplines
            <Icon name="ph:caret-down" class="h-2.5 w-2.5" />
            <span
              class="nav-underline absolute bottom-[28px] left-0 h-[1.5px] w-full origin-left scale-x-0 bg-black transition-transform duration-400"
            ></span>
          </button>
        </div>

        {
          menuItems.map((item) => (
            <a
              href={item.path}
              class="text-charcoal/60 group/nav relative flex h-full items-center py-2 text-[10px] font-medium tracking-[0.3em] uppercase transition-colors hover:text-black"
            >
              {item.name}
              <span class="absolute bottom-[28px] left-0 h-[1.5px] w-full origin-left scale-x-0 bg-black transition-transform duration-400 group-hover/nav:scale-x-100" />
            </a>
          ))
        }
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:block">
        <Cta text="Contact Us" href="/contact" />
      </div>

      <!-- Custom Drafting Burger Trigger -->
      <button
        id="burger-btn"
        class="group/burger relative z-300 flex h-10 w-10 flex-col items-end justify-center gap-1.5 lg:hidden"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span
          class="bg-charcoal h-px w-6 transition-all duration-500 group-[.is-active]/burger:translate-y-[3.5px] group-[.is-active]/burger:rotate-45"
        ></span>
        <span
          class="bg-charcoal h-px w-4 transition-all duration-500 group-[.is-active]/burger:w-6 group-[.is-active]/burger:-translate-y-[3.5px] group-[.is-active]/burger:-rotate-45"
        ></span>
      </button>
    </div>
  </div>
</header>

<!-- ============================================================
     SECTORS MEGA MENU
============================================================ -->
<div
  id="mega-menu-sectors"
  class="pointer-events-none fixed top-0 left-0 z-190 h-screen w-full"
  aria-hidden="true"
>
  <!-- Backdrop -->
  <div class="mm-backdrop absolute inset-0 bg-black/0 transition-colors duration-500"></div>

  <!-- Panel -->
  <div
    class="mm-panel absolute top-[80px] left-0 w-full -translate-y-3 bg-white opacity-0 shadow-[0_30px_80px_rgba(0,0,0,0.18)] transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
  >
    <div
      class="relative mx-auto grid max-w-[1440px] grid-cols-[1fr_1.4fr] gap-16 px-6 py-10 lg:px-12 lg:py-16"
    >
      <!-- Close Button -->
      <button
        class="text-charcoal/20 mm-close-btn group/close absolute top-10 right-12 z-50 flex cursor-pointer items-center gap-3 text-[9px] font-medium tracking-[0.4em] uppercase transition-all duration-300 hover:text-black"
        aria-label="Close menu"
      >
        <span>Close</span>
        <Icon
          name="ph:x"
          class="h-3.5 w-3.5 transition-transform duration-500 group-hover/close:rotate-90"
        />
      </button>

      <!-- Left: Numbered List -->
      <div class="flex flex-col justify-between">
        <p class="text-charcoal/30 mb-10 text-[9px] font-medium tracking-[0.6em] uppercase">
          Work by Industry
        </p>
        <nav class="group/list flex flex-1 flex-col justify-center gap-0" aria-label="Sectors">
          {
            sectors.map((sector: any, i: number) => (
              <a
                href={sector.path}
                class="sector-item border-charcoal/5 text-charcoal/40 group/item flex items-center gap-6 border-b py-4 transition-all duration-500 group-hover/list:opacity-50 last:border-0 hover:opacity-100! [&.is-active]:text-black [&.is-active]:opacity-100!"
                data-image={imageUrl(sector.image)}
                data-tagline={sector.tagline}
                data-title={sector.title}
              >
                <span class="w-8 shrink-0 text-[14px] tracking-widest tabular-nums opacity-20 transition-all duration-500 group-hover/item:opacity-100 group-[.is-active]/item:opacity-100">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span class="text-[22px] leading-tight font-medium tracking-tight transition-transform duration-500 group-hover/item:translate-x-3 group-[.is-active]/item:translate-x-3 lg:text-[26px]">
                  {sector.title}
                </span>
                <div class="ml-auto flex items-center">
                  <Icon
                    name="ph:arrow-right"
                    class="h-5 w-5 shrink-0 -translate-x-2 opacity-0 transition-all duration-400 group-hover/item:translate-x-0 group-hover/item:opacity-100 group-[.is-active]/item:translate-x-0 group-[.is-active]/item:opacity-100"
                  />
                </div>
              </a>
            ))
          }
        </nav>
      </div>

      <!-- Right: Large Image (intent-driven, empty by default) -->
      <div class="mm-image-pane group/pane relative overflow-hidden bg-stone-100 p-4 lg:p-6">
        <a
          id="sectors-preview-link"
          href="#"
          class="relative block h-full w-full cursor-pointer overflow-hidden bg-stone-200"
        >
          <img
            id="sectors-preview-img"
            src=""
            alt=""
            class="absolute inset-0 h-full w-full scale-100 object-cover opacity-0 transition-all duration-[8s] ease-out [&.is-visible]:scale-110 [&.is-visible]:opacity-100"
          />
          <div
            class="absolute inset-0 bg-linear-to-t from-black/50 via-black/10 to-transparent opacity-0 transition-opacity duration-700 [&.is-visible]:opacity-100"
            id="sectors-preview-gradient"
          >
          </div>
        </a>
        <!-- Tagline: Elegant Footnote Style -->
        <div
          id="sectors-preview-caption"
          class="absolute right-12 bottom-12 left-12 z-10 translate-y-2 opacity-0 transition-all duration-700 [&.is-visible]:translate-y-0 [&.is-visible]:opacity-100"
        >
          <div class="border-l border-white/30 py-2 pl-6">
            <h4
              class="mb-3 text-3xl leading-tight text-white opacity-0 transition-opacity duration-700 lg:text-4xl [&.is-visible]:opacity-100"
              id="sectors-caption-header"
            >
            </h4>
            <p
              class="max-w-[80%] text-[10px] leading-relaxed font-semibold tracking-[0.5em] text-white/90 uppercase"
              id="sectors-caption-text"
            >
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ============================================================
     DISCIPLINES MEGA MENU
============================================================ -->
<div
  id="mega-menu-disciplines"
  class="pointer-events-none fixed top-0 left-0 z-190 h-screen w-full"
  aria-hidden="true"
>
  <!-- Backdrop -->
  <div class="mm-backdrop absolute inset-0 bg-black/0 transition-colors duration-500"></div>

  <!-- Panel -->
  <div
    class="mm-panel absolute top-[80px] left-0 w-full -translate-y-3 bg-white opacity-0 shadow-[0_30px_80px_rgba(0,0,0,0.18)] transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
  >
    <div
      class="relative mx-auto grid max-w-[1440px] grid-cols-[1fr_1.4fr] gap-16 px-6 py-10 lg:px-12 lg:py-16"
    >
      <!-- Close Button -->
      <button
        class="text-charcoal/20 mm-close-btn group/close absolute top-10 right-12 z-50 flex cursor-pointer items-center gap-3 text-[9px] font-medium tracking-[0.4em] uppercase transition-all duration-300 hover:text-black"
        aria-label="Close menu"
      >
        <span>Close</span>
        <Icon
          name="ph:x"
          class="h-3.5 w-3.5 transition-transform duration-500 group-hover/close:rotate-90"
        />
      </button>

      <!-- Left: Numbered List -->
      <div class="flex flex-col justify-between">
        <p class="text-charcoal/30 mb-10 text-[9px] font-medium tracking-[0.6em] uppercase">
          Core Capabilities
        </p>
        <nav class="group/list flex flex-1 flex-col justify-center gap-0" aria-label="Disciplines">
          {
            disciplines.map((d: any, i: number) => (
              <a
                href={d.path}
                class="discipline-item border-charcoal/5 text-charcoal/40 group/item flex items-center gap-6 border-b py-4 transition-all duration-500 group-hover/list:opacity-50 last:border-0 hover:opacity-100! [&.is-active]:text-black [&.is-active]:opacity-100!"
                data-image={imageUrl(d.image)}
                data-tagline={d.tagline}
                data-title={d.title}
              >
                <span class="w-8 shrink-0 text-[14px] tracking-widest tabular-nums opacity-20 transition-all duration-500 group-hover/item:opacity-100 group-[.is-active]/item:opacity-100">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span class="text-[22px] leading-tight font-medium tracking-tight transition-transform duration-500 group-hover/item:translate-x-3 group-[.is-active]/item:translate-x-3 lg:text-[26px]">
                  {d.title}
                </span>
                <div class="ml-auto flex items-center">
                  <Icon
                    name="ph:arrow-right"
                    class="h-5 w-5 shrink-0 -translate-x-2 opacity-0 transition-all duration-400 group-hover/item:translate-x-0 group-hover/item:opacity-100 group-[.is-active]/item:translate-x-0 group-[.is-active]/item:opacity-100"
                  />
                </div>
              </a>
            ))
          }
        </nav>
      </div>

      <!-- Right: Large Image -->
      <div class="mm-image-pane group/pane relative overflow-hidden bg-stone-100 p-4 lg:p-6">
        <a
          id="disciplines-preview-link"
          href="#"
          class="relative block h-full w-full cursor-pointer overflow-hidden bg-stone-200"
        >
          <img
            id="disciplines-preview-img"
            src=""
            alt=""
            class="absolute inset-0 h-full w-full scale-100 object-cover opacity-0 transition-all duration-[8s] ease-out [&.is-visible]:scale-110 [&.is-visible]:opacity-100"
          />
          <div
            class="absolute inset-0 bg-linear-to-t from-black/50 via-black/10 to-transparent opacity-0 transition-opacity duration-700 [&.is-visible]:opacity-100"
            id="disciplines-preview-gradient"
          >
          </div>
        </a>
        <!-- Tagline: Elegant Footnote Style -->
        <div
          id="disciplines-preview-caption"
          class="absolute right-12 bottom-12 left-12 z-10 translate-y-2 opacity-0 transition-all duration-700 [&.is-visible]:translate-y-0 [&.is-visible]:opacity-100"
        >
          <div class="border-l border-white/30 py-2 pl-6">
            <h4
              class="mb-3 text-3xl leading-tight text-white opacity-0 transition-opacity duration-700 lg:text-4xl [&.is-visible]:opacity-100"
              id="disciplines-caption-header"
            >
            </h4>
            <p
              class="max-w-[80%] text-[10px] leading-relaxed font-semibold tracking-[0.5em] text-white/90 uppercase"
              id="disciplines-caption-text"
            >
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MOBILE NAV -->
<nav
  id="mobile-nav"
  class="pointer-events-none fixed inset-0 z-350 flex flex-col bg-white opacity-0 transition-opacity duration-500 lg:hidden"
>
  <div class="flex h-20 shrink-0 items-center justify-end px-6">
    <!-- Hidden completely, the main burger in the header stays visible to close it -->
    <button id="mobile-nav-close" class="hidden" aria-label="Close navigation menu"> </button>
  </div>
  <div class="flex-1 overflow-y-auto px-8 py-14">
    <div class="flex flex-col gap-10">
      <!-- Core Utility Index -->
      <ul class="border-charcoal/5 mb-4 flex flex-wrap gap-x-8 gap-y-4 border-b pb-10" role="list">
        <li>
          <a
            href="/"
            class="text-charcoal/40 text-[10px] font-semibold tracking-[0.4em] uppercase transition-colors hover:text-black"
          >
            Home
          </a>
        </li>
        {
          menuItems.map((item) => (
            <li>
              <a
                href={item.path}
                class="text-charcoal/40 text-[10px] font-semibold tracking-[0.4em] uppercase transition-colors hover:text-black"
              >
                {item.name}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Interactive Taxonomy Accordions -->
      <div class="flex flex-col gap-6">
        <div class="mobile-accordion group/accordion" id="mobile-sectors-acc">
          <button
            class="text-charcoal/40 flex w-full items-center justify-between text-4xl tracking-tight transition-all duration-500 group-[.is-expanded]/accordion:mb-6 group-[.is-expanded]/accordion:text-black hover:text-black"
          >
            Portfolio
            <div class="relative flex h-4 w-4 items-center justify-center">
              <span class="absolute h-px w-4 bg-current transition-transform duration-500"></span>
              <span
                class="absolute h-4 w-px bg-current transition-transform duration-500 group-[.is-expanded]/accordion:rotate-90"
              ></span>
            </div>
          </button>
          <div
            class="animate-in fade-in slide-in-from-top-2 mt-8 hidden duration-500 group-[.is-expanded]/accordion:block"
          >
            <ul class="flex flex-col gap-1" role="list">
              {
                sectors.map((sector: any, i: number) => (
                  <li
                    class="animate-in fade-in slide-in-from-left-4 fill-mode-both duration-700"
                    style={`animation-delay: ${i * 50}ms`}
                  >
                    <a
                      href={sector.path}
                      class="border-charcoal/5 group/mobitem text-charcoal/60 flex items-center gap-6 border-b py-4 transition-colors hover:text-black"
                    >
                      <span class="w-6 shrink-0 text-[9px] font-medium tracking-[0.2em] tabular-nums opacity-40">
                        {String(i + 1).padStart(2, "0")}
                      </span>
                      <span class="text-2xl font-medium tracking-tight capitalize">
                        {sector.title}
                      </span>
                      <Icon
                        name="ph:arrow-right"
                        class="ml-auto h-4 w-4 -translate-x-2 opacity-0 transition-all duration-300 group-hover/mobitem:translate-x-0 group-hover/mobitem:opacity-100"
                      />
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <!-- Disciplines Accordion -->
        <div class="mobile-accordion group/accordion" id="mobile-disciplines-acc">
          <button
            class="text-charcoal/40 flex w-full items-center justify-between text-4xl tracking-tight transition-all duration-500 group-[.is-expanded]/accordion:mb-6 group-[.is-expanded]/accordion:text-black hover:text-black"
          >
            Disciplines
            <div class="relative flex h-4 w-4 items-center justify-center">
              <span class="absolute h-px w-4 bg-current transition-transform duration-500"></span>
              <span
                class="absolute h-4 w-px bg-current transition-transform duration-500 group-[.is-expanded]/accordion:rotate-90"
              ></span>
            </div>
          </button>
          <div
            class="animate-in fade-in slide-in-from-top-2 mt-8 hidden duration-500 group-[.is-expanded]/accordion:block"
          >
            <ul class="flex flex-col gap-1" role="list">
              {
                disciplines.map((d: any, i: number) => (
                  <li
                    class="animate-in fade-in slide-in-from-left-4 fill-mode-both duration-700"
                    style={`animation-delay: ${i * 50}ms`}
                  >
                    <a
                      href={d.path}
                      class="border-charcoal/5 group/mobitem text-charcoal/60 flex items-center gap-6 border-b py-4 transition-colors hover:text-black"
                    >
                      <span class="w-6 shrink-0 text-[9px] font-medium tracking-[0.2em] tabular-nums opacity-40">
                        {String(i + 1).padStart(2, "0")}
                      </span>
                      <span class="text-2xl font-medium tracking-tight capitalize">{d.title}</span>
                      <Icon
                        name="ph:arrow-right"
                        class="ml-auto h-4 w-4 -translate-x-2 opacity-0 transition-all duration-300 group-hover/mobitem:translate-x-0 group-hover/mobitem:opacity-100"
                      />
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>

      <!-- Contact CTA -->
      <div class="border-charcoal/5 mt-8 border-t pt-8">
        <a
          href="/contact"
          class="hover:bg-charcoal inline-block w-full bg-black px-10 py-5 text-center text-[10px] font-semibold tracking-[0.4em] text-white uppercase transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  (() => {
    // ── Mobile Nav ──────────────────────────────────────────────
    const burgerBtn = document.getElementById("burger-btn") as HTMLButtonElement;
    const mobileNav = document.getElementById("mobile-nav") as HTMLElement;
    const closeBtn = document.getElementById("mobile-nav-close") as HTMLButtonElement;

    if (burgerBtn && mobileNav && closeBtn) {
      const toggle = () => {
        const isOpen = !mobileNav.classList.contains("opacity-0");
        mobileNav.classList.toggle("opacity-0", isOpen);
        mobileNav.classList.toggle("pointer-events-none", isOpen);

        // Toggle active state on the trigger lines
        burgerBtn.classList.toggle("is-active", !isOpen);

        document.body.style.overflow = isOpen ? "" : "hidden";
      };
      burgerBtn.addEventListener("click", toggle);
      closeBtn.addEventListener("click", toggle);
    }

    // ── Mobile Accordions ──────────────────────────────────────
    const setupAccordion = (id: string) => {
      const acc = document.getElementById(id);
      const btn = acc?.querySelector("button");
      if (!acc || !btn) return;
      btn.addEventListener("click", () => {
        acc.classList.toggle("is-expanded");
      });
    };

    setupAccordion("mobile-sectors-acc");
    setupAccordion("mobile-disciplines-acc");

    // ── Mega Menu Engine ────────────────────────────────────────
    interface MenuConfig {
      triggerId: string;
      panelId: string;
      imgId: string;
      linkId: string;
      gradientId: string;
      captionId: string;
      captionTextId: string;
      captionHeaderId: string;
      itemSelector: string;
    }

    const setupMenu = (cfg: MenuConfig) => {
      const trigger = document.getElementById(cfg.triggerId);
      const panel = document.getElementById(cfg.panelId);
      const previewImg = document.getElementById(cfg.imgId) as HTMLImageElement;
      const previewLink = document.getElementById(cfg.linkId) as HTMLAnchorElement;
      const previewGradient = document.getElementById(cfg.gradientId) as HTMLElement;
      const previewCaption = document.getElementById(cfg.captionId) as HTMLElement;
      const captionText = document.getElementById(cfg.captionTextId) as HTMLElement;
      const captionHeader = document.getElementById(cfg.captionHeaderId) as HTMLElement;

      if (!trigger || !panel) return;

      const mmPanel = panel.querySelector(".mm-panel") as HTMLElement;
      const mmBackdrop = panel.querySelector(".mm-backdrop") as HTMLElement;
      const closeBtn = panel.querySelector(".mm-close-btn") as HTMLElement;
      const items = panel.querySelectorAll(cfg.itemSelector);

      let closeTimer: ReturnType<typeof setTimeout>;
      let currentImgSrc = "";

      const openMenu = () => {
        clearTimeout(closeTimer);
        panel.classList.remove("pointer-events-none");
        panel.setAttribute("aria-hidden", "false");

        // Escape key support
        const onEsc = (e: KeyboardEvent) => {
          if (e.key === "Escape") closeMenu();
        };
        document.addEventListener("keydown", onEsc, { once: true });

        // Underline
        trigger.querySelector(".nav-underline")?.classList.add("scale-x-100");

        // Panel reveal
        mmPanel.classList.remove("opacity-0", "-translate-y-3");
        mmPanel.classList.add("opacity-100", "translate-y-0");

        // Backdrop
        mmBackdrop.classList.remove("bg-black/0");
        mmBackdrop.classList.add("bg-black/20");

        // Pre-select the first item
        const firstItem = items[0] as HTMLElement;
        if (firstItem && !currentImgSrc) {
          firstItem.classList.add("is-active");
          const src = firstItem.dataset.image || "";
          const tagline = firstItem.dataset.tagline || "";
          const title = firstItem.dataset.title || "";
          const href = (firstItem as HTMLAnchorElement).href || "";
          if (src) showImage(src, tagline, title, href);
        }
      };

      const closeMenu = () => {
        closeTimer = setTimeout(() => {
          panel.classList.add("pointer-events-none");
          panel.setAttribute("aria-hidden", "true");
          // Underline
          trigger.querySelector(".nav-underline")?.classList.remove("scale-x-100");
          // Panel
          mmPanel.classList.add("opacity-0", "-translate-y-3");
          mmPanel.classList.remove("opacity-100", "translate-y-0");
          // Backdrop
          mmBackdrop.classList.add("bg-black/0");
          mmBackdrop.classList.remove("bg-black/20");
          // Hide image & clear active state
          hideImage();
        }, 150);
      };

      const showImage = (src: string, tagline: string, title: string, href: string) => {
        if (src === currentImgSrc) return;
        currentImgSrc = src;

        // Update link
        if (previewLink) previewLink.href = href;

        // Remove 'is-visible' first to reset transition if needed
        [previewImg, previewGradient, previewCaption, captionHeader].forEach((el) =>
          el?.classList.remove("is-visible"),
        );

        // Minor delay to ensure browser paints the removal if we wanted a per-image reset,
        // but for now, just swapping src and adding class is usually enough for a fresh transition
        previewImg.src = src;

        requestAnimationFrame(() => {
          [previewImg, previewGradient, previewCaption, captionHeader].forEach((el) =>
            el?.classList.add("is-visible"),
          );
          if (tagline && captionText) {
            captionText.textContent = tagline;
          }
          if (title && captionHeader) {
            captionHeader.textContent = title;
          }
        });
      };

      const hideImage = () => {
        currentImgSrc = "";
        [previewImg, previewGradient, previewCaption, captionHeader].forEach((el) =>
          el?.classList.remove("is-visible"),
        );
        // Also clear active item if image is hidden
        items.forEach((el) => el.classList.remove("is-active"));
      };

      // Trigger hover
      trigger.addEventListener("mouseenter", openMenu);
      trigger.addEventListener("mouseleave", closeMenu);
      // Panel hover (keep open)
      panel.addEventListener("mouseenter", () => clearTimeout(closeTimer));
      panel.addEventListener("mouseleave", closeMenu);

      // Item hover → show image
      items.forEach((item) => {
        item.addEventListener("mouseenter", () => {
          // Clear others first
          items.forEach((el) => el.classList.remove("is-active"));
          // Set active
          item.classList.add("is-active");

          const src = (item as HTMLElement).dataset.image || "";
          const tagline = (item as HTMLElement).dataset.tagline || "";
          const title = (item as HTMLElement).dataset.title || "";
          const href = (item as HTMLAnchorElement).href || "";
          if (src) showImage(src, tagline, title, href);
        });
      });

      // Backdrop click → close
      mmBackdrop.addEventListener("click", () => {
        clearTimeout(closeTimer);
        closeMenu();
      });

      // Close button click
      closeBtn?.addEventListener("click", () => {
        clearTimeout(closeTimer);
        closeMenu();
      });
    };

    setupMenu({
      triggerId: "sectors-trigger",
      panelId: "mega-menu-sectors",
      imgId: "sectors-preview-img",
      linkId: "sectors-preview-link",
      gradientId: "sectors-preview-gradient",
      captionId: "sectors-preview-caption",
      captionTextId: "sectors-caption-text",
      captionHeaderId: "sectors-caption-header",
      itemSelector: ".sector-item",
    });

    setupMenu({
      triggerId: "disciplines-trigger",
      panelId: "mega-menu-disciplines",
      imgId: "disciplines-preview-img",
      linkId: "disciplines-preview-link",
      gradientId: "disciplines-preview-gradient",
      captionId: "disciplines-preview-caption",
      captionTextId: "disciplines-caption-text",
      captionHeaderId: "disciplines-caption-header",
      itemSelector: ".discipline-item",
    });
  })();
</script>
