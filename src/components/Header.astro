---
import Icon from "./Icon.astro";
import Cta from "./Cta.astro";
import {
  client,
  SECTORS_QUERY,
  DISCIPLINES_QUERY,
  imageUrl,
} from "../lib/sanity";

const sectorsData = await client.fetch(SECTORS_QUERY);
const disciplinesData = await client.fetch(DISCIPLINES_QUERY);

const sectors = sectorsData.map((sector: any) => ({
  title: sector.title,
  tagline:
    sector.menuTagline ||
    sector.homeHeadline ||
    "Expert Architectural Solutions",
  path: `/sectors/${sector.slug}`,
  image: sector.menuImage || sector.image,
}));

const disciplines = disciplinesData.map((d: any) => ({
  title: d.title,
  path: `/disciplines/${d.slug}`,
  image: d.mainImage,
  tagline: d.valueProposition,
}));

const menuItems = [
  { name: "Engagement", path: "/engagement" },
  { name: "About", path: "/about" },
];
---

<!-- HEADER BAR -->
<header
  id="site-header"
  class="fixed top-0 left-0 w-full z-400 transition-all duration-700 bg-white/80 backdrop-blur-md border-b border-charcoal/5"
  aria-label="Site Header"
>
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12 relative">
    <div class="flex h-20 items-center justify-between">
      <!-- Logo -->
      <a
        href="/"
        class="relative z-10 flex items-center gap-3 group/logo"
        aria-label="Metaphors Design — Home"
      >
        <img
          alt=""
          aria-hidden="true"
          class="h-6 w-auto transition-transform duration-700 grayscale-30 group-hover/logo:scale-110 group-hover/logo:grayscale-0"
          src="/metaphors-design-logo.svg"
        />
        <span class="text-xl font-medium tracking-tight text-black"
          >metaphors design</span
        >
      </a>

      <!-- Desktop Navigation -->
      <nav
        class="hidden lg:flex items-center gap-12 h-full"
        aria-label="Primary"
      >
        <!-- Sectors Trigger -->
        <div
          class="h-full flex items-center menu-trigger-container projects"
          id="sectors-trigger"
        >
          <button
            class="relative flex items-center gap-2 text-[10px] font-medium uppercase tracking-[0.3em] text-charcoal/60 hover:text-black transition-colors duration-300 h-full cursor-pointer"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Portfolio
            <Icon name="ph:caret-down" class="w-2.5 h-2.5" />
            <span
              class="nav-underline absolute bottom-[28px] left-0 w-full h-[1.5px] bg-black scale-x-0 transition-transform duration-400 origin-left"
            ></span>
          </button>
        </div>

        <!-- Disciplines Trigger -->
        <div
          class="h-full flex items-center menu-trigger-container disciplines"
          id="disciplines-trigger"
        >
          <button
            class="relative flex items-center gap-2 text-[10px] font-medium uppercase tracking-[0.3em] text-charcoal/60 hover:text-black transition-colors duration-300 h-full cursor-pointer"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Expertise
            <Icon name="ph:caret-down" class="w-2.5 h-2.5" />
            <span
              class="nav-underline absolute bottom-[28px] left-0 w-full h-[1.5px] bg-black scale-x-0 transition-transform duration-400 origin-left"
            ></span>
          </button>
        </div>

        {
          menuItems.map((item) => (
            <a
              href={item.path}
              class="relative text-[10px] font-medium uppercase tracking-[0.3em] text-charcoal/60 hover:text-black transition-colors py-2 group/nav h-full flex items-center"
            >
              {item.name}
              <span class="absolute bottom-[28px] left-0 w-full h-[1.5px] bg-black scale-x-0 group-hover/nav:scale-x-100 transition-transform duration-400 origin-left" />
            </a>
          ))
        }
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:block">
        <Cta text="Contact Us" href="/contact" />
      </div>

      <!-- Custom Drafting Burger Trigger -->
      <button
        id="burger-btn"
        class="lg:hidden relative z-300 w-10 h-10 flex flex-col items-end justify-center gap-1.5 group/burger"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span
          class="w-6 h-px bg-charcoal transition-all duration-500 group-[.is-active]/burger:rotate-45 group-[.is-active]/burger:translate-y-[3.5px]"
        ></span>
        <span
          class="w-4 h-px bg-charcoal transition-all duration-500 group-[.is-active]/burger:w-6 group-[.is-active]/burger:-rotate-45 group-[.is-active]/burger:-translate-y-[3.5px]"
        ></span>
      </button>
    </div>
  </div>
</header>

<!-- ============================================================
     SECTORS MEGA MENU
============================================================ -->
<div
  id="mega-menu-sectors"
  class="fixed top-0 left-0 w-full h-screen z-190 pointer-events-none"
  aria-hidden="true"
>
  <!-- Backdrop -->
  <div
    class="mm-backdrop absolute inset-0 bg-black/0 transition-colors duration-500"
  >
  </div>

  <!-- Panel -->
  <div
    class="mm-panel absolute top-[80px] left-0 w-full bg-white shadow-[0_30px_80px_rgba(0,0,0,0.18)]
              opacity-0 -translate-y-3 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
  >
    <div
      class="max-w-[1440px] mx-auto px-6 lg:px-12 grid grid-cols-[1fr_1.4fr] py-10 lg:py-16 gap-16 relative"
    >
      <!-- Close Button -->
      <button
        class="absolute top-10 right-12 text-[9px] font-medium uppercase tracking-[0.4em] text-charcoal/20 hover:text-black transition-all duration-300 flex items-center gap-3 mm-close-btn cursor-pointer group/close z-50"
        aria-label="Close menu"
      >
        <span>Close</span>
        <Icon
          name="ph:x"
          class="w-3.5 h-3.5 transition-transform duration-500 group-hover/close:rotate-90"
        />
      </button>

      <!-- Left: Numbered List -->
      <div class="flex flex-col justify-between">
        <p
          class="text-[9px] font-medium uppercase tracking-[0.6em] text-charcoal/30 mb-10"
        >
          Work by Industry
        </p>
        <nav
          class="flex flex-col gap-0 group/list flex-1 justify-center"
          aria-label="Sectors"
        >
          {
            sectors.map((sector: any, i: number) => (
              <a
                href={sector.path}
                class="sector-item flex items-center gap-6 py-4 border-b border-charcoal/5 last:border-0
                     text-charcoal/40 transition-all duration-500 group/item
                     group-hover/list:opacity-50 hover:opacity-100! [&.is-active]:text-black [&.is-active]:opacity-100!"
                data-image={imageUrl(sector.image)}
                data-tagline={sector.tagline}
                data-title={sector.title}
              >
                <span class="text-[14px] tracking-widest w-8 shrink-0 tabular-nums opacity-20 group-hover/item:opacity-100 group-[.is-active]/item:opacity-100 transition-all duration-500">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span class="text-[22px] lg:text-[26px] font-medium leading-tight tracking-tight transition-transform duration-500 group-hover/item:translate-x-3 group-[.is-active]/item:translate-x-3">
                  {sector.title}
                </span>
                <div class="ml-auto flex items-center">
                  <Icon
                    name="ph:arrow-right"
                    class="w-5 h-5 opacity-0 -translate-x-2 group-hover/item:opacity-100 group-hover/item:translate-x-0 group-[.is-active]/item:opacity-100 group-[.is-active]/item:translate-x-0 transition-all duration-400 shrink-0"
                  />
                </div>
              </a>
            ))
          }
        </nav>
      </div>

      <!-- Right: Large Image (intent-driven, empty by default) -->
      <div
        class="mm-image-pane relative overflow-hidden bg-stone-100 group/pane p-4 lg:p-6"
      >
        <a
          id="sectors-preview-link"
          href="#"
          class="block w-full h-full relative overflow-hidden bg-stone-200 cursor-pointer"
        >
          <img
            id="sectors-preview-img"
            src=""
            alt=""
            class="absolute inset-0 w-full h-full object-cover opacity-0 transition-all duration-[8s] ease-out scale-100 [&.is-visible]:opacity-100 [&.is-visible]:scale-110"
          />
          <div
            class="absolute inset-0 bg-linear-to-t from-black/50 via-black/10 to-transparent opacity-0 transition-opacity duration-700 [&.is-visible]:opacity-100"
            id="sectors-preview-gradient"
          >
          </div>
        </a>
        <!-- Tagline: Elegant Footnote Style -->
        <div
          id="sectors-preview-caption"
          class="absolute bottom-12 left-12 right-12 z-10 opacity-0 translate-y-2 transition-all duration-700 [&.is-visible]:opacity-100 [&.is-visible]:translate-y-0"
        >
          <div class="border-l border-white/30 pl-6 py-2">
            <h4
              class="text-3xl lg:text-4xl text-white mb-3 leading-tight opacity-0 transition-opacity duration-700 [&.is-visible]:opacity-100"
              id="sectors-caption-header"
            >
            </h4>
            <p
              class="text-[10px] font-semibold uppercase tracking-[0.5em] text-white/90 leading-relaxed max-w-[80%]"
              id="sectors-caption-text"
            >
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ============================================================
     DISCIPLINES MEGA MENU
============================================================ -->
<div
  id="mega-menu-disciplines"
  class="fixed top-0 left-0 w-full h-screen z-190 pointer-events-none"
  aria-hidden="true"
>
  <!-- Backdrop -->
  <div
    class="mm-backdrop absolute inset-0 bg-black/0 transition-colors duration-500"
  >
  </div>

  <!-- Panel -->
  <div
    class="mm-panel absolute top-[80px] left-0 w-full bg-white shadow-[0_30px_80px_rgba(0,0,0,0.18)]
              opacity-0 -translate-y-3 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
  >
    <div
      class="max-w-[1440px] mx-auto px-6 lg:px-12 grid grid-cols-[1fr_1.4fr] py-10 lg:py-16 gap-16 relative"
    >
      <!-- Close Button -->
      <button
        class="absolute top-10 right-12 text-[9px] font-medium uppercase tracking-[0.4em] text-charcoal/20 hover:text-black transition-all duration-300 flex items-center gap-3 mm-close-btn cursor-pointer group/close z-50"
        aria-label="Close menu"
      >
        <span>Close</span>
        <Icon
          name="ph:x"
          class="w-3.5 h-3.5 transition-transform duration-500 group-hover/close:rotate-90"
        />
      </button>

      <!-- Left: Numbered List -->
      <div class="flex flex-col justify-between">
        <p
          class="text-[9px] font-medium uppercase tracking-[0.6em] text-charcoal/30 mb-10"
        >
          Core Capabilities
        </p>
        <nav
          class="flex flex-col gap-0 group/list flex-1 justify-center"
          aria-label="Disciplines"
        >
          {
            disciplines.map((d: any, i: number) => (
              <a
                href={d.path}
                class="discipline-item flex items-center gap-6 py-4 border-b border-charcoal/5 last:border-0
                     text-charcoal/40 transition-all duration-500 group/item
                     group-hover/list:opacity-50 hover:opacity-100! [&.is-active]:text-black [&.is-active]:opacity-100!"
                data-image={imageUrl(d.image)}
                data-tagline={d.tagline}
                data-title={d.title}
              >
                <span class="text-[14px] tracking-widest w-8 shrink-0 tabular-nums opacity-20 group-hover/item:opacity-100 group-[.is-active]/item:opacity-100 transition-all duration-500">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span class="text-[22px] lg:text-[26px] font-medium leading-tight tracking-tight transition-transform duration-500 group-hover/item:translate-x-3 group-[.is-active]/item:translate-x-3">
                  {d.title}
                </span>
                <div class="ml-auto flex items-center">
                  <Icon
                    name="ph:arrow-right"
                    class="w-5 h-5 opacity-0 -translate-x-2 group-hover/item:opacity-100 group-hover/item:translate-x-0 group-[.is-active]/item:opacity-100 group-[.is-active]/item:translate-x-0 transition-all duration-400 shrink-0"
                  />
                </div>
              </a>
            ))
          }
        </nav>
      </div>

      <!-- Right: Large Image -->
      <div
        class="mm-image-pane relative overflow-hidden bg-stone-100 group/pane p-4 lg:p-6"
      >
        <a
          id="disciplines-preview-link"
          href="#"
          class="block w-full h-full relative overflow-hidden bg-stone-200 cursor-pointer"
        >
          <img
            id="disciplines-preview-img"
            src=""
            alt=""
            class="absolute inset-0 w-full h-full object-cover opacity-0 transition-all duration-[8s] ease-out scale-100 [&.is-visible]:opacity-100 [&.is-visible]:scale-110"
          />
          <div
            class="absolute inset-0 bg-linear-to-t from-black/50 via-black/10 to-transparent opacity-0 transition-opacity duration-700 [&.is-visible]:opacity-100"
            id="disciplines-preview-gradient"
          >
          </div>
        </a>
        <!-- Tagline: Elegant Footnote Style -->
        <div
          id="disciplines-preview-caption"
          class="absolute bottom-12 left-12 right-12 z-10 opacity-0 translate-y-2 transition-all duration-700 [&.is-visible]:opacity-100 [&.is-visible]:translate-y-0"
        >
          <div class="border-l border-white/30 pl-6 py-2">
            <h4
              class="text-3xl lg:text-4xl text-white mb-3 leading-tight opacity-0 transition-opacity duration-700 [&.is-visible]:opacity-100"
              id="disciplines-caption-header"
            >
            </h4>
            <p
              class="text-[10px] font-semibold uppercase tracking-[0.5em] text-white/90 leading-relaxed max-w-[80%]"
              id="disciplines-caption-text"
            >
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MOBILE NAV -->
<nav
  id="mobile-nav"
  class="fixed inset-0 z-350 bg-white flex flex-col pointer-events-none opacity-0 transition-opacity duration-500 lg:hidden"
>
  <div class="flex h-20 items-center justify-end px-6 shrink-0">
    <!-- Hidden completely, the main burger in the header stays visible to close it -->
    <button
      id="mobile-nav-close"
      class="hidden"
      aria-label="Close navigation menu"
    >
    </button>
  </div>
  <div class="flex-1 overflow-y-auto px-8 py-14">
    <div class="flex flex-col gap-10">
      <!-- Core Utility Index -->
      <ul
        class="flex flex-wrap gap-x-8 gap-y-4 mb-4 border-b border-charcoal/5 pb-10"
        role="list"
      >
        <li>
          <a
            href="/"
            class="text-[10px] font-semibold uppercase tracking-[0.4em] text-charcoal/40 hover:text-black transition-colors"
          >
            Home
          </a>
        </li>
        {
          menuItems.map((item) => (
            <li>
              <a
                href={item.path}
                class="text-[10px] font-semibold uppercase tracking-[0.4em] text-charcoal/40 hover:text-black transition-colors"
              >
                {item.name}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Interactive Taxonomy Accordions -->
      <div class="flex flex-col gap-6">
        <div class="mobile-accordion group/accordion" id="mobile-sectors-acc">
          <button
            class="flex items-center justify-between w-full text-4xl tracking-tight text-charcoal/40 hover:text-black transition-all duration-500 group-[.is-expanded]/accordion:text-black group-[.is-expanded]/accordion:mb-6"
          >
            Portfolio
            <div class="relative w-4 h-4 flex items-center justify-center">
              <span
                class="absolute w-4 h-px bg-current transition-transform duration-500"
              ></span>
              <span
                class="absolute w-px h-4 bg-current transition-transform duration-500 group-[.is-expanded]/accordion:rotate-90"
              ></span>
            </div>
          </button>
          <div
            class="hidden group-[.is-expanded]/accordion:block mt-8 animate-in fade-in slide-in-from-top-2 duration-500"
          >
            <ul class="flex flex-col gap-1" role="list">
              {
                sectors.map((sector: any, i: number) => (
                  <li
                    class="animate-in fade-in slide-in-from-left-4 fill-mode-both duration-700"
                    style={`animation-delay: ${i * 50}ms`}
                  >
                    <a
                      href={sector.path}
                      class="flex items-center gap-6 py-4 border-b border-charcoal/5 group/mobitem
                             text-charcoal/60 hover:text-black transition-colors"
                    >
                      <span class="text-[9px] font-medium tracking-[0.2em] w-6 shrink-0 tabular-nums opacity-40">
                        {String(i + 1).padStart(2, "0")}
                      </span>
                      <span class="text-2xl font-medium tracking-tight capitalize">
                        {sector.title}
                      </span>
                      <Icon
                        name="ph:arrow-right"
                        class="ml-auto w-4 h-4 opacity-0 -translate-x-2 group-hover/mobitem:opacity-100 group-hover/mobitem:translate-x-0 transition-all duration-300"
                      />
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <!-- Disciplines Accordion -->
        <div
          class="mobile-accordion group/accordion"
          id="mobile-disciplines-acc"
        >
          <button
            class="flex items-center justify-between w-full text-4xl tracking-tight text-charcoal/40 hover:text-black transition-all duration-500 group-[.is-expanded]/accordion:text-black group-[.is-expanded]/accordion:mb-6"
          >
            Expertise
            <div class="relative w-4 h-4 flex items-center justify-center">
              <span
                class="absolute w-4 h-px bg-current transition-transform duration-500"
              ></span>
              <span
                class="absolute w-px h-4 bg-current transition-transform duration-500 group-[.is-expanded]/accordion:rotate-90"
              ></span>
            </div>
          </button>
          <div
            class="hidden group-[.is-expanded]/accordion:block mt-8 animate-in fade-in slide-in-from-top-2 duration-500"
          >
            <ul class="flex flex-col gap-1" role="list">
              {
                disciplines.map((d: any, i: number) => (
                  <li
                    class="animate-in fade-in slide-in-from-left-4 fill-mode-both duration-700"
                    style={`animation-delay: ${i * 50}ms`}
                  >
                    <a
                      href={d.path}
                      class="flex items-center gap-6 py-4 border-b border-charcoal/5 group/mobitem
                             text-charcoal/60 hover:text-black transition-colors"
                    >
                      <span class="text-[9px] font-medium tracking-[0.2em] w-6 shrink-0 tabular-nums opacity-40">
                        {String(i + 1).padStart(2, "0")}
                      </span>
                      <span class="text-2xl font-medium tracking-tight capitalize">
                        {d.title}
                      </span>
                      <Icon
                        name="ph:arrow-right"
                        class="ml-auto w-4 h-4 opacity-0 -translate-x-2 group-hover/mobitem:opacity-100 group-hover/mobitem:translate-x-0 transition-all duration-300"
                      />
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>

      <!-- Contact CTA -->
      <div class="mt-8 pt-8 border-t border-charcoal/5">
        <a
          href="/contact"
          class="inline-block text-[10px] font-semibold uppercase tracking-[0.4em] w-full text-center text-white bg-black px-10 py-5 hover:bg-charcoal transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  (() => {
    // ── Mobile Nav ──────────────────────────────────────────────
    const burgerBtn = document.getElementById(
      "burger-btn",
    ) as HTMLButtonElement;
    const mobileNav = document.getElementById("mobile-nav") as HTMLElement;
    const closeBtn = document.getElementById(
      "mobile-nav-close",
    ) as HTMLButtonElement;

    if (burgerBtn && mobileNav && closeBtn) {
      const toggle = () => {
        const isOpen = !mobileNav.classList.contains("opacity-0");
        mobileNav.classList.toggle("opacity-0", isOpen);
        mobileNav.classList.toggle("pointer-events-none", isOpen);

        // Toggle active state on the trigger lines
        burgerBtn.classList.toggle("is-active", !isOpen);

        document.body.style.overflow = isOpen ? "" : "hidden";
      };
      burgerBtn.addEventListener("click", toggle);
      closeBtn.addEventListener("click", toggle);
    }

    // ── Mobile Accordions ──────────────────────────────────────
    const setupAccordion = (id: string) => {
      const acc = document.getElementById(id);
      const btn = acc?.querySelector("button");
      if (!acc || !btn) return;
      btn.addEventListener("click", () => {
        acc.classList.toggle("is-expanded");
      });
    };

    setupAccordion("mobile-sectors-acc");
    setupAccordion("mobile-disciplines-acc");

    // ── Mega Menu Engine ────────────────────────────────────────
    interface MenuConfig {
      triggerId: string;
      panelId: string;
      imgId: string;
      linkId: string;
      gradientId: string;
      captionId: string;
      captionTextId: string;
      captionHeaderId: string;
      itemSelector: string;
    }

    const setupMenu = (cfg: MenuConfig) => {
      const trigger = document.getElementById(cfg.triggerId);
      const panel = document.getElementById(cfg.panelId);
      const previewImg = document.getElementById(cfg.imgId) as HTMLImageElement;
      const previewLink = document.getElementById(
        cfg.linkId,
      ) as HTMLAnchorElement;
      const previewGradient = document.getElementById(
        cfg.gradientId,
      ) as HTMLElement;
      const previewCaption = document.getElementById(
        cfg.captionId,
      ) as HTMLElement;
      const captionText = document.getElementById(
        cfg.captionTextId,
      ) as HTMLElement;
      const captionHeader = document.getElementById(
        cfg.captionHeaderId,
      ) as HTMLElement;

      if (!trigger || !panel) return;

      const mmPanel = panel.querySelector(".mm-panel") as HTMLElement;
      const mmBackdrop = panel.querySelector(".mm-backdrop") as HTMLElement;
      const closeBtn = panel.querySelector(".mm-close-btn") as HTMLElement;
      const items = panel.querySelectorAll(cfg.itemSelector);

      let closeTimer: ReturnType<typeof setTimeout>;
      let currentImgSrc = "";

      const openMenu = () => {
        clearTimeout(closeTimer);
        panel.classList.remove("pointer-events-none");
        panel.setAttribute("aria-hidden", "false");

        // Escape key support
        const onEsc = (e: KeyboardEvent) => {
          if (e.key === "Escape") closeMenu();
        };
        document.addEventListener("keydown", onEsc, { once: true });

        // Underline
        trigger.querySelector(".nav-underline")?.classList.add("scale-x-100");

        // Panel reveal
        mmPanel.classList.remove("opacity-0", "-translate-y-3");
        mmPanel.classList.add("opacity-100", "translate-y-0");

        // Backdrop
        mmBackdrop.classList.remove("bg-black/0");
        mmBackdrop.classList.add("bg-black/20");

        // Pre-select the first item
        const firstItem = items[0] as HTMLElement;
        if (firstItem && !currentImgSrc) {
          firstItem.classList.add("is-active");
          const src = firstItem.dataset.image || "";
          const tagline = firstItem.dataset.tagline || "";
          const title = firstItem.dataset.title || "";
          const href = (firstItem as HTMLAnchorElement).href || "";
          if (src) showImage(src, tagline, title, href);
        }
      };

      const closeMenu = () => {
        closeTimer = setTimeout(() => {
          panel.classList.add("pointer-events-none");
          panel.setAttribute("aria-hidden", "true");
          // Underline
          trigger
            .querySelector(".nav-underline")
            ?.classList.remove("scale-x-100");
          // Panel
          mmPanel.classList.add("opacity-0", "-translate-y-3");
          mmPanel.classList.remove("opacity-100", "translate-y-0");
          // Backdrop
          mmBackdrop.classList.add("bg-black/0");
          mmBackdrop.classList.remove("bg-black/20");
          // Hide image & clear active state
          hideImage();
        }, 150);
      };

      const showImage = (
        src: string,
        tagline: string,
        title: string,
        href: string,
      ) => {
        if (src === currentImgSrc) return;
        currentImgSrc = src;

        // Update link
        if (previewLink) previewLink.href = href;

        // Remove 'is-visible' first to reset transition if needed
        [previewImg, previewGradient, previewCaption, captionHeader].forEach(
          (el) => el?.classList.remove("is-visible"),
        );

        // Minor delay to ensure browser paints the removal if we wanted a per-image reset,
        // but for now, just swapping src and adding class is usually enough for a fresh transition
        previewImg.src = src;

        requestAnimationFrame(() => {
          [previewImg, previewGradient, previewCaption, captionHeader].forEach(
            (el) => el?.classList.add("is-visible"),
          );
          if (tagline && captionText) {
            captionText.textContent = tagline;
          }
          if (title && captionHeader) {
            captionHeader.textContent = title;
          }
        });
      };

      const hideImage = () => {
        currentImgSrc = "";
        [previewImg, previewGradient, previewCaption, captionHeader].forEach(
          (el) => el?.classList.remove("is-visible"),
        );
        // Also clear active item if image is hidden
        items.forEach((el) => el.classList.remove("is-active"));
      };

      // Trigger hover
      trigger.addEventListener("mouseenter", openMenu);
      trigger.addEventListener("mouseleave", closeMenu);
      // Panel hover (keep open)
      panel.addEventListener("mouseenter", () => clearTimeout(closeTimer));
      panel.addEventListener("mouseleave", closeMenu);

      // Item hover → show image
      items.forEach((item) => {
        item.addEventListener("mouseenter", () => {
          // Clear others first
          items.forEach((el) => el.classList.remove("is-active"));
          // Set active
          item.classList.add("is-active");

          const src = (item as HTMLElement).dataset.image || "";
          const tagline = (item as HTMLElement).dataset.tagline || "";
          const title = (item as HTMLElement).dataset.title || "";
          const href = (item as HTMLAnchorElement).href || "";
          if (src) showImage(src, tagline, title, href);
        });
      });

      // Backdrop click → close
      mmBackdrop.addEventListener("click", () => {
        clearTimeout(closeTimer);
        closeMenu();
      });

      // Close button click
      closeBtn?.addEventListener("click", () => {
        clearTimeout(closeTimer);
        closeMenu();
      });
    };

    setupMenu({
      triggerId: "sectors-trigger",
      panelId: "mega-menu-sectors",
      imgId: "sectors-preview-img",
      linkId: "sectors-preview-link",
      gradientId: "sectors-preview-gradient",
      captionId: "sectors-preview-caption",
      captionTextId: "sectors-caption-text",
      captionHeaderId: "sectors-caption-header",
      itemSelector: ".sector-item",
    });

    setupMenu({
      triggerId: "disciplines-trigger",
      panelId: "mega-menu-disciplines",
      imgId: "disciplines-preview-img",
      linkId: "disciplines-preview-link",
      gradientId: "disciplines-preview-gradient",
      captionId: "disciplines-preview-caption",
      captionTextId: "disciplines-caption-text",
      captionHeaderId: "disciplines-caption-header",
      itemSelector: ".discipline-item",
    });
  })();
</script>
