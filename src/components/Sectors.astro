---
import { client, SECTORS_QUERY, imageUrl } from "../lib/sanity";

const sectors = await client.fetch(SECTORS_QUERY);
---

<section class="w-full bg-bone py-24 border-t border-charcoal/5">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div
      class="flex flex-col md:flex-row justify-between items-end mb-24 gap-8"
    >
      <div class="max-w-xl">
        <h2 class="text-4xl lg:text-6xl mb-6 italic tracking-tight">
          Sector Expertise.
        </h2>
        <p class="text-lg text-charcoal/60 font-light leading-relaxed">
          Broad architectural reach across India's most significant asset
          classes, delivered with technical discipline.
        </p>
      </div>
      <a
        href="/sectors"
        class="text-[10px] font-medium uppercase tracking-[0.2em] pb-1 micro-hover luxury-transition text-charcoal/80 hover:text-charcoal"
      >
        View Sector Portfolios
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      {
        sectors.map((sector: any) => (
          <a
            href={`/sectors/${sector.slug}`}
            class="bg-bone group flex flex-col lg:flex-row transition-all duration-1000 cubic-bezier(0.19, 1, 0.22, 1) hover:bg-charcoal overflow-hidden border border-charcoal/20 hover:border-charcoal/20 relative cursor-pointer min-h-[440px]"
          >
            {/* Architectural Visual Breakup */}
            <div class="w-full h-48 lg:h-auto lg:w-1/4 relative overflow-hidden luxury-grayscale">
              {sector.image && (
                <img
                  src={imageUrl(sector.image, { width: 162, height: 484 })}
                  alt={sector.title}
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 cubic-bezier(0.19, 1, 0.22, 1) group-hover:scale-110"
                />
              )}
            </div>

            {/* Strategic Content Block */}
            <div class="w-full lg:w-3/4 p-8 lg:p-14 flex flex-col justify-between relative">
              <div class="reveal">
                <div class="mb-10">
                  <h3 class="text-3xl lg:text-4xl group-hover:text-bone luxury-transition font-serif italic font-medium leading-none">
                    {sector.title}
                  </h3>
                </div>
                <div class="space-y-8 mb-12 lg:mb-16">
                  <div>
                    <div class="flex items-center gap-2 mb-2 lg:mb-3">
                      <p class="text-[9px] lg:text-[10px] font-medium uppercase tracking-widest text-charcoal/40 group-hover:text-bone/40 luxury-transition">
                        Focus
                      </p>
                    </div>
                    <p class="text-charcoal/80 group-hover:text-bone/80 font-light leading-snug luxury-transition text-base lg:text-lg">
                      {sector.focus}
                    </p>
                  </div>
                  <div>
                    <div class="flex items-center gap-2 mb-2 lg:mb-3">
                      <p class="text-[9px] lg:text-[10px] font-medium uppercase tracking-widest text-charcoal/40 group-hover:text-bone/40 luxury-transition">
                        Our Approach
                      </p>
                    </div>
                    <p class="text-charcoal group-hover:text-bone font-medium leading-snug luxury-transition text-base lg:text-lg">
                      {sector.approach}
                    </p>
                  </div>
                </div>
              </div>

              <div class="flex flex-col-reverse lg:flex-row justify-between items-start lg:items-end gap-6 border-t border-charcoal/10 group-hover:border-white/10 pt-6">
                <p class="text-[10px] lg:text-xs italic font-serif text-charcoal/60 group-hover:text-bone/60 luxury-transition reveal">
                  {sector.proof}
                </p>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
