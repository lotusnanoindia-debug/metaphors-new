---
import { Icon } from "astro-icon/components";
const sectors = [
  {
    title: "Commerce & Retail",
    problem: "Real estate inefficiency and low traffic conversion.",
    solution:
      "We architect high-velocity retail and commercial assets engineered for yield.",
    proof: "Flagship work: Phoenix Mall & Shizusan.",
    image:
      "https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=2070&auto=format&fit=crop",
  },
  {
    title: "Hospitality & Leisure",
    problem: "Operational friction and high lifecycle maintenance costs.",
    solution:
      "Premium hospitality estates designed for guest loyalty and long-term durability.",
    proof: "Flagship work: The Corinthians Resort.",
    image:
      "https://images.unsplash.com/photo-1566073771259-6a8506099945?q=80&w=2070&auto=format&fit=crop",
  },
  {
    title: "Private & Collective Living",
    problem:
      "Generic residential design that lacks bespoke value and desirability.",
    solution:
      "From private villas to luxury landmarks, we architect for elevated living and rapid absorption.",
    proof: "Featured: Premium Villas & Residence Landmarks.",
    image:
      "https://images.unsplash.com/photo-1613490493576-7fde63acd811?q=80&w=2071&auto=format&fit=crop",
  },
  {
    title: "Institutional & Corporate",
    problem: "Technical resilience and operational flow constraints.",
    solution:
      "High-precision environments designed for structural efficiency and technical complexity.",
    proof: "Trusted by Wipro, Pune & Healthcare Providers.",
    image:
      "https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2069&auto=format&fit=crop",
  },
];
---

<section class="w-full bg-bone py-24 border-t border-charcoal/5">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div
      class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8"
    >
      <div class="max-w-xl">
        <h2 class="text-4xl lg:text-6xl mb-6 italic tracking-tight">
          Sector Specialisation.
        </h2>
        <p class="text-lg text-charcoal/60 font-light leading-relaxed">
          We do not just offer architectural services. We deliver strategic
          results across the most complex asset classes in India.
        </p>
      </div>
      <a
        href="#"
        class="text-[10px] font-bold uppercase tracking-[0.2em] pb-1 micro-hover luxury-transition text-charcoal/80 hover:text-charcoal"
      >
        View All Sectors
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      {
        sectors.map((sector) => (
          <a
            href="#"
            class="bg-bone group flex flex-col lg:flex-row transition-all duration-1000 cubic-bezier(0.19, 1, 0.22, 1) hover:bg-charcoal overflow-hidden border border-charcoal/20 hover:border-charcoal/20 relative cursor-pointer min-h-[440px]"
          >
            {/* Architectural Visual Breakup */}
            <div class="w-full h-48 lg:h-auto lg:w-1/4 relative overflow-hidden luxury-grayscale">
              <img
                src={sector.image}
                alt={sector.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 cubic-bezier(0.19, 1, 0.22, 1) group-hover:scale-110"
              />
            </div>

            {/* Strategic Content Block */}
            <div class="w-full lg:w-3/4 p-8 lg:p-14 flex flex-col justify-between relative">
              <div class="reveal">
                <div class="mb-10">
                  <h3 class="text-3xl lg:text-4xl group-hover:text-bone luxury-transition font-serif italic leading-none">
                    {sector.title}
                  </h3>
                </div>
                <div class="space-y-8 mb-12 lg:mb-16">
                  <div>
                    <div class="flex items-center gap-2 mb-2 lg:mb-3">
                      <Icon
                        name="ph:warning-circle"
                        class="w-4 h-4 text-charcoal/40 group-hover:text-bone/40 luxury-transition"
                      />
                      <p class="text-[9px] lg:text-[10px] font-bold uppercase tracking-widest text-charcoal/40 group-hover:text-bone/40 luxury-transition">
                        The Challenge
                      </p>
                    </div>
                    <p class="text-charcoal/80 group-hover:text-bone/80 font-light leading-snug luxury-transition text-base lg:text-lg">
                      {sector.problem}
                    </p>
                  </div>
                  <div>
                    <div class="flex items-center gap-2 mb-2 lg:mb-3">
                      <Icon
                        name="ph:chart-line-up"
                        class="w-4 h-4 text-charcoal/40 group-hover:text-bone/40 luxury-transition"
                      />
                      <p class="text-[9px] lg:text-[10px] font-bold uppercase tracking-widest text-charcoal/40 group-hover:text-bone/40 luxury-transition">
                        The Strategic Result
                      </p>
                    </div>
                    <p class="text-charcoal group-hover:text-bone font-medium leading-snug luxury-transition text-base lg:text-lg">
                      {sector.solution}
                    </p>
                  </div>
                </div>
              </div>

              <div class="flex flex-col-reverse lg:flex-row justify-between items-start lg:items-end gap-6 border-t border-charcoal/10 group-hover:border-white/10 pt-6">
                <p class="text-[10px] lg:text-xs italic font-serif text-charcoal/60 group-hover:text-bone/60 luxury-transition reveal">
                  {sector.proof}
                </p>

                {/* Explore Action Button - Responsive Placement */}
                <div class="lg:absolute lg:bottom-10 lg:right-12 opacity-100 lg:opacity-0 transform lg:translate-x-4 lg:group-hover:opacity-100 lg:group-hover:translate-x-0 luxury-transition">
                  <span class="flex items-center gap-2 text-ink text-[9px] lg:text-[10px] font-black uppercase tracking-widest transition-all hover:gap-4">
                    Explore Sector
                    <Icon
                      name="ph:caret-right-bold"
                      class="w-3 h-3 lg:w-4 lg:h-4"
                    />
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
