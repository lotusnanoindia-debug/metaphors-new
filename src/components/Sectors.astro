---
import { client, SECTORS_QUERY, imageUrl } from "../lib/sanity";
import Icon from "./Icon.astro";
import Cta from "./Cta.astro";

interface Props {
  section?: any;
}

const { section } = Astro.props;

const rawSectors = await client.fetch(SECTORS_QUERY);

function formatSqFt(sqft: number): string | null {
  if (!sqft) return null;
  const lakhs = sqft / 100_000;
  const ind = lakhs >= 100 ? `${(lakhs / 100).toFixed(1)} Crore` : `${lakhs.toLocaleString()} Lakh`;
  return `${ind} / ${(sqft / 1_000_000).toFixed(1)}M Sq Ft`;
}

const sectors = rawSectors.map((sector: any) => ({
  ...sector,
  totalSqFt: sector.projects?.reduce((sum: number, p: any) => sum + (p.areaSqFt || 0), 0) ?? 0,
  validStarredProjects: (sector.starredProjects ?? []).filter((p: any) => p.title),
}));

const total = sectors.length;
---

<section class="bg-bone w-full py-40 lg:py-60" aria-labelledby="sectors-heading">
  <div class="mx-auto max-w-[1440px] px-6 lg:px-12">
    <div class="mb-32 grid gap-16 lg:mb-56 lg:grid-cols-[1fr_0.6fr] lg:gap-32">
      <div
        class="reveal flex flex-col items-center justify-center text-center lg:items-start lg:text-left"
      >
        <p class="text-charcoal/30 mb-10 text-[10px] font-medium tracking-[0.5em] uppercase">
          {section?.eyebrow}
        </p>
        <h2
          id="sectors-heading"
          class="text-charcoal text-6xl leading-[0.99] tracking-tight lg:text-[6.5rem]"
          set:html={section?.headline}
        />
      </div>

      <div
        class="reveal flex flex-col items-center gap-10 text-center lg:items-end lg:justify-end lg:pt-12 lg:text-right"
      >
        <p
          class="text-charcoal/60 text-[10px] leading-loose font-semibold tracking-[0.25em] uppercase sm:text-xs"
        >
          {section?.subheading}
        </p>
        <div class="flex w-full justify-center lg:justify-end">
          <Cta
            text={section?.ctaLabel}
            invert={true}
            isContact={true}
            contactContext="How can we assist you?"
          />
        </div>
      </div>
    </div>
  </div>

  <div class="reveal group/sector-slider relative mt-24 lg:mt-36">
    <div class="relative mx-auto w-full lg:max-w-[1800px]">
      {/* Floating Navigation — Centered on Image Plane */}
      <div
        class="pointer-events-none absolute inset-x-0 top-0 z-30 h-[calc(86vw*8/7)] sm:h-[calc(56vw*8/7)] lg:h-[calc(31vw*8/7)] xl:h-[calc(24.5vw*8/7)]"
      >
        {
          ["prev", "next"].map((dir) => (
            <button
              id={`sector-${dir}`}
              aria-label={`${dir === "prev" ? "Previous" : "Next"} sector`}
              disabled={dir === "prev"}
              class={[
                "pointer-events-auto absolute top-0 bottom-0 flex items-center opacity-0 transition-all duration-500",
                "group-hover/sector-slider:opacity-100 disabled:pointer-events-none! disabled:opacity-0!",
                dir === "prev"
                  ? "from-bone/70 left-0 w-20 justify-start bg-linear-to-r to-transparent px-4 sm:w-32 lg:px-8"
                  : "from-bone/70 right-0 w-20 justify-end bg-linear-to-l to-transparent px-4 sm:w-32 lg:px-8",
              ].join(" ")}
            >
              <div class="bg-charcoal/90 text-bone hover:bg-charcoal flex h-12 w-12 items-center justify-center rounded-full shadow-lg backdrop-blur-md transition-all hover:scale-105 active:scale-95">
                {dir === "prev" ? (
                  <Icon name="ph:arrow-left-light" class="h-5 w-5" />
                ) : (
                  <Icon name="ph:arrow-right-light" class="h-5 w-5" />
                )}
              </div>
            </button>
          ))
        }
      </div>

      <div
        id="sectors-slider"
        class="flex snap-x snap-mandatory scroll-px-6 items-start gap-4 overflow-x-auto scroll-smooth px-6 pb-12 [-ms-overflow-style:none] [scrollbar-width:none] sm:scroll-px-0 sm:gap-5 sm:px-8 lg:gap-6 lg:px-12 2xl:px-32 [&::-webkit-scrollbar]:hidden"
        aria-label="Sector slider"
      >
        {
          sectors.map((sector: any, index: number) => (
            <article class="group border-charcoal/10 w-[86vw] shrink-0 snap-center border bg-white first:snap-start last:snap-end sm:w-[56vw] lg:w-[31vw] xl:w-[24.5vw]">
              <a href={`/sectors/${sector.slug}`} class="block">
                {/* Image & Overlay Pattern from Portfolio.astro */}
                <div class="bg-charcoal relative aspect-7/8 overflow-hidden">
                  {sector.image && (
                    <img
                      src={imageUrl(sector.image, { width: 960, height: 1100 })}
                      alt={sector.title}
                      class="h-full w-full object-cover transition-all duration-[2.2s] ease-[cubic-bezier(0.19,1,0.22,1)] group-hover:scale-[1.04]"
                      loading="lazy"
                    />
                  )}
                  <div class="from-charcoal/80 via-charcoal/20 absolute inset-0 bg-linear-to-t to-transparent" />

                  <div class="absolute inset-x-0 top-0 p-5 lg:p-6">
                    <p class="text-bone/50 text-[10px] tracking-[0.32em] uppercase">
                      {String(index + 1).padStart(2, "0")} / {String(total).padStart(2, "0")}
                    </p>
                  </div>

                  <div class="absolute inset-x-0 bottom-10 p-6 lg:p-7">
                    <h3 class="text-bone mb-4 text-2xl leading-tight lg:text-4xl">
                      {sector.title}
                    </h3>
                    <p class="text-bone/60 text-[10px] font-semibold tracking-[0.25em] uppercase">
                      {sector.menuTagline || sector.homeHeadline}
                    </p>
                  </div>
                </div>

                {/* Footer Pattern from Portfolio.astro */}
                <div class="px-6 py-5 lg:px-7 lg:py-6">
                  {sector.validStarredProjects.length > 0 && (
                    <div class="my-6">
                      <p class="text-charcoal/50 mb-4 text-[9px] font-bold tracking-[0.24em] uppercase">
                        Significant Commissions
                      </p>
                      <ul class="flex flex-col gap-3" role="list">
                        {sector.validStarredProjects.map((project: any) => (
                          <li class="group/proj">
                            <a
                              href={`/projects/${project.slug}`}
                              class="flex items-center justify-between gap-4"
                            >
                              <span class="text-charcoal/60 group-hover/proj:text-charcoal block truncate text-[11px] leading-tight font-semibold tracking-widest uppercase transition-colors">
                                {project.title}
                              </span>
                              <span class="text-charcoal/30 shrink-0 text-[8px] tracking-[0.25em] uppercase">
                                {project.city}
                              </span>
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const slider = document.getElementById("sectors-slider") as HTMLElement;
    const prevBtn = document.getElementById("sector-prev") as HTMLButtonElement;
    const nextBtn = document.getElementById("sector-next") as HTMLButtonElement;
    if (!slider || !prevBtn || !nextBtn) return;

    // Cache scroll amount — recalculate only on resize
    let scrollAmount = 0;
    const calcScrollAmount = () => {
      const card = slider.querySelector("article") as HTMLElement;
      if (card) scrollAmount = card.offsetWidth + parseFloat(getComputedStyle(slider).gap || "0");
    };
    calcScrollAmount();
    window.addEventListener("resize", calcScrollAmount, { passive: true });

    // Boundary detection via IntersectionObserver
    const observer = new IntersectionObserver(
      (entries) =>
        entries.forEach((e) => {
          const el = e.target as HTMLElement;
          if ("first" in el.dataset) prevBtn.disabled = e.isIntersecting;
          if ("last" in el.dataset) nextBtn.disabled = e.isIntersecting;
        }),
      { root: slider, threshold: 0.9 },
    );
    const firstCard = slider.querySelector("[data-first]");
    const lastCard = slider.querySelector("[data-last]");
    if (firstCard) observer.observe(firstCard);
    if (lastCard) observer.observe(lastCard);

    // Scroll logic with hold-to-scroll
    const scroll = (dir: "left" | "right") =>
      slider.scrollBy({
        left: dir === "left" ? -scrollAmount : scrollAmount,
        behavior: "smooth",
      });

    let holdTimeout: ReturnType<typeof setTimeout> | null = null;
    let scrollInterval: ReturnType<typeof setInterval> | null = null;

    const stop = () => {
      clearTimeout(holdTimeout!);
      clearInterval(scrollInterval!);
      holdTimeout = scrollInterval = null;
    };

    const start = (dir: "left" | "right") => {
      stop();
      scroll(dir);
      holdTimeout = setTimeout(() => {
        scrollInterval = setInterval(() => {
          const btn = dir === "left" ? prevBtn : nextBtn;
          btn.disabled ? stop() : scroll(dir);
        }, 300);
      }, 400);
    };

    prevBtn.addEventListener("pointerdown", (e) => {
      if (e.button === 0) start("left");
    });
    nextBtn.addEventListener("pointerdown", (e) => {
      if (e.button === 0) start("right");
    });
    window.addEventListener("pointerup", stop);
    window.addEventListener("pointercancel", stop);
  });
</script>
