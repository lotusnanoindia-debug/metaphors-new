---
import Cta from "./Cta.astro";
import { client, SECTORS_QUERY } from "../lib/sanity";

interface Props {
  section?: any;
}

const { section } = Astro.props;

// Fetch data at build time
const rawSectors = await client.fetch(SECTORS_QUERY);

// 1. Aggregate Sectors
const sectors = rawSectors
  .map((s: any) => ({
    label: s.title,
    sqft:
      s.projects?.reduce((sum: number, p: any) => sum + (p.areaSqFt || 0), 0) ??
      0,
  }))
  .filter((s: any) => s.sqft > 0);

// Grand total
const totalSqFt = sectors.reduce((sum: number, s: any) => sum + s.sqft, 0);

// Formatting for monumental display
const totalLakhs = totalSqFt / 100_000;
const formattedTotal =
  totalLakhs >= 100
    ? `${(totalLakhs / 100).toFixed(2)} Crore`
    : `${totalLakhs.toFixed(0)} Lakh`;

const intlTotalSqFt = `${(totalSqFt / 1_000_000).toFixed(1)} Million`;
const intlTotalSqMt = `${((totalSqFt * 0.0929) / 1_000_000).toFixed(2)} Million`;
---

<section
  class="relative w-full bg-[#f2f1ec] py-24 md:py-40 lg:py-56 overflow-hidden"
>
  {/* Architectural Grid Layer */}
  <div
    class="absolute inset-0 opacity-[0.03] pointer-events-none"
    style="background-image: radial-gradient(circle, #222 1px, transparent 1px); background-size: 80px 80px; transform: translateY(var(--grid-y, 0))"
    id="scale-grid"
  >
  </div>

  <div class="max-w-[1800px] mx-auto px-6 lg:px-12 relative z-10">
    <div class="flex flex-col items-center text-center">
      <h2
        class="text-6xl leading-[0.99] tracking-tight text-charcoal lg:text-[6.5rem] mb-28 max-w-5xl reveal"
        style="transition-delay: 100ms"
        set:html={section?.scaleHeadline}
      />

      {/* Monumental Counter */}
      <div
        class="mb-20 sm:mb-12 lg:mb-20 reveal"
        style="transition-delay: 200ms"
      >
        <div class="relative inline-block">
          <span
            id="monumental-value"
            class="text-[140px] lg:text-[280px] leading-[0.7] tracking-tighter text-charcoal block"
          >
            {formattedTotal.split(" ")[0]} +
          </span>

          <p
            class="mt-12 text-xs font-semibold uppercase tracking-[0.5em] text-charcoal/50"
          >
            {formattedTotal.split(" ").slice(1).join(" ")} Sq Ft - Delivered
          </p>
        </div>
      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-10 gap-16 items-center w-full max-w-7xl mb-20 lg:mb-32"
      >
        <div
          class="order-2 lg:order-1 lg:col-span-6 text-center lg:text-left reveal"
          style="transition-delay: 300ms"
        >
          <div class="space-y-8">
            <p
              class="text-base lg:text-2xl text-charcoal/60 font-light leading-relaxed max-w-2xl mx-auto lg:mx-0"
              set:html={section?.scaleBody}
            />
            <div class="pt-4 flex flex-col items-center lg:items-start gap-8">
              <a
                href="/studio#partners"
                class="lg:hidden group/partners font-semibold flex items-center gap-3 text-base text-charcoal/40 transition-all duration-300 hover:text-charcoal"
              >
                Meet the Partners
                <svg
                  viewBox="0 0 24 24"
                  class="h-4 w-4 fill-none stroke-current stroke-[1.5] transition-transform duration-300 group-hover/partners:translate-x-1.5"
                >
                  <path d="M5 12h14M12 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <div
          class="order-1 lg:order-2 lg:col-span-4 flex flex-col items-center lg:items-end gap-12 reveal"
          style="transition-delay: 450ms"
        >
          <div class="text-center lg:text-right space-y-4">
            <div>
              <p
                class="text-[10px] uppercase tracking-widest text-charcoal/40 mb-1"
              >
                = Sq Ft + (Imperial)
              </p>
              <p
                class="text-3xl text-charcoal/70 transition-all hover:text-charcoal cursor-default"
              >
                {intlTotalSqFt}
              </p>
            </div>
            <div>
              <p
                class="text-[10px] uppercase tracking-widest text-charcoal/40 mb-1"
              >
                = Sq Metres + (Metric)
              </p>
              <p
                class="text-3xl text-charcoal/70 transition-all hover:text-charcoal cursor-default"
              >
                {intlTotalSqMt}
              </p>
            </div>
          </div>
          <div class="hidden lg:flex flex-col items-center lg:items-end gap-8">
            <a
              href="/studio#partners"
              class="group/partners font-semibold flex items-center gap-3 text-base text-charcoal/40 transition-all duration-300 hover:text-charcoal"
            >
              Meet the Partners
              <svg
                viewBox="0 0 24 24"
                class="h-4 w-4 fill-none stroke-current stroke-[1.5] transition-transform duration-300 group-hover/partners:translate-x-1.5"
              >
                <path d="M5 12h14M12 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>

      {/* Philosophy & CTA (Underneath all, Centred) */}
      <div
        class="flex flex-col items-center text-center space-y-12 reveal"
        style="transition-delay: 500ms"
      >
        <p
          class="text-xs font-semibold uppercase tracking-[0.3em] text-charcoal/50 max-w-xl"
        >
          Every defining project begins with an idea.
        </p>
        <Cta
          text="Discuss Your Idea"
          invert={true}
          isContact={true}
          contactContext="How can we assist you?"
        />
      </div>
    </div>
  </div>
</section>

<script>
  // Advanced Parallax & Kinetic Effects
  const ghost = document.getElementById("ghost-scale");
  const grid = document.getElementById("scale-grid");
  const dash = document.getElementById("drafting-dash");
  const section = document.querySelector("section");

  if (ghost && grid && dash && section) {
    window.addEventListener(
      "scroll",
      () => {
        const rect = section.getBoundingClientRect();
        const scrolled = window.scrollY;

        // Only run when section is in view to save perf
        if (rect.top < window.innerHeight && rect.bottom > 0) {
          // 1. Ghost Big Number Parallax (Slow)
          const ghostVal = (scrolled * 0.1) % 500;
          ghost.style.setProperty("--scroll-y", `${ghostVal * -0.3}px`);

          // 2. Blueprint Grid Parallax (Fast)
          grid.style.setProperty("--grid-y", `${scrolled * 0.15}px`);

          // 3. Drafting Dash Progress
          const progress = Math.min(
            100,
            Math.max(
              0,
              (Math.abs(rect.top - window.innerHeight) / section.offsetHeight) *
                100,
            ),
          );
          dash.style.setProperty("--dash-width", `${progress * 0.8}%`);
        }
      },
      { passive: true },
    );
  }
</script>
