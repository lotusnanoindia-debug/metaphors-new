---
import { DollarSign, Clock, Target } from "lucide-react";

const items = [
  {
    icon: DollarSign,
    title: "Cost Control",
    desc: "Eliminating bad investments early through rigorous pre-design feasibility studies and real-time budget tracking.",
    link: "Process"
  },
  {
    icon: Clock,
    title: "Regulatory Speed",
    desc: "Navigating complex zoning and permitting to accelerate your speed to market by weeks or months.",
    link: "Timeline"
  },
  {
    icon: Target,
    title: "Feasibility",
    desc: "Reducing change orders through precise documentation, clash detection, and proactive contractor coordination.",
    link: "Standards"
  }
];
---

<section class="w-full py-20 lg:py-32 bg-white">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div class="mb-16 max-w-3xl reveal">
      <span class="block text-xs font-medium uppercase tracking-[0.2em] text-black/40 mb-4">Risk Management</span>
      <h2 class="text-4xl lg:text-6xl font-serif text-black leading-tight">
        Protecting your investment<br/>
        <span class="text-black/40 italic">before groundbreak.</span>
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {items.map((item) => (
        <div class="flex flex-col bg-[#F8F9FA] p-10 h-full transition-colors hover:bg-[#F0F2F5] reveal">
          <div class="mb-8 text-black">
            <item.icon size={32} strokeWidth={1} />
          </div>
          <h3 class="text-xl font-medium uppercase tracking-wide text-black mb-4 font-sans">{item.title}</h3>
          <p class="text-black/60 leading-relaxed font-light mb-8 flex-grow">
            {item.desc}
          </p>
          <div>
            <a class="inline-flex items-center text-xs font-medium uppercase tracking-widest text-black border-b border-black pb-1 hover:border-transparent transition-all" href="#">
              {item.link}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
