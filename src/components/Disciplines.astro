---
import Cta from "./Cta.astro";
import { client, ALL_DISCIPLINES_WITH_AREA_QUERY, imageUrl } from "../lib/sanity";

interface Props {
  section?: any;
}

const { section } = Astro.props;

// Fetch data at build time
const rawDisciplines = await client.fetch(ALL_DISCIPLINES_WITH_AREA_QUERY);

// Aggregate Disciplines
const disciplines = rawDisciplines
  .map((d: any) => {
    const sqft = d.projects?.reduce((sum: number, p: any) => sum + (p.areaSqFt || 0), 0) ?? 0;
    const lakhs = sqft / 100_000;
    const metric = lakhs >= 100 ? `${(lakhs / 100).toFixed(1)} Cr` : `${lakhs.toFixed(0)} Lakh`;
    const intl = `${(sqft / 1_000_000).toFixed(1)}M Sq Ft`;

    return {
      title: d.title,
      slug: d.slug,
      image: d.mainImage,
      sqft,
      display: `${metric} / ${intl}`,
    };
  })
  .filter((d: any) => d.sqft > 0)
  .sort((a, b) => b.sqft - a.sqft);
---

<section class="bg-bone relative w-full overflow-hidden py-24 lg:py-48">
  {/* Discipline Header - Constrained to 1440px to match Evidence/Sectors pattern */}
  <div class="relative z-10 mx-auto mb-24 max-w-[1440px] px-6 lg:mb-40 lg:px-12">
    <div
      class="reveal grid gap-16 lg:grid-cols-[1fr_0.6fr] lg:gap-32"
      style="transition-delay: 450ms"
    >
      <div
        class="flex flex-col items-center justify-center text-center lg:items-start lg:text-left"
      >
        <p class="text-charcoal/30 mb-10 text-[10px] font-medium tracking-[0.5em] uppercase">
          {section?.eyebrow} ({disciplines.length.toString().padStart(2, "0")})
        </p>
        <h2
          class="text-charcoal text-6xl leading-[0.99] tracking-tight lg:text-[6.5rem]"
          set:html={section?.headline}
        />
      </div>

      <div
        class="flex flex-col items-center justify-center gap-10 text-center lg:items-end lg:pt-12 lg:text-right"
      >
        <p
          class="text-charcoal/60 text-[10px] leading-loose font-semibold tracking-[0.25em] uppercase sm:text-xs"
          set:html={section?.subheading}
        />
        <div class="flex w-full justify-center lg:justify-end">
          <Cta
            text={section?.ctaLabel}
            invert={true}
            isContact={true}
            contactContext="Queries about our Disciplines?"
          />
        </div>
      </div>
    </div>
  </div>

  {/* Discipline Cards Grid - Expanded to 1800px for breadth */}
  <div class="relative z-10 mx-auto max-w-[1800px] px-6 lg:px-12">
    <div
      class="reveal delay-500ms grid w-full grid-cols-2 gap-x-8 gap-y-16 text-left lg:grid-cols-3"
    >
      {
        disciplines.map((d: any) => (
          <a href={`/disciplines/${d.slug}`} class="group relative block transition-all">
            {/* Image Box - Square on mobile/tablet for improved verticality in 2-column grid, 16:9 on desktop */}
            <div class="bg-charcoal/5 border-charcoal/5 mb-8 aspect-square w-full overflow-hidden border">
              {d.image ? (
                <img
                  src={imageUrl(d.image, { width: 800, height: 800 })}
                  alt={d.title}
                  class="h-full w-full object-cover contrast-104 grayscale-65 saturate-88 transition-all duration-1000 group-hover:scale-105 group-hover:contrast-100 group-hover:grayscale-0 group-hover:saturate-100"
                />
              ) : (
                <div class="text-charcoal/20 flex h-full w-full items-center justify-center text-[10px] tracking-widest uppercase italic">
                  {d.title} Hero
                </div>
              )}
            </div>

            <div class="border-charcoal/10 group-hover:border-charcoal/40 border-t-0 pt-0 transition-all duration-1000 sm:border-t sm:pt-8">
              <p class="text-charcoal/30 group-hover:text-charcoal/80 mb-2 text-[10px] font-bold tracking-widest uppercase transition-all sm:text-[11px]">
                {d.display}
              </p>
              <h3 class="text-charcoal/80 hover:text-charcoal text-xl lg:text-3xl">{d.title}</h3>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
