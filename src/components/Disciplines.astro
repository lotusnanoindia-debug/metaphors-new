---
import Cta from "./Cta.astro";
import {
  client,
  ALL_DISCIPLINES_WITH_AREA_QUERY,
  imageUrl,
} from "../lib/sanity";

interface Props {
  section?: any;
}

const { section } = Astro.props;

// Fetch data at build time
const rawDisciplines = await client.fetch(ALL_DISCIPLINES_WITH_AREA_QUERY);

// Aggregate Disciplines
const disciplines = rawDisciplines
  .map((d: any) => {
    const sqft =
      d.projects?.reduce((sum: number, p: any) => sum + (p.areaSqFt || 0), 0) ??
      0;
    const lakhs = sqft / 100_000;
    const metric =
      lakhs >= 100
        ? `${(lakhs / 100).toFixed(1)} Cr`
        : `${lakhs.toFixed(0)} Lakh`;
    const intl = `${(sqft / 1_000_000).toFixed(1)}M Sq Ft`;

    return {
      title: d.title,
      slug: d.slug,
      image: d.mainImage,
      sqft,
      display: `${metric} / ${intl}`,
    };
  })
  .filter((d: any) => d.sqft > 0)
  .sort((a, b) => b.sqft - a.sqft);
---

<section class="relative w-full bg-bone py-24 lg:py-48 overflow-hidden">
  {
    /* Discipline Header - Constrained to 1440px to match Evidence/Sectors pattern */
  }
  <div
    class="max-w-[1440px] mx-auto px-6 lg:px-12 relative z-10 mb-24 lg:mb-40"
  >
    <div
      class="grid gap-16 lg:grid-cols-[1fr_0.6fr] lg:gap-32 reveal"
      style="transition-delay: 450ms"
    >
      <div
        class="flex flex-col items-center text-center lg:items-start lg:text-left justify-center"
      >
        <p
          class="mb-10 text-[10px] font-medium uppercase tracking-[0.5em] text-charcoal/30"
        >
          {section?.eyebrow} ({disciplines.length.toString().padStart(2, "0")})
        </p>
        <h2
          class="text-6xl leading-[0.99] tracking-tight text-charcoal lg:text-[6.5rem]"
          set:html={section?.headline}
        />
      </div>

      <div
        class="flex flex-col items-center text-center lg:items-end lg:text-right justify-center lg:pt-12 gap-10"
      >
        <p
          class="text-[10px] sm:text-xs font-semibold leading-loose tracking-[0.25em] text-charcoal/60 uppercase"
          set:html={section?.subheading}
        />
        <div class="flex justify-center lg:justify-end w-full">
          <Cta
            text={section?.ctaLabel}
            invert={true}
            isContact={true}
            contactContext="Queries about our Disciplines?"
          />
        </div>
      </div>
    </div>
  </div>

  {/* Discipline Cards Grid - Expanded to 1800px for breadth */}
  <div class="max-w-[1800px] mx-auto px-6 lg:px-12 relative z-10">
    <div
      class="w-full grid grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16 text-left reveal delay-500ms"
    >
      {
        disciplines.map((d: any) => (
          <a
            href={`/disciplines/${d.slug}`}
            class="group relative block transition-all"
          >
            {/* Image Box - Square on mobile/tablet for improved verticality in 2-column grid, 16:9 on desktop */}
            <div class="aspect-square w-full overflow-hidden bg-charcoal/5 mb-8 border border-charcoal/5">
              {d.image ? (
                <img
                  src={imageUrl(d.image, { width: 800, height: 800 })}
                  alt={d.title}
                  class="h-full w-full object-cover transition-all duration-1000 grayscale-65 saturate-88 contrast-104 group-hover:scale-105 group-hover:grayscale-0 group-hover:saturate-100 group-hover:contrast-100"
                />
              ) : (
                <div class="flex h-full w-full items-center justify-center text-[10px] italic uppercase tracking-widest text-charcoal/20">
                  {d.title} Hero
                </div>
              )}
            </div>

            <div class="border-t-0 sm:border-t border-charcoal/10 pt-0 sm:pt-8 transition-all group-hover:border-charcoal/40 duration-1000">
              <p class="mb-2 sm:text-[11px] text-[10px] font-bold uppercase tracking-widest text-charcoal/30 transition-all group-hover:text-charcoal/80">
                {d.display}
              </p>
              <h3 class="text-xl lg:text-3xl text-charcoal/80 hover:text-charcoal">
                {d.title}
              </h3>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
