---
import Icon from "./Icon.astro";
import { client, SECTORS_QUERY, DISCIPLINES_QUERY } from "../lib/sanity";

const sectorsData = await client.fetch(SECTORS_QUERY);
const disciplinesData = await client.fetch(DISCIPLINES_QUERY);

const Portfolio = sectorsData.map((sector: any) => ({
  name: sector.title,
  href: `/sectors/${sector.slug}`,
}));

const Expertise = disciplinesData.map((d: any) => ({
  name: d.title,
  href: `/disciplines/${d.slug}`,
}));

const Practice = [
  { name: "Engagement", href: "/engagement" },
  { name: "About", href: "/about" },
  { name: "Contact", href: "/contact" },
];

const Legal = [
  { name: "Terms of Engagement", href: "/terms" },
  { name: "Privacy Policy", href: "/privacy" },
];
---

<footer class="bg-charcoal text-bone pt-24 pb-12">
  <div class="mx-auto max-w-[1440px] px-6 lg:px-12">
    <div class="mb-24 grid grid-cols-1 gap-16 md:grid-cols-2 lg:grid-cols-5 lg:gap-8">
      {/* Column 1: Studio Info */}
      <div class="pr-12 lg:col-span-2">
        <div class="mb-8 flex items-center gap-3">
          <img
            alt="Metaphors Design Logo"
            class="h-7 w-auto transition-transform duration-500 hover:scale-105"
            src="/metaphors-design-logo.svg"
            loading="lazy"
            decoding="async"
          />
          <span class="text-bone text-xl font-medium tracking-tight">metaphors design</span>
        </div>
        <p class="text-bone/40 mb-8 max-w-sm text-sm leading-relaxed">
          Four decades of shaping India's corporate, civic, and residential landscape. A practice
          built on architectural precision, long-term stewardship, and measured ambition.
        </p>

        <div class="mt-[2px] mb-8 space-y-3">
          <div class="flex items-start gap-3">
            <Icon name="ph:map-pin-light" class="text-bone/40 h-[18px] w-[18px] shrink-0" />
            <a
              href="https://maps.app.goo.gl/Pp2mLdzqZynSaU5b9"
              target="_blank"
              rel="noopener noreferrer"
              class="text-bone/60 cursor-pointer text-[13px] transition-colors hover:text-white"
            >
              Studio: Pune, India
            </a>
          </div>

          <div class="flex items-start gap-3">
            <Icon name="ph:envelope-light" class="text-bone/40 h-[18px] w-[18px] shrink-0" />
            <a
              href="#"
              onclick="window.location.href='mailto:' + 'moc.ngised-srohpatem@ofni'.split('').reverse().join(''); return false;"
              class="text-bone/60 inline-block text-[13px] transition-colors hover:text-white"
              aria-label="Email us"
            >
              <span style="unicode-bidi: bidi-override; direction: rtl;"
                >moc.ngised-srohpatem@ofni</span
              >
            </a>
          </div>

          <div class="flex items-start gap-3">
            <Icon name="ph:phone-light" class="text-bone/40 h-[18px] w-[18px] shrink-0" />
            <div class="text-bone/60 flex flex-wrap gap-x-2 text-[13px]">
              <a href="tel:+919665355522" class="transition-colors hover:text-white">
                (+91) 96653 55522
              </a>
              <span class="text-bone/20">/</span>
              <a href="tel:+919822279173" class="transition-colors hover:text-white">
                (+91) 98222 79173
              </a>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-6">
          <a
            href="https://www.facebook.com/metaphorsdesign/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="text-white/80 transition-colors duration-300 hover:text-[#1877F2]"
          >
            <Icon name="ph:facebook-logo-fill" class="h-8 w-8" />
          </a>
          <a
            href="https://linkedin.com/company/metaphors-design"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-white/80 transition-colors duration-300 hover:text-[#0077B5]"
          >
            <Icon name="ph:linkedin-logo-fill" class="h-8 w-8" />
          </a>
          <a
            href="https://instagram.com/metaphorspune"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="text-white/80 transition-colors duration-300 hover:text-[#E4405F]"
          >
            <Icon name="ph:instagram-logo-fill" class="h-8 w-8" />
          </a>
        </div>
      </div>

      {/* Column 2: Portfolio (Sectors) */}
      <div>
        <h4 class="mb-8 text-[10px] font-medium tracking-[0.4em] text-white/50 uppercase">
          Portfolio
        </h4>
        <ul class="space-y-4">
          {
            Portfolio.map((link: any) => (
              <li>
                <a
                  href={link.href}
                  class="text-bone/60 inline-block text-sm transition-colors duration-300 hover:text-white"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Column 3: Expertise (Disciplines) */}
      <div>
        <h4 class="mb-8 text-[10px] font-medium tracking-[0.4em] text-white/50 uppercase">
          Studio Disciplines
        </h4>
        <ul class="space-y-4">
          {
            Expertise.map((link: any) => (
              <li>
                <a
                  href={link.href}
                  class="text-bone/60 inline-block text-sm transition-colors duration-300 hover:text-white"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Column 4: Practice */}
      <div>
        <h4 class="mb-8 text-[10px] font-medium tracking-[0.4em] text-white/50 uppercase">
          Practice
        </h4>
        <ul class="space-y-4">
          {
            Practice.map((link: any) => (
              <li>
                <a
                  href={link.href}
                  class="text-bone/60 inline-block text-sm transition-colors duration-300 hover:text-white"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    {/* Footer Bottom Archive */}
    <div
      class="flex flex-col items-center justify-between gap-8 border-t border-white/5 pt-12 md:flex-row"
    >
      <div class="flex gap-8">
        {
          Legal.map((link) => (
            <a
              href={link.href}
              class="luxury-transition micro-hover pb-1 text-[10px] font-medium tracking-[0.2em] text-white/30 uppercase hover:text-white/60"
            >
              {link.name}
            </a>
          ))
        }
      </div>
      <p
        class="text-center text-[10px] font-medium tracking-[0.2em] text-white/20 uppercase md:text-right"
      >
        © 2026 Metaphors Design.
      </p>
    </div>
  </div>
</footer>
