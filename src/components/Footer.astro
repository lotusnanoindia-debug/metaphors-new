---
import { Building2 } from "lucide-react";
---

<footer class="bg-black text-white pt-20 pb-10">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 lg:gap-24 mb-20 border-b border-white/10 pb-12">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center gap-3 mb-6">
          <div class="flex items-center justify-center size-8 bg-white text-black">
            <Building2 size={20} strokeWidth={1.5} />
          </div>
          <span class="text-2xl font-serif italic">Metaphors.</span>
        </div>
        <p class="text-white/60 font-light max-w-md text-lg">
          Architectural precision for the modern hospitality developer. Driven by data, defined by design.
        </p>
      </div>
      <div>
        <h4 class="font-bold text-xs uppercase tracking-widest text-white mb-6">Sitemap</h4>
        <ul class="space-y-4 text-sm text-white/60">
          <li><a class="hover:text-white transition-colors" href="#">Approach</a></li>
          <li><a class="hover:text-white transition-colors" href="#">Our Team</a></li>
          <li><a class="hover:text-white transition-colors" href="#">Careers</a></li>
          <li><a class="hover:text-white transition-colors" href="#">Insights</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-xs uppercase tracking-widest text-white mb-6">Contact</h4>
        <p class="text-sm text-white/60 mb-4 leading-relaxed">
          142 W 57th St<br/>
          New York, NY 10019
        </p>
        <a class="text-sm text-white hover:text-white/80 border-b border-white/30 pb-1" href="mailto:hello@metaphors.design">hello@metaphors.design</a>
      </div>
    </div>
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-xs text-white/40 uppercase tracking-wider">
        © 2024 Metaphors Design.
      </p>
      <div class="flex gap-8">
        <a class="text-xs text-white/40 hover:text-white uppercase tracking-wider" href="#">Privacy</a>
        <a class="text-xs text-white/40 hover:text-white uppercase tracking-wider" href="#">Terms</a>
      </div>
    </div>
  </div>
</footer>
