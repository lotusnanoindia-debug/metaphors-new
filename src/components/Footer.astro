---
import { Icon } from "astro-icon/components";

const footerLinks = {
  sectors: [
    { name: "Commerce & Retail", href: "/sectors/commerce-retail" },
    { name: "Hospitality & Leisure", href: "/sectors/hospitality-leisure" },
    {
      name: "Private & Collective Living",
      href: "/sectors/private-collective-living",
    },
    {
      name: "Institutional & Corporate",
      href: "/sectors/institutional-corporate",
    },
  ],
  company: [
    { name: "Strategic Approach", href: "/approach" },
    { name: "Selected Evidence", href: "/archive" },
    { name: "The Partnership", href: "/partnership" },
  ],
  legal: [
    { name: "Terms of Engagement", href: "/legal/terms" },
    { name: "Privacy Policy", href: "/legal/privacy" },
  ],
};
---

<footer class="bg-charcoal text-bone pt-24 pb-12">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 lg:gap-24 mb-24"
    >
      {/* Brand & Mission */}
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-8">
          <img
            alt="Metaphors Design Logo"
            class="h-8 w-auto"
            src="/logo-v1.png"
            loading="lazy"
            decoding="async"
          />
          <span class="text-xl font-medium tracking-tight lowercase text-bone"
            >metaphors design</span
          >
        </div>
        <p class="text-sm text-bone/40 leading-relaxed max-w-[280px]">
          Modern Indian Architecture. Designed for scale, environmental
          intelligence, and lasting civic impact.
        </p>
      </div>

      {/* Strategic Portfolio */}
      <div>
        <h4
          class="text-[10px] font-medium uppercase tracking-[0.3em] text-white/30 mb-8"
        >
          Portfolio
        </h4>
        <ul class="space-y-4">
          {
            footerLinks.sectors.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-bone/60 hover:text-white luxury-transition micro-hover pb-0.5"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Corporate Strategy */}
      <div>
        <h4
          class="text-[10px] font-medium uppercase tracking-[0.3em] text-white/30 mb-8"
        >
          Practice
        </h4>
        <ul class="space-y-4">
          {
            footerLinks.company.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-bone/60 hover:text-white luxury-transition micro-hover pb-0.5"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Global Inquiries */}
      <div>
        <h4
          class="text-[10px] font-medium uppercase tracking-[0.3em] text-white/30 mb-8"
        >
          Studio
        </h4>
        <p class="text-sm mb-6 leading-relaxed">
          Shambhu Vihar Society, Pallod Farms II,<br />
          Nankude Vasti, Aundh,<br />
          Pune, Maharashtra 411067<br />
          India
        </p>
        <div class="flex items-center gap-6">
          <a
            href="https://linkedin.com/company/metaphors-design"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-white/40 hover:text-white transition-colors"
          >
            <Icon name="mdi:linkedin" class="w-5 h-5" />
          </a>
          <a
            href="https://facebook.com/metaphorsdesign"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="text-white/40 hover:text-white transition-colors"
          >
            <Icon name="mdi:facebook" class="w-5 h-5" />
          </a>
          <a
            href="https://instagram.com/metaphorsdesign"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="text-white/40 hover:text-white transition-colors"
          >
            <Icon name="mdi:instagram" class="w-5 h-5" />
          </a>
        </div>
      </div>
    </div>

    {/* Footer Bottom Archive */}
    <div
      class="pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8"
    >
      <div class="flex gap-8">
        {
          footerLinks.legal.map((link) => (
            <a
              href={link.href}
              class="text-[10px] font-medium uppercase tracking-[0.2em] text-white/30 hover:text-white/60 luxury-transition micro-hover pb-1"
            >
              {link.name}
            </a>
          ))
        }
      </div>
      <p
        class="text-[10px] font-medium uppercase tracking-[0.2em] text-white/20 text-center md:text-right"
      >
        © 2026 Metaphors Design. All rights reserved.
      </p>
    </div>
  </div>
</footer>
