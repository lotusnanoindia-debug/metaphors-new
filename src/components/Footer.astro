---
import { Icon } from "astro-icon/components";

const footerLinks = {
  sectors: [
    { name: "Commerce & Retail", href: "#" },
    { name: "Hospitality & Leisure", href: "#" },
    { name: "Private & Collective Living", href: "#" },
    { name: "Institutional & Corporate", href: "#" },
  ],
  company: [
    { name: "Strategic Approach", href: "#" },
    { name: "Selected Evidence", href: "#" },
    { name: "The Partnership", href: "#" },
  ],
  legal: [
    { name: "Terms of Engagement", href: "#" },
    { name: "Privacy Policy", href: "#" },
  ],
};
---

<footer class="bg-charcoal text-bone pt-24 pb-12">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 lg:gap-24 mb-24"
    >
      {/* Brand & Mission */}
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-8">
          <img
            alt="Metaphors Design Logo"
            class="h-8 w-auto"
            src="/logo-v1.png"
          />
          <span class="text-xl font-semibold tracking-tight lowercase text-bone"
            >metaphors design</span
          >
        </div>
        <p class="text-sm text-bone/40 leading-relaxed max-w-[280px]">
          Architectural precision and execution certainty for high-stakes Indian
          developments. Designed for impact, engineered for yield.
        </p>
      </div>

      {/* Strategic Sectors */}
      <div>
        <h4
          class="text-[10px] font-bold uppercase tracking-[0.3em] text-white/30 mb-8"
        >
          Strategic Sectors
        </h4>
        <ul class="space-y-4">
          {
            footerLinks.sectors.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-bone/60 hover:text-white luxury-transition micro-hover pb-0.5"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Corporate Strategy */}
      <div>
        <h4
          class="text-[10px] font-bold uppercase tracking-[0.3em] text-white/30 mb-8"
        >
          Company Strategy
        </h4>
        <ul class="space-y-4">
          {
            footerLinks.company.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-bone/60 hover:text-white luxury-transition micro-hover pb-0.5"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Global Inquiries */}
      <div>
        <h4
          class="text-[10px] font-bold uppercase tracking-[0.3em] text-white/30 mb-8"
        >
          Asset Acquisition
        </h4>
        <p class="text-sm mb-6 leading-relaxed">
          Office 104, Global Business Hub,<br />
          Eon IT Park, Kharadi, Pune 411014.
        </p>
        <div class="flex items-center gap-6">
          <a href="#" class="text-white/40 hover:text-white transition-colors">
            <Icon name="mdi:linkedin" class="w-5 h-5" />
          </a>
          <a href="#" class="text-white/40 hover:text-white transition-colors">
            <Icon name="mdi:instagram" class="w-5 h-5" />
          </a>
        </div>
      </div>
    </div>

    {/* Footer Bottom Archive */}
    <div
      class="pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8"
    >
      <div class="flex gap-8">
        {
          footerLinks.legal.map((link) => (
            <a
              href={link.href}
              class="text-[10px] font-medium uppercase tracking-[0.2em] text-white/30 hover:text-white/60 luxury-transition micro-hover pb-1"
            >
              {link.name}
            </a>
          ))
        }
      </div>
      <p
        class="text-[10px] font-medium uppercase tracking-[0.2em] text-white/20 text-center md:text-right"
      >
        © 2026 Metaphors Design. All rights reserved. British English compliant.
      </p>
    </div>
  </div>
</footer>
