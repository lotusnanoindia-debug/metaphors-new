---
import Cta from "./Cta.astro";

interface Props {
  eyebrow?: string;
  headline?: string;
  tagline?: string;
  ctaText?: string;
  ctaUrl?: string;
  className?: string;
}

const {
  eyebrow = "COMMISSION STEWARDSHIP",
  headline = "Your next landmark begins here.",
  tagline = "Precision-led architecture for clients who refuse to compromise.<br class='hidden md:block' /> Every project begins with a focused conversation.",
  ctaText = "Start a Dialogue",
  ctaUrl = "/contact",
  className = "",
} = Astro.props;
---

<section
  class={`relative pb-32 pt-24 lg:pb-56 lg:pt-32 overflow-hidden bg-white border-t border-charcoal/5 ${className}`}
>
  <div
    class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10 flex justify-center"
  >
    <div class="max-w-3xl flex flex-col items-center text-center">
      {
        eyebrow && (
          <p class="text-[10px] font-medium uppercase tracking-[0.6em] text-charcoal/40 mb-10 reveal">
            {eyebrow}
          </p>
        )
      }

      <h2
        class="text-4xl lg:text-6xl font-serif italic tracking-tight text-charcoal leading-[1.2] mb-12 reveal capitalize"
        style="animation-delay: 200ms;"
      >
        {headline}
      </h2>

      <div
        class="flex flex-col items-center gap-12 w-full reveal"
        style="animation-delay: 400ms;"
      >
        <p 
          class="text-xl text-charcoal/60 leading-relaxed"
          set:html={tagline}
        />

        <div class="shrink-0 flex justify-center">
          <Cta text={ctaText} href={ctaUrl} />
        </div>
      </div>
    </div>
  </div>

  {/* Subtle Background Accent */}
  <div
    class="absolute top-0 right-0 w-1/3 h-full bg-charcoal/[0.02] -z-0 pointer-events-none"
  >
  </div>
</section>
