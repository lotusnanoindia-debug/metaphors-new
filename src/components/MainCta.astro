---
import Cta from "./Cta.astro";

interface Props {
  section?: any;
  className?: string;
  isContact?: boolean;
  contactContext?: string;
  discipline?: string;
}

const { section, className = "", isContact = false, contactContext, discipline } = Astro.props;
---

<section
  class={`relative pb-32 pt-24 lg:pb-56 lg:pt-32 overflow-hidden bg-white border-t border-charcoal/5 ${className}`}
>
  <div class="relative z-10 mx-auto flex max-w-7xl justify-center px-6 lg:px-12">
    <div class="flex max-w-3xl flex-col items-center text-center">
      {
        section?.eyebrow && (
          <p class="text-charcoal/40 reveal mb-10 text-[10px] font-medium tracking-[0.6em] uppercase">
            {section?.eyebrow}
          </p>
        )
      }

      <h2
        class="text-charcoal reveal mb-12 text-6xl leading-[0.99] tracking-tight capitalize lg:text-[6.5rem]"
        style="animation-delay: 200ms;"
        set:html={section?.headline}
      />

      <div class="reveal flex w-full flex-col items-center gap-12" style="animation-delay: 400ms;">
        <p class="text-charcoal/60 text-xl leading-relaxed" set:html={section?.tagline} />

        <div class="flex shrink-0 justify-center">
          <Cta
            text={section?.ctaLabel}
            href={section?.ctaUrl}
            invert={true}
            isContact={isContact}
            contactContext={contactContext}
            discipline={discipline}
          />
        </div>
      </div>
    </div>
  </div>

  {/* Subtle Background Accent */}
  <div class="bg-charcoal/2 pointer-events-none absolute top-0 right-0 z-0 h-full w-1/3"></div>
</section>
