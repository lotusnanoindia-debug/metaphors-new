---
import { imageUrl } from "../lib/sanity";

interface Props {
  section: any;
  subheading?: string;
  quotes: any[];
}

const { section, subheading, quotes } = Astro.props;
---

<section class="-mt-12 w-full px-6 pb-32 lg:mt-0 lg:px-12 lg:pb-48">
  <div class="reveal relative mx-auto max-w-[1440px]">
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-10 lg:gap-4">
      {/* Large Image column */}
      <div class="flex flex-col gap-12 lg:col-span-7">
        {/* Studio Intro — big editorial lead */}
        {
          subheading && (
            <div class="reveal mx-auto max-w-2xl text-center lg:mx-0 lg:text-left">
              <p class="text-charcoal/30 mb-4 hidden text-[10px] font-bold tracking-[0.4em] uppercase lg:block">
                {section?.contextEyebrow}
              </p>
              <p class="text-charcoal/90 text-2xl leading-[1.15] font-light tracking-tight lg:text-4xl">
                {subheading}
              </p>
            </div>
          )
        }
        <div
          class="group/stature-lg relative h-[60vh] overflow-hidden contrast-104 grayscale-65 saturate-88 transition-all duration-1000 hover:contrast-100 hover:grayscale-0 hover:saturate-100 lg:h-[60vh]"
        >
          {/* Footnote */}
          <div class="pointer-events-none absolute bottom-0 left-0 z-10">
            <div
              class="bg-bone/50 group-hover/stature-lg:bg-bone/90 origin-bottom-left translate-x-10 -translate-y-10 border border-white/10 px-8 py-4 backdrop-blur-sm transition-all duration-1000 group-hover/stature-lg:border-white/20 group-hover/stature-lg:backdrop-blur-xl"
            >
              <p
                class="text-charcoal text-[10px] font-semibold tracking-[0.5em] whitespace-nowrap uppercase transition-all duration-1000"
              >
                {section?.statureImage?.caption}
              </p>
            </div>
          </div>

          {
            section?.statureImage && (
              <img
                alt={section.statureImage?.alt}
                class="cubic-bezier(0.19, 1, 0.22, 1) h-full w-full object-cover object-center transition-transform duration-[3s] group-hover/stature-lg:scale-[1.02]"
                loading="lazy"
                decoding="async"
                src={imageUrl(section.statureImage, { width: 1000 })}
              />
            )
          }
        </div>
      </div>

      {/* Secondary Column - Dialogue & Pressed Context */}
      <div
        class="group/stature-sm bg-charcoal reveal relative h-auto overflow-hidden lg:col-span-3 lg:h-[65vh]"
        style="transition-delay: 200ms"
      >
        {/* The Image (Backdrop) */}
        {
          section?.precisionImage && (
            <img
              alt={section.precisionImage?.alt}
              class="cubic-bezier(0.19, 1, 0.22, 1) absolute inset-0 h-full w-full object-cover object-center opacity-60 grayscale transition-all duration-[2s] group-hover/stature-sm:scale-110 group-hover/stature-sm:opacity-80 group-hover/stature-sm:grayscale-0"
              loading="lazy"
              decoding="async"
              src={imageUrl(section.precisionImage, { width: 800 })}
            />
          )
        }

        {/* The Dialogue Overlay */}
        <div
          class="from-charcoal via-charcoal/60 relative z-10 flex flex-col justify-end gap-12 bg-linear-to-t to-transparent p-8 pt-16 lg:absolute lg:inset-0 lg:p-10"
        >
          <div class="relative grid h-full overflow-hidden text-center">
            {
              quotes.map((item: any, idx: number) => (
                <div
                  class={`press-quote col-start-1 row-start-1 flex flex-col justify-end transition-opacity duration-1000 ${idx === 0 ? "opacity-100" : "opacity-0"}`}
                  data-index={idx}
                >
                  <p class="mb-8 text-2xl leading-snug font-light tracking-tight text-white italic md:text-3xl">
                    "{item.quote}"
                  </p>

                  <div class="flex h-5 items-center justify-center">
                    {item.logo ? (
                      <img
                        src={imageUrl(item.logo, { height: 40 })}
                        alt={item.publication}
                        class="h-full w-auto opacity-60 brightness-0 grayscale invert"
                      />
                    ) : (
                      <span class="text-right text-[10px] font-bold tracking-[0.25em] text-white/60 uppercase">
                        {item.publication}
                      </span>
                    )}
                  </div>
                </div>
              ))
            }
          </div>

          <div class="flex items-center justify-between border-t border-white/10 pt-8">
            <div>
              <p class="tracking-[0.3 em] text-[10px] font-bold text-white/30 uppercase">
                {section?.pressEyebrow}
              </p>
              <p class="mt-1 text-[10px] text-white/50">
                {section?.pressSubEyebrow}
              </p>
            </div>

            <a
              href={section?.pressCtaUrl}
              class="group/link flex items-center gap-2 text-[10px] font-bold tracking-[0.3em] text-white/60 uppercase transition-colors duration-300 hover:text-white"
            >
              {section?.pressCtaLabel}
              <span
                class="block h-px w-4 bg-white/20 transition-all duration-500 group-hover/link:w-8 group-hover/link:bg-white"
              ></span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const quotes = document.querySelectorAll(".press-quote");
  if (quotes.length > 1) {
    let currentIndex = 0;
    setInterval(() => {
      quotes[currentIndex].classList.remove("opacity-100");
      quotes[currentIndex].classList.add("opacity-0");
      currentIndex = (currentIndex + 1) % quotes.length;
      quotes[currentIndex].classList.remove("opacity-0");
      quotes[currentIndex].classList.add("opacity-100");
    }, 6000); // 6 second interval for a slow, refined feel
  }
</script>
