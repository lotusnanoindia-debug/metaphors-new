---
const { eyebrow, headline, headlineAccent, headlineTagline, ctaLabel, ctaUrl } =
  Astro.props;
---

<section class="relative w-full pt-48 pb-24 lg:pt-56 lg:pb-32">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div class="max-w-5xl mx-auto flex flex-col items-center text-center">
      <h1
        class="font-medium leading-[0.88] tracking-[-0.045em] text-[clamp(3.8rem,11vw,9rem)] lg:text-[clamp(3.8rem,9vw,8rem)] select-none mb-16 reveal"
      >
        <span class="block text-neutral-950">{headline}</span>

        <span
          class="block text-transparent bg-clip-text animate-sheen will-change-[background-position] bg-[linear-gradient(105deg,#6b6b67_0%,#6b6b67_40%,#a8a8a2_48%,#a8a8a2_52%,#6b6b67_60%,#6b6b67_100%)] bg-size-[200%_auto]"
          >{headlineAccent}</span
        >

        {
          headlineTagline && (
            <span class="block text-2xl lg:text-4xl font-semibold text-black/30 tracking-normal mt-8">
              {headlineTagline}
            </span>
          )
        }
      </h1>
    </div>
  </div>
</section>
