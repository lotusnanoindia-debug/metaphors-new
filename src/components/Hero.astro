<section class="relative w-full pt-32 pb-24 lg:pt-48 lg:pb-32">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div class="max-w-4xl">
      <p
        class="text-[10px] font-bold uppercase tracking-[0.3em] text-black/30 mb-8 reveal"
      >
        Metaphors Design • Est. 1989
      </p>

      <h1
        class="text-6xl sm:text-7xl lg:text-[120px] font-medium leading-[0.96] tracking-tighter text-black mb-12 reveal"
      >
        Defining Modern<br />
        <span class="italic font-normal text-black/60"
          >Indian Architecture.</span
        >
      </h1>

      <p
        class="text-xl lg:text-3xl text-black/70 font-sans font-light leading-snug mb-16 reveal max-w-2xl"
      >
        A four-decade practice behind some of India's most significant
        corporate, institutional and civic spaces.
      </p>

      <div class="reveal flex flex-wrap items-center gap-10 mb-24">
        <a
          href="/contact"
          class="group relative px-12 py-5 bg-charcoal text-bone text-[11px] font-bold uppercase tracking-[0.3em] luxury-transition hover:shadow-[0_20px_50px_rgba(0,0,0,0.1)]"
        >
          <span class="relative z-10">Discuss Partnership</span>
          <div
            class="absolute inset-0 bg-white/5 opacity-0 group-hover:opacity-100 luxury-transition"
          >
          </div>
        </a>

        <a
          href="/archive"
          class="text-[11px] font-bold uppercase tracking-[0.3em] text-black/40 hover:text-black luxury-transition micro-hover pb-1"
        >
          View the Archive
        </a>
      </div>
    </div>
  </div>
</section>
