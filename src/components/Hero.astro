<section class="relative w-full pt-32 pb-24 lg:pt-48 lg:pb-32">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div class="max-w-5xl mx-auto flex flex-col items-center text-center">
      <p
        class="text-[10px] font-medium uppercase tracking-[0.3em] text-black/30 mb-8 reveal"
