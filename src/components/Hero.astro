---
const { eyebrow, headline, headlineAccent, headlineTagline, ctaLabel, ctaUrl } = Astro.props;
---

<section class="relative w-full pt-48 pb-24 lg:pt-56 lg:pb-32">
  <div class="mx-auto max-w-[1440px] px-6 lg:px-12">
    <div class="mx-auto flex max-w-5xl flex-col items-center text-center">
      <h1
        class="reveal mb-16 text-[clamp(3.8rem,11vw,9rem)] leading-[0.88] font-medium tracking-[-0.045em] select-none lg:text-[clamp(3.8rem,9vw,8rem)]"
      >
        <span class="text-charcoal block">{headline}</span>

        <span
          class="animate-sheen block bg-[linear-gradient(105deg,var(--color-charcoal)_0%,var(--color-charcoal)_40%,var(--color-charcoal-light)_48%,var(--color-charcoal-light)_52%,var(--color-charcoal)_60%,var(--color-charcoal)_100%)] bg-size-[200%_auto] bg-clip-text text-transparent will-change-[background-position]"
          >{headlineAccent}</span
        >

        {
          headlineTagline && (
            <span class="text-charcoal/30 mt-8 block text-2xl font-semibold tracking-normal lg:text-4xl">
              {headlineTagline}
            </span>
          )
        }
      </h1>
    </div>
  </div>
</section>
